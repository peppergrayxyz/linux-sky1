From 829428f2923ecd159be1deb8a452a9a456c59f81 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 3 Jan 2026 19:52:54 +1100
Subject: [PATCH 72/73] arm64: dts: cix: orion-o6n: Use level-low for power
 button interrupt

Change the power button interrupt type from IRQ_TYPE_EDGE_BOTH to
IRQ_TYPE_LEVEL_LOW. The Cadence GPIO controller (cdns,gpio-r1p02)
used by s5_gpio2 only supports level-triggered interrupts.

The power button is active-low (GPIO_ACTIVE_LOW), so when pressed
the GPIO line goes low. Using IRQ_TYPE_LEVEL_LOW properly triggers
the interrupt when the button is pressed.

This fixes a boot failure where the gpio-keys driver failed to
configure edge-triggered interrupts on the Cadence GPIO controller.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6n.dts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
index 71b5a2c961e37..b1453dbcec64e 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
@@ -322,7 +322,7 @@ power-button {
             debounce-interval = <300>;
 
 			interrupt-parent = <&s5_gpio2>;
-            interrupts = <1 IRQ_TYPE_EDGE_BOTH>;
+            interrupts = <1 IRQ_TYPE_LEVEL_LOW>;
 
             wakeup-source;
         };
