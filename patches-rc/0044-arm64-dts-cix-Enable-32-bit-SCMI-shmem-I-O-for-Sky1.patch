From 0dfcd509c6c3f3dc81481a363ad60ec48fbc513c Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Wed, 10 Dec 2025 10:08:08 +0800
Subject: [PATCH 44/73] arm64: dts: cix: Enable 32-bit SCMI shmem I/O for Sky1

Add reg-io-width = <4> to SCMI shared memory nodes to enable 32-bit
word-aligned I/O operations. The Sky1 SoC requires aligned 32-bit
accesses for SCMI communication; without this property, the kernel
defaults to byte-copy operations (memcpy_fromio) which don't work
correctly with this hardware.

This fixes CPU frequency scaling - without this change, only a subset
of OPPs are reported by SCMI firmware, limiting CPU frequencies to
~1.9GHz instead of the full 2.6GHz.

Affected nodes:
- ap2pm_scmi_mem (AP to PM communication)
- pm2ap_scmi_mem (PM to AP communication)
- ap_tfa_scmi_mem (AP to TF-A communication)
---
 arch/arm64/boot/dts/cix/sky1.dtsi | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index b53e2355a2414..2ceaba390e3d9 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -3468,6 +3468,7 @@ ap2pm_scmi_mem: ap2pm-shmem@0 {
 		#address-cells = <2>;
 		#size-cells = <2>;
 		reg = <0x0 0x06590000 0x0 0x80>;
+		reg-io-width = <4>;
 		status = "disabled";
 	};
 
@@ -3476,12 +3477,14 @@ pm2ap_scmi_mem: pm2pm-shmem@0 {
 		#address-cells = <2>;
 		#size-cells = <2>;
 		reg = <0x0 0x065a0000 0x0 0x80>;
+		reg-io-width = <4>;
 		status = "disabled";
 	};
 
 	ap_tfa_scmi_mem: ap2tf-shmem@1 {
 		compatible = "arm,scmi-shmem";
 		reg = <0x0 0x84380000 0x0 0x80>;
+		reg-io-width = <4>;
 		status = "disabled";
 	};
 
