From 3b370eff476843cef7b65879155a073185e6717c Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Tue, 23 Dec 2025 18:24:11 +1100
Subject: [PATCH 59/73] perf: arm_spe: Check per-CPU SPE support for
 heterogeneous systems

On heterogeneous big.LITTLE systems like CIX Sky1 (Cortex-A720 + A520),
only the big cores (A720) implement SPE while the little cores (A520)
do not. The driver currently gets the supported_cpus mask from the IRQ
partition and probes SPE capability on only one CPU, then assumes all
CPUs in the mask support SPE.

This causes an undefined instruction exception during CPU hotplug when
the driver tries to access SPE system registers on A520 cores:

  Internal error: Oops - Undefined instruction: 0000000002000000
  CPU: 1 UID: 0 PID: 20 Comm: cpuhp/1
  pc : arm_spe_pmu_disable_and_drain_local+0x8/0x38 [arm_spe_pmu]

Add arm_spe_pmu_cpu_supported() to check ID_AA64DFR0_EL1.PMSVer on the
current CPU, and skip SPE register access on CPUs where PMSVer is 0.
---
 drivers/perf/arm_spe_pmu.c | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/drivers/perf/arm_spe_pmu.c b/drivers/perf/arm_spe_pmu.c
index fa50645feddad..fade9b93f615f 100644
--- a/drivers/perf/arm_spe_pmu.c
+++ b/drivers/perf/arm_spe_pmu.c
@@ -1191,6 +1191,15 @@ static void __arm_spe_pmu_dev_probe(void *info)
 	spe_pmu->features |= SPE_PMU_FEAT_DEV_PROBED;
 }
 
+/* Check if current CPU supports SPE (for heterogeneous big.LITTLE systems) */
+static bool arm_spe_pmu_cpu_supported(void)
+{
+	u64 dfr0 = read_sysreg(id_aa64dfr0_el1);
+	int pmsver = cpuid_feature_extract_unsigned_field(dfr0,
+					ID_AA64DFR0_EL1_PMSVer_SHIFT);
+	return pmsver != 0;
+}
+
 static void __arm_spe_pmu_reset_local(void)
 {
 	/*
@@ -1212,6 +1221,10 @@ static void __arm_spe_pmu_setup_one(void *info)
 {
 	struct arm_spe_pmu *spe_pmu = info;
 
+	/* Skip CPUs that don't support SPE (e.g., A520 in big.LITTLE) */
+	if (!arm_spe_pmu_cpu_supported())
+		return;
+
 	__arm_spe_pmu_reset_local();
 	enable_percpu_irq(spe_pmu->irq, IRQ_TYPE_NONE);
 }
@@ -1220,6 +1233,10 @@ static void __arm_spe_pmu_stop_one(void *info)
 {
 	struct arm_spe_pmu *spe_pmu = info;
 
+	/* Skip CPUs that don't support SPE */
+	if (!arm_spe_pmu_cpu_supported())
+		return;
+
 	disable_percpu_irq(spe_pmu->irq);
 	__arm_spe_pmu_reset_local();
 }
