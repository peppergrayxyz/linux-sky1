From 7e0d849c9a0f5cf03c3c1f9288caba1fea3c88d6 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sun, 30 Nov 2025 00:51:17 +0800
Subject: [PATCH 09/73] pci: cadence: sky1: Fail probe gracefully when PCIe
 link is down

Mainline's cdns_pcie_host_link_setup() returns 0 even when the PCIe
link doesn't come up (e.g., empty slot). This differs from vendor
kernel behavior where the function returns an error on link failure.

Without this check, the driver proceeds to enumerate non-existent
devices on empty slots, which causes system hangs during config
space access.

Add an explicit link check after cdns_pcie_host_link_setup() returns.
If the link is down, fail probe with -ENODEV and log an informational
message. This matches vendor kernel behavior and allows empty slots
to be safely enabled in devicetree.
---
 drivers/pci/controller/cadence/pci-sky1.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/drivers/pci/controller/cadence/pci-sky1.c b/drivers/pci/controller/cadence/pci-sky1.c
index 24a301d17e8d6..0a9c9714bd5f0 100644
--- a/drivers/pci/controller/cadence/pci-sky1.c
+++ b/drivers/pci/controller/cadence/pci-sky1.c
@@ -2318,6 +2318,8 @@ static int sky1_pci_host_probe(struct pci_host_bridge *bridge)
 static int sky1_cdns_pcie_host_setup(struct cdns_pcie_rc *rc)
 {
 	struct pci_host_bridge *bridge = pci_host_bridge_from_priv(rc);
+	struct cdns_pcie *pcie = &rc->pcie;
+	struct device *dev = pcie->dev;
 	enum cdns_pcie_rp_bar bar;
 	int ret;
 
@@ -2325,6 +2327,17 @@ static int sky1_cdns_pcie_host_setup(struct cdns_pcie_rc *rc)
 	if (ret)
 		return ret;
 
+	/*
+	 * Mainline's cdns_pcie_host_link_setup() returns 0 even when link
+	 * doesn't come up. Check link status explicitly - if link is down
+	 * (empty slot), fail probe gracefully instead of trying to enumerate
+	 * non-existent devices which causes hangs.
+	 */
+	if (!cdns_pcie_link_up(pcie)) {
+		dev_info(dev, "PCIe link down, slot may be empty\n");
+		return -ENODEV;
+	}
+
 	for (bar = RP_BAR0; bar <= RP_NO_BAR; bar++)
 		rc->avail_ib_bar[bar] = true;
 
