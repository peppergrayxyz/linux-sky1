@@ -105,10 +105,18 @@ static inline bool topology_core_has_smt(int cpu)
 	return cpu_topology[cpu].thread_id != -1;
 }
 
-#else
+#ifdef CONFIG_CPU_FREQ
+struct cpufreq_policy;
