From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Tue, 3 Feb 2026 13:04:41 +1100
Subject: [PATCH] drm/cix: Add DRM bridge chain for PS185 DP-to-HDMI on Orange
 Pi 6 Plus
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Replace the vendor-style dp_to_hdmi property hack with a proper DRM
bridge chain for the Parade PS185 DP-to-HDMI converter on the Orange
Pi 6 Plus board.

The bridge chain is: dp4 (encoder) -> simple-bridge (PS185) ->
display-connector (HDMI-A). The PS185 power-down GPIO is managed by
a regulator-fixed node with always-on/boot-on, ensuring the chip is
powered before HPD detection occurs.

In the DPTX driver, look up the downstream bridge via
devm_drm_of_get_bridge() on output port 2 and attach it with
DRM_BRIDGE_ATTACH_NO_CONNECTOR. Walk the bridge chain to the
terminal bridge to determine the correct connector type
(DRM_MODE_CONNECTOR_HDMIA) without any custom DT properties.

Boards without a port@2 (Orion O6/O6N) are unaffected — the bridge
lookup returns -ENODEV which is treated as "no bridge".
---
 .../boot/dts/cix/sky1-orangepi-6-plus.dts     | 61 +++++++++++++++++--
 drivers/gpu/drm/cix/dptx/trilin_dptx.h        |  1 +
 drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c    | 14 +++++
 drivers/gpu/drm/cix/dptx/trilin_drm.c         | 18 +++++-
 4 files changed, 88 insertions(+), 6 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orangepi-6-plus.dts b/arch/arm64/boot/dts/cix/sky1-orangepi-6-plus.dts
index a22a0d06e47a0..b059fce0f0010 100644
--- a/arch/arm64/boot/dts/cix/sky1-orangepi-6-plus.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orangepi-6-plus.dts
@@ -235,6 +235,54 @@ vdd_1v8_pcie_x1_0_rc: regulator-vdd-1v8-pcie-x1-0-rc {
 		status = "okay";
 	};
 
+	ps185_pdb: regulator-ps185-pdb {
+		compatible = "regulator-fixed";
+		regulator-name = "PS185_PDB";
+		pinctrl-names = "default";
+		pinctrl-0 = <&pinctrl_dp_to_hdmi_ps185>;
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		gpio = <&fch_gpio0 31 GPIO_ACTIVE_LOW>;
+		regulator-boot-on;
+		regulator-always-on;
+	};
+
+	ps185: dp-to-hdmi-bridge {
+		compatible = "parade,ps185hdm";
+
+		ports {
+			#address-cells = <1>;
+			#size-cells = <0>;
+
+			port@0 {
+				reg = <0>;
+
+				ps185_in: endpoint {
+					remote-endpoint = <&dp4_out>;
+				};
+			};
+
+			port@1 {
+				reg = <1>;
+
+				ps185_out: endpoint {
+					remote-endpoint = <&hdmi_con_in>;
+				};
+			};
+		};
+	};
+
+	hdmi_connector: hdmi-connector {
+		compatible = "hdmi-connector";
+		type = "a";
+
+		port {
+			hdmi_con_in: endpoint {
+				remote-endpoint = <&ps185_out>;
+			};
+		};
+	};
+
 /*	gpio-leds {
 		compatible = "gpio-leds";
 		pinctrl-names = "default";
@@ -1129,11 +1177,6 @@ dp3_1_in: endpoint {
 &dp4 {
 	status = "okay";
 	cix,dp-max-rate = <540000>;
-	dp_to_hdmi = "yes";
-	side_by_side_master = <0>;
-	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_dp_to_hdmi_ps185>;
-	pdb-gpios = <&fch_gpio0 31 GPIO_ACTIVE_LOW>;
 
 	ports {
 		#address-cells = <1>;
@@ -1154,6 +1197,14 @@ dp4_1_in: endpoint {
 				remote-endpoint = <&dpu4_pipe1_out>;
 			};
 		};
+
+		port@2 {
+			reg = <2>;
+
+			dp4_out: endpoint {
+				remote-endpoint = <&ps185_in>;
+			};
+		};
 	};
 };
 
diff --git a/drivers/gpu/drm/cix/dptx/trilin_dptx.h b/drivers/gpu/drm/cix/dptx/trilin_dptx.h
index 69b1cf0a81d6c..c14384ada4229 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_dptx.h
+++ b/drivers/gpu/drm/cix/dptx/trilin_dptx.h
@@ -422,6 +422,7 @@ struct trilin_dp {
 	struct trilin_encoder encoder; //for sst
 	struct trilin_connector connector; //for sst
 	struct drm_panel *edp_panel;
+	struct drm_bridge *next_bridge;
 	struct device *dev;
 	struct trilin_dpsub *dpsub;
 	struct drm_device **drm;
diff --git a/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c b/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
index a2b016610e329..4eacfdd27060a 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
+++ b/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
@@ -16,6 +16,7 @@
 //	along with this program. If not, see <http://www.gnu.org/licenses/>.
 //------------------------------------------------------------------------------
 #include <drm/drm_atomic_helper.h>
+#include <drm/drm_bridge.h>
 #include <drm/drm_device.h>
 //#include <drm/display/drm_dp_helper.h>
 #include <drm/drm_of.h>
@@ -159,6 +160,19 @@ static int trilin_dptx_cix_bind(struct device *comp, struct device *master,
 	if (ret)
 		return ret;
 
+	/* Look for downstream bridge on output port (port 2) */
+	{
+		struct drm_bridge *bridge;
+
+		bridge = devm_drm_of_get_bridge(comp, comp->of_node, 2, 0);
+		if (IS_ERR(bridge)) {
+			if (PTR_ERR(bridge) == -EPROBE_DEFER)
+				return -EPROBE_DEFER;
+			bridge = NULL;
+		}
+		dpsub->dp->next_bridge = bridge;
+	}
+
 	ret = trilin_dp_drm_init(dpsub);
 	if (ret)
 		return ret;
diff --git a/drivers/gpu/drm/cix/dptx/trilin_drm.c b/drivers/gpu/drm/cix/dptx/trilin_drm.c
index 217050e337667..53954a5bed0ce 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_drm.c
+++ b/drivers/gpu/drm/cix/dptx/trilin_drm.c
@@ -17,6 +17,7 @@
 //------------------------------------------------------------------------------
 
 #include <drm/drm_atomic_helper.h>
+#include <drm/drm_bridge.h>
 #include <drm/drm_crtc.h>
 #include <drm/drm_device.h>
 #include <drm/drm_edid.h>
@@ -1150,8 +1151,23 @@ int trilin_dp_drm_init(struct trilin_dpsub *dpsub)
 	drm_encoder_helper_add(encoder, &trilin_dp_encoder_helper_funcs);
 
 	connector->polled = DRM_CONNECTOR_POLL_HPD;
-	if (dp->edp_panel)
+	if (dp->edp_panel) {
 		drm_mode_connector = DRM_MODE_CONNECTOR_eDP;
+	} else if (dp->next_bridge) {
+		ret = drm_bridge_attach(encoder, dp->next_bridge, NULL,
+					DRM_BRIDGE_ATTACH_NO_CONNECTOR);
+		if (!ret) {
+			/* Walk chain to terminal bridge for connector type */
+			struct drm_bridge *b;
+
+			for (b = dp->next_bridge;
+			     drm_bridge_get_next_bridge(b);
+			     b = drm_bridge_get_next_bridge(b))
+				;
+			if (b->type)
+				drm_mode_connector = b->type;
+		}
+	}
 
 	ret = drm_connector_init(encoder->dev, connector,
 				 &trilin_dp_connector_funcs,
