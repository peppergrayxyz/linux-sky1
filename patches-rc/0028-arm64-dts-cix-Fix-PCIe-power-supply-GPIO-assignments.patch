From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Tue, 3 Feb 2026 20:16:23 +1100
Subject: [PATCH] arm64: dts: cix: Fix PCIe power supply GPIO assignments on
 Orion O6/O6N

Fix several vendor DTS bugs in PCIe power supply GPIO mappings,
verified against board schematics:

- WiFi power (WLAN_PWREN): pinctrl was muxing GPIO012 (M2_SSD_PWREN)
  but gpio controller s5_gpio0[12] drives GPIO013 (WLAN_PWREN). Fix
  pinctrl to CIX_PAD_GPIO013 and rename regulator to vdd_3v3_wlan.

- NVMe power (M2_SSD_PWREN): pcie_x4_rc had no vcc-pcie-supply at
  all. Add vdd_3v3_nvme regulator on GPIO012 / s5_gpio0[11].

- GBE power labels swapped: gbe1_power was using GPIO022
  (5GPHY2_PWR_EN = GBE2) and gbe2_power was using GPIO010
  (LOM_PWREN = GBE1). Swap to match schematic. Also fix controller
  comments: pcie_x1_0_rc = PCIE3 = GBE1, pcie_x1_1_rc = PCIE4 = GBE2.

The s5_gpio0 offset mapping (s5_gpio0[N] = GPIO(N+1) for pins 0-13)
was confirmed by cross-referencing with the Orange Pi 6 Plus DTS which
correctly uses s5_gpio0[11] for GPIO012 and s5_gpio0[12] for GPIO013.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts  | 58 +++++++++++++++-------
 arch/arm64/boot/dts/cix/sky1-orion-o6n.dts | 58 +++++++++++++++-------
 2 files changed, 78 insertions(+), 38 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index c9692116d1576..20ad40d084c08 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -245,11 +245,11 @@ vgfx_power: vgfx-power {
 		off-on-delay-us = <15000>;
 	};
 
-	vdd_3v3_pcie: regulator-vdd-3v3-pcie {
+	vdd_3v3_wlan: regulator-vdd-3v3-wlan {
 		compatible = "regulator-fixed";
-		regulator-name = "vdd_3v3_pcie";
+		regulator-name = "vdd_3v3_wlan";
 		pinctrl-names = "default";
-		pinctrl-0 = <&wifi_vbat_gpio>;
+		pinctrl-0 = <&wlan_pwren_gpio>;
 		regulator-min-microvolt = <3300000>;
 		regulator-max-microvolt = <3300000>;
 		gpio = <&s5_gpio0 12 GPIO_ACTIVE_HIGH>;
@@ -258,6 +258,19 @@ vdd_3v3_pcie: regulator-vdd-3v3-pcie {
 		off-on-delay-us = <15000>;
 	};
 
+	vdd_3v3_nvme: regulator-vdd-3v3-nvme {
+		compatible = "regulator-fixed";
+		regulator-name = "vdd_3v3_nvme";
+		pinctrl-names = "default";
+		pinctrl-0 = <&nvme_pwren_gpio>;
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		gpio = <&s5_gpio0 11 GPIO_ACTIVE_HIGH>;
+		regulator-pull-down;
+		enable-active-high;
+		off-on-delay-us = <15000>;
+	};
+
 	gbe1_power_3v3: gbe1-power-3v3 {
 		compatible = "regulator-fixed";
 		regulator-name = "gbe1_power_3v3";
@@ -265,7 +278,7 @@ gbe1_power_3v3: gbe1-power-3v3 {
 		pinctrl-0 = <&gbe1_poweren_gpio>;
 		regulator-min-microvolt = <3300000>;
 		regulator-max-microvolt = <3300000>;
-		gpio = <&s5_gpio2 7 GPIO_ACTIVE_HIGH>;
+		gpio = <&s5_gpio0 9 GPIO_ACTIVE_HIGH>;
 		regulator-pull-down;
 		enable-active-high;
 		off-on-delay-us = <15000>;
@@ -288,7 +301,7 @@ gbe2_power_3v3: gbe2-power-3v3 {
 		pinctrl-0 = <&gbe2_poweren_gpio>;
 		regulator-min-microvolt = <3300000>;
 		regulator-max-microvolt = <3300000>;
-		gpio = <&s5_gpio0 9 GPIO_ACTIVE_HIGH>;
+		gpio = <&s5_gpio2 7 GPIO_ACTIVE_HIGH>;
 		regulator-pull-down;
 		enable-active-high;
 		off-on-delay-us = <15000>;
@@ -348,9 +361,15 @@ CIX_PAD_GPIO014_FUNC_GPIO014  (PULL_UP|DS_LEVEL4) /* GPIO14 hp det */
 		>;
 	};
 
-	wifi_vbat_gpio: wifi_vbat_gpio {
+	wlan_pwren_gpio: wlan_pwren_gpio {
+		sky1,pins = <
+			CIX_PAD_GPIO013_FUNC_GPIO013  (PULL_UP|DS_LEVEL4) /* GPIO013 - S5_gpio0 12 */
+		>;
+	};
+
+	nvme_pwren_gpio: nvme_pwren_gpio {
 		sky1,pins = <
-			CIX_PAD_GPIO012_FUNC_GPIO012  (PULL_UP|DS_LEVEL4) /* GPIO0-12 */
+			CIX_PAD_GPIO012_FUNC_GPIO012  (PULL_UP|DS_LEVEL4) /* GPIO012 - S5_gpio0 11 */
 		>;
 	};
 
@@ -560,13 +579,13 @@ CIX_PAD_GPIO010_FUNC_GPIO010 (PULL_UP|DS_LEVEL4) /* GPIO010 - S5_gpio0 9 */
 
 	gbe1_poweren_gpio: gbe1_poweren_gpio {
 		sky1,pins = <
-			CIX_PAD_GPIO022_FUNC_GPIO022 (PULL_UP|ST|DS_LEVEL7) /* GPIO022 - S5_gpio2 7 */
+			CIX_PAD_GPIO010_FUNC_GPIO010 (PULL_UP|DS_LEVEL4) /* GPIO010 - S5_gpio0 9 - LOM_PWREN */
 		>;
 	};
 
 	gbe2_poweren_gpio: gbe2_poweren_gpio {
 		sky1,pins = <
-			CIX_PAD_GPIO010_FUNC_GPIO010 (PULL_UP|DS_LEVEL4) /* GPIO010 - S5_gpio0 9 */
+			CIX_PAD_GPIO022_FUNC_GPIO022 (PULL_UP|ST|DS_LEVEL7) /* GPIO022 - S5_gpio2 7 - 5GPHY2_PWR_EN */
 		>;
 	};
 
@@ -2151,12 +2170,13 @@ &pcie_x8_rc {
 	status = "okay";
 };
 
-/* M.2 M-Key */
+/* M.2 M-Key (NVMe) */
 &pcie_x4_rc {
 	plat-evk;
 	pinctrl-names = "default";
 	pinctrl-0 = <&pinctrl_pcie_x4_rc>;
 	reset-gpios = <&s5_gpio0 3 GPIO_ACTIVE_HIGH>;
+	vcc-pcie-supply = <&vdd_3v3_nvme>;
 	status = "okay";
 };
 
@@ -2165,24 +2185,24 @@ &pcie_x2_rc {
 	pinctrl-names = "default";
 	pinctrl-0 = <&pinctrl_pcie_x2_rc>, <&wlan_radio_gpio>;
 	reset-gpios = <&s5_gpio0 4 GPIO_ACTIVE_HIGH>;
-	vcc-pcie-supply = <&vdd_3v3_pcie>;
+	vcc-pcie-supply = <&vdd_3v3_wlan>;
 	status = "okay";
 };
 
-/* 5GBE-1 */
-&pcie_x1_1_rc {
+/* 5GBE-1 (PCIE3) */
+&pcie_x1_0_rc {
 	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_pcie_x1_1_rc>;
-	reset-gpios = <&s5_gpio0 2 GPIO_ACTIVE_HIGH>;
+	pinctrl-0 = <&pinctrl_pcie_x1_0_rc>;
+	reset-gpios = <&s5_gpio0 5 GPIO_ACTIVE_HIGH>;
 	vcc-pcie-supply = <&gbe1_power_3v3>;
 	status = "okay";
 };
 
-/* 5GBE-2 */
-&pcie_x1_0_rc {
+/* 5GBE-2 (PCIE4) */
+&pcie_x1_1_rc {
 	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_pcie_x1_0_rc>;
-	reset-gpios = <&s5_gpio0 5 GPIO_ACTIVE_HIGH>;
+	pinctrl-0 = <&pinctrl_pcie_x1_1_rc>;
+	reset-gpios = <&s5_gpio0 2 GPIO_ACTIVE_HIGH>;
 	vcc-pcie-supply = <&gbe2_power_3v3>;
 	status = "okay";
 };
