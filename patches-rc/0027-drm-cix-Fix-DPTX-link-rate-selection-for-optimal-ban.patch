From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Tue, 3 Feb 2026 19:11:59 +1100
Subject: [PATCH] drm/cix: Fix DPTX link rate selection for optimal bandwidth
 margin

Replace the minimum-rate link selection algorithm with one that ensures
adequate bandwidth margin. The old code picked the lowest link rate
whose theoretical capacity exceeded the pixel clock, leaving zero
margin for SSC jitter, protocol overhead, and blanking periods.

The new select_link_rate() function requires at least 5% margin over
the pixel clock before accepting a link rate, and falls back to the
maximum supported rate if no rate meets the threshold.

Also promote the compute_config log message from DP_DEBUG to DP_INFO
to show the selected mode, bpc, link rate, and lane count at modeset
time, making display debugging practical without recompilation.

Tested: USB-C DP output correctly selects HBR2 for 1080p@120Hz at
10bpc (50% margin) and 1080p@240Hz at 8bpc (16% margin), instead of
the previous RBR which could not carry 10bpc at 120Hz.
---
 drivers/gpu/drm/cix/dptx/trilin_drm.c | 59 +++++++++++++++++++--------
 1 file changed, 41 insertions(+), 18 deletions(-)

diff --git a/drivers/gpu/drm/cix/dptx/trilin_drm.c b/drivers/gpu/drm/cix/dptx/trilin_drm.c
index 53954a5bed0ce..2b9e4a939eaa1 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_drm.c
+++ b/drivers/gpu/drm/cix/dptx/trilin_drm.c
@@ -878,6 +878,37 @@ static bool compute_available_clock_rate(struct trilin_dp *dp,
 	return false;
 }
 
+/*
+ * Select the optimal link rate for the given mode and bpp.
+ *
+ * Instead of picking the absolute minimum link rate that can carry the pixel
+ * clock, this function selects a rate with adequate bandwidth margin. A link
+ * rate is considered adequate when the available bandwidth exceeds the required
+ * pixel clock by at least 5%, accounting for SSC jitter and protocol overhead.
+ * If no rate meets the margin threshold, the highest supported rate is used.
+ */
+static int select_link_rate(struct trilin_dp *dp, int clock, int bpp)
+{
+	int max_rate = dp->link_config.max_rate;
+	u8 max_lanes = dp->link_config.max_lanes;
+	int i, capacity;
+	int best_rate = max_rate;
+
+	for (i = 0; i < ARRAY_SIZE(DP_COMMON_LINK_RATES); i++) {
+		if (DP_COMMON_LINK_RATES[i] > max_rate)
+			break;
+		capacity = trilin_dp_max_rate(DP_COMMON_LINK_RATES[i],
+					      max_lanes, bpp);
+		/* Require 5% margin over pixel clock for SSC and overhead */
+		if (clock * 100 <= capacity * 95) {
+			best_rate = DP_COMMON_LINK_RATES[i];
+			break;
+		}
+	}
+
+	return best_rate;
+}
+
 int trilin_dp_encoder_compute_config(struct drm_encoder *encoder,
 				  struct drm_crtc_state *crtc_state,
 				  struct drm_connector_state *connector_state,
@@ -895,10 +926,9 @@ int trilin_dp_encoder_compute_config(struct drm_encoder *encoder,
 	int color_format;// = BIT(__ffs(info->color_formats));
 	int info_formats = info->color_formats;
 	bool success = false;
-	int rate, max_rate = dp->link_config.max_rate;
 	u8 link_rate_bw_code, i;
 	u8 max_lanes = dp->link_config.max_lanes;
-	int link_rate = max_rate;
+	int link_rate = dp->link_config.max_rate;
 
 	if (!(info_formats & DRM_COLOR_FORMAT_RGB444)) {
 		info_formats |= DRM_COLOR_FORMAT_RGB444;
@@ -945,25 +975,18 @@ int trilin_dp_encoder_compute_config(struct drm_encoder *encoder,
 
 	kcrtc_st->output_format = color_format; //Let DPU to know the format.
 
-	if (!dp->mst.mst_active) {
-		for (i = 0; i < ARRAY_SIZE(DP_COMMON_LINK_RATES); i++) {
-			if (DP_COMMON_LINK_RATES[i] > max_rate)
-				break;
-			rate = trilin_dp_max_rate(DP_COMMON_LINK_RATES[i], max_lanes, bpp);
-			if (adjusted_mode->clock <= rate) {
-				link_rate = DP_COMMON_LINK_RATES[i];
-				break;
-			}
-		}
-	}
+	if (!dp->mst.mst_active)
+		link_rate = select_link_rate(dp, adjusted_mode->clock, bpp);
 
 	link_rate_bw_code = drm_dp_link_rate_to_bw_code(link_rate);
 
-	DP_DEBUG(
-		"Note: disp->bpc(%d) bpc(%d) bpp(%d) colorspace=%d clock=%d format=0x%0x color_formats=%0x link_rate_bw=%0x %d request_max_bpc=%d\n",
-		info->bpc, bpc, bpp, colorspace, adjusted_mode->clock,
-		color_format, info->color_formats, link_rate_bw_code, link_rate,
-		connector_state->max_requested_bpc);
+	DP_INFO("mode %s clock=%d bpc=%d bpp=%d link_rate=%d (%s) lanes=%d max_bpc=%d\n",
+		adjusted_mode->name, adjusted_mode->clock, bpc, bpp,
+		link_rate,
+		link_rate == 810000 ? "HBR3" :
+		link_rate == 540000 ? "HBR2" :
+		link_rate == 270000 ? "HBR" : "RBR",
+		max_lanes, connector_state->max_requested_bpc);
 
 	ret = trilin_dp_mode_configure(dp, adjusted_mode->clock, link_rate_bw_code, bpp, false);
 	if (ret < 0)
