From 285aa2bb6bbc370ff71b9fd89fb7eed7726725b8 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 19 Dec 2025 22:51:33 +1100
Subject: [PATCH 58/73] arm64: cix: change core Sky1 Kconfig entries from
 tristate to bool

Core SoC infrastructure drivers must be built-in and cannot be modules:
- CIX_MBOX (mailbox for SCMI)
- RESET_SKY1 (reset controller)
- PINCTRL_SKY1_BASE (pin control)
- CLK_SKY1_AUDSS (audio clock controller)
- PCI_SKY1 (PCIe controller)
- HWSPINLOCK_SKY1 (hardware spinlock)
- PHY_CIX_PCIE, PHY_CIX_USB2, PHY_CIX_USB3, PHY_CIX_USBDP (PHY drivers)

Board-specific drivers (PWM, watchdog, NVMEM, socinfo, USB glue,
Type-C PD) remain tristate for flexibility across different Sky1 boards.
---
 drivers/clk/cix/Kconfig                | 2 +-
 drivers/hwspinlock/Kconfig             | 2 +-
 drivers/mailbox/Kconfig                | 2 +-
 drivers/pci/controller/cadence/Kconfig | 2 +-
 drivers/phy/cix/Kconfig                | 8 ++++----
 drivers/pinctrl/cix/Kconfig            | 2 +-
 drivers/reset/Kconfig                  | 2 +-
 7 files changed, 10 insertions(+), 10 deletions(-)

diff --git a/drivers/clk/cix/Kconfig b/drivers/clk/cix/Kconfig
index 64517f873bd1a..d572e14db5bb5 100644
--- a/drivers/clk/cix/Kconfig
+++ b/drivers/clk/cix/Kconfig
@@ -1,7 +1,7 @@
 # SPDX-License-Identifier: GPL-2.0-only
 
 config CLK_SKY1_AUDSS
-	tristate "CIX Sky1 Audio Subsystem Clock Controller"
+	bool "CIX Sky1 Audio Subsystem Clock Controller"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on MFD_SYSCON
 	depends on COMMON_CLK
diff --git a/drivers/hwspinlock/Kconfig b/drivers/hwspinlock/Kconfig
index 0a044c00fe8a4..b84c892e18031 100644
--- a/drivers/hwspinlock/Kconfig
+++ b/drivers/hwspinlock/Kconfig
@@ -54,7 +54,7 @@ config HWSPINLOCK_SUN6I
 	  If unsure, say N.
 
 config HWSPINLOCK_SKY1
-	tristate "Sky1 Hardware Spinlock device"
+	bool "Sky1 Hardware Spinlock device"
 	depends on ARCH_CIX || COMPILE_TEST
 	help
 	  Say y here to support the Sky1 Hardware Spinlock device which provides
diff --git a/drivers/mailbox/Kconfig b/drivers/mailbox/Kconfig
index 29f16f220384f..5b719705eff25 100644
--- a/drivers/mailbox/Kconfig
+++ b/drivers/mailbox/Kconfig
@@ -360,7 +360,7 @@ config THEAD_TH1520_MBOX
 	  things.
 
 config CIX_MBOX
-        tristate "CIX Mailbox"
+        bool "CIX Mailbox"
         depends on ARCH_CIX || COMPILE_TEST
         depends on OF
         help
diff --git a/drivers/pci/controller/cadence/Kconfig b/drivers/pci/controller/cadence/Kconfig
index a04a38e54c06c..ad5ad2d534f94 100644
--- a/drivers/pci/controller/cadence/Kconfig
+++ b/drivers/pci/controller/cadence/Kconfig
@@ -78,7 +78,7 @@ config PCI_J721E_EP
 	  core.
 
 config PCI_SKY1
-	tristate "CIX Sky1 PCIe controller (host mode)"
+	bool "CIX Sky1 PCIe controller (host mode)"
 	depends on OF && (ARCH_CIX || COMPILE_TEST)
 	select PCIE_CADENCE_HOST
 	help
diff --git a/drivers/phy/cix/Kconfig b/drivers/phy/cix/Kconfig
index 0b649df0a0cef..dcf77de2ffedb 100644
--- a/drivers/phy/cix/Kconfig
+++ b/drivers/phy/cix/Kconfig
@@ -1,7 +1,7 @@
 # SPDX-License-Identifier: GPL-2.0-only
 
 config PHY_CIX_PCIE
-	tristate "CIX Sky1 PCIe PHY driver"
+	bool "CIX Sky1 PCIe PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
 	select GENERIC_PHY
@@ -11,7 +11,7 @@ config PHY_CIX_PCIE
 	  on CIX Sky1 platforms.
 
 config PHY_CIX_USB2
-	tristate "CIX Sky1 USB2 PHY driver"
+	bool "CIX Sky1 USB2 PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
 	select GENERIC_PHY
@@ -19,7 +19,7 @@ config PHY_CIX_USB2
 	  Enable this to support the USB2 PHY on CIX Sky1 SoCs.
 
 config PHY_CIX_USB3
-	tristate "CIX Sky1 USB3 PHY driver"
+	bool "CIX Sky1 USB3 PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
 	select GENERIC_PHY
@@ -27,7 +27,7 @@ config PHY_CIX_USB3
 	  Enable this to support the USB3 PHY on CIX Sky1 SoCs.
 
 config PHY_CIX_USBDP
-	tristate "CIX Sky1 USB-DP combo PHY driver"
+	bool "CIX Sky1 USB-DP combo PHY driver"
 	depends on ARCH_CIX || COMPILE_TEST
 	depends on OF
 	select GENERIC_PHY
diff --git a/drivers/pinctrl/cix/Kconfig b/drivers/pinctrl/cix/Kconfig
index b711ed0eb5af6..64593fe0121c7 100644
--- a/drivers/pinctrl/cix/Kconfig
+++ b/drivers/pinctrl/cix/Kconfig
@@ -1,6 +1,6 @@
 # SPDX-License-Identifier: GPL-2.0-only
 config PINCTRL_SKY1_BASE
-	tristate
+	bool
 	select GENERIC_PINCTRL_GROUPS
 	select GENERIC_PINMUX_FUNCTIONS
 	select GENERIC_PINCONF
diff --git a/drivers/reset/Kconfig b/drivers/reset/Kconfig
index 3fdc7a0130ed6..8bc1af280b77d 100644
--- a/drivers/reset/Kconfig
+++ b/drivers/reset/Kconfig
@@ -399,7 +399,7 @@ source "drivers/reset/hisilicon/Kconfig"
 source "drivers/reset/tegra/Kconfig"
 
 config RESET_SKY1
-	tristate "CIX Sky1 Reset Controller"
+	bool "CIX Sky1 Reset Controller"
 	depends on ARCH_CIX || COMPILE_TEST
 	default ARCH_CIX
 	help
