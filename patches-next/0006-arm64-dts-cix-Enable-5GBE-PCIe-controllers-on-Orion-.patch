From a73e305228476e8c520c33d11a29b3c5cf49eb41 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 29 Nov 2025 18:29:04 +0800
Subject: [PATCH 06/73] arm64: dts: cix: Enable 5GBE PCIe controllers on Orion
 O6

Enable both RTL8126 5GbE ethernet controllers (pcie_x1_0_rc and
pcie_x1_1_rc) on the Radxa Orion O6 board. These use separate PCIe
x1 lanes with dedicated reset GPIOs and power supplies.

Remove IO ranges from PCIe controller nodes (pcie_x2_rc, pcie_x1_0_rc,
pcie_x1_1_rc) since the RTL8852BE WiFi and RTL8126 5GbE devices use
only MMIO - removing unused IO ranges avoids allocation failures.

Add pci=realloc bootarg as a workaround for IO BAR allocation issues.
The RTL8126/RTL8852BE devices have IO BARs in hardware that cannot be
satisfied without an IO window on the host bridges, and without realloc
the PCI core leaves resource state corrupted causing kernel panics.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts | 24 ++++++++++++++++++-----
 arch/arm64/boot/dts/cix/sky1.dtsi         | 21 ++++++++++++++------
 2 files changed, 34 insertions(+), 11 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index 4e7578a4f0ec6..688b95519ee7f 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -16,6 +16,12 @@ / {
 
 	chosen {
 		stdout-path = &uart2;
+		/*
+		 * pci=realloc needed because RTL8126/RTL8852BE have IO BARs
+		 * that can't be allocated (no IO window on bridges), and
+		 * without realloc the PCI core leaves state corrupted.
+		 */
+		bootargs = "pci=realloc";
 	};
 
 	dummy_codec: dummy_codec {
@@ -2073,7 +2079,7 @@ &smmu_mmhub {
 	status = "okay";
 };
 
-/* PCIe X16 Slot - disabled to avoid resource conflict during boot */
+/* PCIe X16 Slot - disabled, causes SCMI timeouts */
 &pcie_x8_rc {
 	status = "disabled";
 };
@@ -2096,14 +2102,22 @@ &pcie_x2_rc {
 	status = "okay";
 };
 
-/* 5GBE-1 - disabled to avoid resource conflict during boot */
+/* 5GBE-1 */
 &pcie_x1_1_rc {
-	status = "disabled";
+	pinctrl-names = "default";
+	pinctrl-0 = <&pinctrl_pcie_x1_1_rc>;
+	reset-gpios = <&s5_gpio0 2 GPIO_ACTIVE_HIGH>;
+	vcc-pcie-supply = <&gbe1_power_3v3>;
+	status = "okay";
 };
 
-/* 5GBE-2 - disabled to avoid resource conflict during boot */
+/* 5GBE-2 */
 &pcie_x1_0_rc {
-	status = "disabled";
+	pinctrl-names = "default";
+	pinctrl-0 = <&pinctrl_pcie_x1_0_rc>;
+	reset-gpios = <&s5_gpio0 5 GPIO_ACTIVE_HIGH>;
+	vcc-pcie-supply = <&gbe2_power_3v3>;
+	status = "okay";
 };
 
 &pcie1_phy {
diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 94f16aa9461a2..bb002d66d61d9 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -2212,8 +2212,11 @@ pcie_x2_rc: pcie@0a0c0000 { /* X2 */
 			max-link-speed = <4>;
 			num-lanes = <2>;
 			max-payload = <512>;
-			ranges = <0x01000000 0x0 0x40100000 0x0 0x40100000 0x0 0x00100000>,
-				 <0x02000000 0x0 0x40200000 0x0 0x40200000 0x0 0x0fe00000>,
+			/*
+			 * Note: IO range removed - RTL8852BE WiFi uses only MMIO.
+			 * Removing unused IO ranges avoids allocation failures.
+			 */
+			ranges = <0x02000000 0x0 0x40200000 0x0 0x40200000 0x0 0x0fe00000>,
 				 <0x43000000 0x10 0x00000000 0x10 0x00000000 0x04 0x00000000>;
 			cdns,no-inbound-bar;
 			clocks = <&scmi_clk CLK_TREE_PCIE_CTRL2_CLK>,
@@ -2295,8 +2298,11 @@ pcie_x1_1_rc: pcie@0a0e0000 { /* X1_1 */
 			max-link-speed = <4>;
 			num-lanes = <1>;
 			max-payload = <512>;
-			ranges = <0x01000000 0x0 0x38100000 0x0 0x38100000 0x0 0x00100000>,
-				 <0x02000000 0x0 0x38200000 0x0 0x38200000 0x0 0x07e00000>,
+			/*
+			 * Note: IO range removed - RTL8126 5GbE uses only MMIO.
+			 * Removing unused IO ranges avoids allocation failures.
+			 */
+			ranges = <0x02000000 0x0 0x38200000 0x0 0x38200000 0x0 0x07e00000>,
 				 <0x43000000 0x0C 0x00000000 0x0C 0x00000000 0x04 0x00000000>;
 			cdns,no-inbound-bar;
 			clocks = <&scmi_clk CLK_TREE_PCIE_CTRL4_CLK>,
@@ -2344,8 +2350,11 @@ pcie_x1_0_rc: pcie@0a0d0000 { /* X1_0 */
 			max-link-speed = <4>;
 			num-lanes = <1>;
 			max-payload = <512>;
-			ranges = <0x01000000 0x0 0x30100000 0x0 0x30100000 0x0 0x00100000>,
-				 <0x02000000 0x0 0x30200000 0x0 0x30200000 0x0 0x07e00000>,
+			/*
+			 * Note: IO range removed - RTL8126 5GbE uses only MMIO.
+			 * Removing unused IO ranges avoids allocation failures.
+			 */
+			ranges = <0x02000000 0x0 0x30200000 0x0 0x30200000 0x0 0x07e00000>,
 				 <0x43000000 0x08 0x00000000 0x08 0x00000000 0x04 0x00000000>;
 			cdns,no-inbound-bar;
 			clocks = <&scmi_clk CLK_TREE_PCIE_CTRL3_CLK>,
-- 
