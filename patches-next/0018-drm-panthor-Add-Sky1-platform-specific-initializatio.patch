+	if (ptdev->pm_domain_devs[1])
+		dev_pm_genpd_set_performance_state(ptdev->pm_domain_devs[1], 1000);
+
 	panthor_devfreq_resume(ptdev);
 
 	if (panthor_device_is_initialized(ptdev) &&
