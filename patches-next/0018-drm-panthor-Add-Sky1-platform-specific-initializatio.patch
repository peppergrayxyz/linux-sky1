 #include <linux/clk.h>
+#include <linux/delay.h>
 #include <linux/mm.h>
 #include <linux/platform_device.h>
 #include <linux/pm_domain.h>
@@ -62,9 +63,131 @@ static int panthor_clk_init(struct panthor_device *ptdev)
