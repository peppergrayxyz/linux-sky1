From d63f45c97e56fa8b2ded238866ec9a5c5b39e7df Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sun, 30 Nov 2025 20:04:09 +0800
Subject: [PATCH 14/73] arm64: dts: cix: Re-enable USB3 PHYs disabled during
 debug

Re-enable USB PHYs that were disabled as debug workarounds during
early boot debugging:

- usb3_phy0: USB3 PHY for controller 0
- usb3_phy2: USB3 PHY for controller 2
- usbc_phy2: USB-C PHY 2
- usbc_phy3: USB-C PHY 3

These should match the vendor DTS which has all PHYs enabled.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index a1eca84153608..c8e9505dff392 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -1379,7 +1379,7 @@ usbdpphy0_lane_switch: endpoint@0 {
 };
 
 &usb3_phy0 {
-	status = "disabled";
+	status = "okay";
 };
 
 &usbc0_dp_phy {
@@ -1445,7 +1445,7 @@ &usbss_1 {
 };
 
 &usbc_phy2 {
-	status = "disabled";
+	status = "okay";
 	orientation-switch;
 	svid = <0xff01>;
 	default_conf = /bits/ 8 <0x03>;
@@ -1463,7 +1463,7 @@ usbdpphy2_lane_switch: endpoint@0 {
 };
 
 &usb3_phy2 {
-	status = "disabled";
+	status = "okay";
 };
 
 &usbc2_dp_phy {
@@ -1495,7 +1495,7 @@ cdnsp_2_role_switch: endpoint@0 {
 };
 
 &usbc_phy3 {
-	status = "disabled";
+	status = "okay";
 };
 
 &usb3_phy3 {
-- 
2.51.0

