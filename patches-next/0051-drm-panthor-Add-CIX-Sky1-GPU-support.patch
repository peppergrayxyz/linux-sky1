-		val &= ~SKY1_RCSU_QCHANNEL_CLK_GATE_EN;
-		writel(val, ptdev->rcsu + SKY1_RCSU_PGCTRL_OFFSET);
-	}
-
 	clk_disable_unprepare(ptdev->clks.coregroup);
 	clk_disable_unprepare(ptdev->clks.stacks);
 	clk_disable_unprepare(ptdev->clks.core);
