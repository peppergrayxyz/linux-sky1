-		return 0;
-
-	if (num_domains > ARRAY_SIZE(ptdev->pm_domain_devs)) {
-		drm_warn(&ptdev->base, "Too many power domains (%d), using first %zu\n",
-			 num_domains, ARRAY_SIZE(ptdev->pm_domain_devs));
