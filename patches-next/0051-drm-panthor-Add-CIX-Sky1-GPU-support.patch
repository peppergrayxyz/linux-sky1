-static void panthor_pm_domain_fini(struct panthor_device *ptdev)
-{
-	int i;
-
-	for (i = 0; i < ARRAY_SIZE(ptdev->pm_domain_devs); i++) {
-		if (!ptdev->pm_domain_devs[i])
-			continue;
-
-		if (ptdev->pm_domain_links[i])
