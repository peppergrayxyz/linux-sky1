From c6c620226de0505e59579638ad5cbaaffa44ccfb Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 29 Nov 2025 09:32:58 +0800
Subject: [PATCH 02/73] arm64: dts: cix: Fix mailbox addresses and enable both
 SCMI transports

Fix AP-PM SCMI mailbox register addresses to match vendor 6.6 kernel:
- mbox_ap2pm: 0x6590080 -> 0x6590000 (size 0xff80 -> 0x10000)
- mbox_pm2ap: 0x65a0080 -> 0x65a0000 (size 0xff80 -> 0x10000)

The shared memory (shmem) intentionally overlaps the first 0x80 bytes
of the mailbox region - this is by design, not a conflict to avoid.

Enable both SCMI transport paths to match vendor configuration:
- Mailbox SCMI (ap_to_pm_scmi): clocks, perf, sensors, pm_excp protocols
- SMC SCMI (ap_to_tfa_scmi): power domain (genpd) protocol

This matches the working vendor 6.6 kernel DT configuration where both
SCMI instances are active simultaneously.

Note: Mailbox SCMI still hits CSUPM security errors on 6.18 due to
differences in the SCMI transport layer between kernel versions.
Further driver work needed to match vendor behavior.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts |  4 ++--
 arch/arm64/boot/dts/cix/sky1.dtsi         | 13 ++++++-------
 2 files changed, 8 insertions(+), 9 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index 6a5cde860275e..8e6d84810a7dc 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -2191,11 +2191,11 @@ &ap_tfa_scmi_mem {
 };
 
 &ap_to_pm_scmi {
-	status = "okay";
+	status = "okay";  /* Mailbox SCMI - clocks, perf, sensors, pm_excp */
 };
 
 &ap_to_tfa_scmi {
-	status = "disabled";  /* Disable SMC SCMI - use mailbox SCMI only */
+	status = "okay";  /* SMC SCMI - power domains (genpd) */
 };
 
 &scmi_dvfs {
diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 363c3fc65eefd..94f16aa9461a2 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -3390,20 +3390,19 @@ cix_dphy_hw_1: phy@14300000 {
 			status = "disabled";
 		};
 
-		/* SCMI mailboxes - must be inside soc@0 for platform device creation */
-		/* Note: reg starts at offset 0x80 after shmem to avoid overlap */
-		mbox_ap2pm: mailbox@6590080 {
+		/* SCMI mailboxes - shmem overlaps first 0x80 bytes (intentional) */
+		mbox_ap2pm: mailbox@6590000 {
 			compatible = "cix,sky1-mbox";
-			reg = <0x0 0x06590080 0x0 0xff80>;
+			reg = <0x0 0x06590000 0x0 0x10000>;
 			interrupts = <GIC_SPI 363 IRQ_TYPE_LEVEL_HIGH 0>;
 			#mbox-cells = <1>;
 			cix,mbox_dir = <0>;
 			status = "disabled";
 		};
 
-		mbox_pm2ap: mailbox@65a0080 {
+		mbox_pm2ap: mailbox@65a0000 {
 			compatible = "cix,sky1-mbox";
-			reg = <0x0 0x065a0080 0x0 0xff80>;
+			reg = <0x0 0x065a0000 0x0 0x10000>;
 			interrupts = <GIC_SPI 359 IRQ_TYPE_LEVEL_HIGH 0>;
 			#mbox-cells = <1>;
 			cix,mbox_dir = <1>;
@@ -3501,7 +3500,7 @@ scmi_pm_excp: protocol@81 {
 			};
 		};
 
-		ap_to_tfa_scmi:scmi-smc {
+		ap_to_tfa_scmi: scmi-smc {
 			compatible = "arm,scmi-smc";
 			arm,smc-id = <0xc2000001>;
 			#address-cells = <1>;
-- 
