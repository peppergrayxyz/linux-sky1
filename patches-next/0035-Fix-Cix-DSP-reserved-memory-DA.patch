From 8fcf119c647ef887a9b4fb68c0572222d1ab6669 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 6 Dec 2025 20:08:02 +0800
Subject: [PATCH 35/73] Fix Cix DSP reserved memory DA

The firmware resource table places vrings at 0xce002000, which is inside
the dsp_reserved region (PA 0xce000000). The driver was mapping this
region to DA 0x3e000000, causing rproc_da_to_va to fail for vring access.
Updating the DA to 0xce000000 (identity map) resolves this.
---
 drivers/remoteproc/cix_dsp_rproc.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/remoteproc/cix_dsp_rproc.c b/drivers/remoteproc/cix_dsp_rproc.c
index 022a4aa57f5ed..b5cea1464f38c 100644
--- a/drivers/remoteproc/cix_dsp_rproc.c
+++ b/drivers/remoteproc/cix_dsp_rproc.c
@@ -87,7 +87,7 @@ static const struct cix_mem_region sky1_dsp_mems[CIX_MEM_REG_NUM] = {
 	/* 1M vdev0buffer */
 	{ .name = "vdev0buffer", .da = 0x3de08000, .sa = 0xcde08000, .len = 0x100000 },
 	/* 16M dsp_reserved */
-	{ .name = "dsp_reserved", .da = 0x3e000000, .sa = 0xce000000, .len = 0x1000000 },
+	{ .name = "dsp_reserved", .da = 0xce000000, .sa = 0xce000000, .len = 0x1000000 },
 };
 
 struct cix_dsp_rproc {
-- 
2.51.0

