From afcc062809c40acc341df591d5cf728f62fda45b Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 3 Jan 2026 19:52:25 +1100
Subject: [PATCH 71/73] Input: gpio_keys - use DTS interrupt trigger type when
 explicit IRQ specified

When a gpio-keys button has an explicit interrupt specified via
interrupt-parent and interrupts properties (rather than deriving
the interrupt from the gpios property), use the trigger type
configured in the device tree instead of defaulting to edge-both.

Some GPIO controllers like the Cadence GPIO (cdns,gpio-r1p02) only
support level-triggered interrupts (LEVEL_HIGH and LEVEL_LOW), not
edge triggers. The previous behavior of always requesting edge-both
for GPIO buttons caused irq_set_trigger to fail on these controllers,
resulting in boot failures.

With this change:
- If button->irq is set (explicit IRQ from DTS), query its trigger
  type with irq_get_trigger_type() and use that
- If no trigger type is configured, fall back to edge-both
- If button->irq is not set (IRQ derived from GPIO), use edge-both
  as before for backwards compatibility
---
 drivers/input/keyboard/gpio_keys.c | 16 +++++++++++++++-
 1 file changed, 15 insertions(+), 1 deletion(-)

diff --git a/drivers/input/keyboard/gpio_keys.c b/drivers/input/keyboard/gpio_keys.c
index f9db86da0818b..c766201b59393 100644
--- a/drivers/input/keyboard/gpio_keys.c
+++ b/drivers/input/keyboard/gpio_keys.c
@@ -596,7 +596,21 @@ static int gpio_keys_setup_key(struct platform_device *pdev,
 			      CLOCK_REALTIME, HRTIMER_MODE_REL);
 
 		isr = gpio_keys_gpio_isr;
-		irqflags = IRQF_TRIGGER_RISING | IRQF_TRIGGER_FALLING;
+
+		/*
+		 * If an explicit interrupt was specified in the device tree,
+		 * use its configured trigger type instead of defaulting to
+		 * edge-both. This allows using level-triggered interrupts
+		 * on GPIO controllers that don't support edge triggers
+		 * (e.g., Cadence GPIO).
+		 */
+		if (button->irq) {
+			irqflags = irq_get_trigger_type(bdata->irq);
+			if (!irqflags)
+				irqflags = IRQF_TRIGGER_RISING | IRQF_TRIGGER_FALLING;
+		} else {
+			irqflags = IRQF_TRIGGER_RISING | IRQF_TRIGGER_FALLING;
+		}
 
 		switch (button->wakeup_event_action) {
 		case EV_ACT_ASSERTED:
