From d65b62bd6793801a9b08ba2847d76526bea28ef8 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 2 Jan 2026 23:31:34 +1100
Subject: [PATCH 70/73] arm64: dts: cix: orion-o6n: Remove regulator-boot-on
 from modem regulators

The LTE modem power and reset regulators had regulator-boot-on which
forces early GPIO/pinctrl initialization. This can block on SCMI clock
initialization before the mailbox is ready, causing boot to hang with
repeated SMC calls to the PM core.

Remove regulator-boot-on and keep regulator-always-on - the regulators
will still be enabled when the driver loads, but won't block early boot.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6n.dts | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
index 6b4f446999cd3..71b5a2c961e37 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6n.dts
@@ -208,9 +208,8 @@ em05_modem_power: em05-modem-power-regulator {
 		enable-active-high;
 		pinctrl-names = "default";
 		pinctrl-0 = <&pinctrl_em05_power_gpio>;
-		
 		gpio = <&fch_gpio0 30 GPIO_ACTIVE_HIGH>;
-		regulator-boot-on;
+		/* regulator-boot-on removed - may block on early SCMI init */
 		regulator-always-on;
 	};
 
@@ -221,7 +220,7 @@ em05_modem_reset: em05-modem-reset-regulator {
 		pinctrl-names = "default";
 		pinctrl-0 = <&pinctrl_em05_reset_gpio>;
 		gpio = <&fch_gpio0 31 GPIO_ACTIVE_HIGH>;
-		regulator-boot-on;
+		/* regulator-boot-on removed - may block on early SCMI init */
 		regulator-always-on;
 	};
 
