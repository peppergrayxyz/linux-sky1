From c056ffe13cab6fce32d27af682bf13c510d94058 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 27 Dec 2025 23:28:52 +1100
Subject: [PATCH 64/73] arm64: dts: cix: orion-o6: Enable DDR LP and CPU IPA
 drivers

Enable the DDR low power control driver and CPU IPA power monitoring
driver on the Radxa Orion O6 board.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index 184a151684c9d..3a30a9ae86890 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -2421,3 +2421,11 @@ &sensorhub {
 &sfh_scp {
 	status = "okay";
 };
+
+&cix_ddrlp {
+	status = "okay";
+};
+
+&cix_ipa {
+	status = "okay";
+};
