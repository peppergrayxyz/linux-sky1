From 4e203046a7d6bb8ff946c39dd7a63f20730a9a53 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Tue, 30 Dec 2025 19:37:34 +1100
Subject: [PATCH 68/73] soc: cix: Fix DDR LP and bus DVFS initialization

Fix two initialization issues in the power management drivers:

cix-ddr-lp: TF-A's DDR LP handler saves register state on disable and
restores on enable. The first enable after boot would restore zeros
(uninitialized save buffer) unless we cycle through disable->enable
to capture boot-time register values. DDR LP remains enabled after
probe completes.

cix-bus-perf: Actually set the bus frequency to max on probe instead
of just recording the value. This ensures buses run at full speed
from driver load.
---
 drivers/soc/cix/cix-bus-perf.c | 13 +++++++++++--
 drivers/soc/cix/cix-ddr-lp.c   | 18 +++++++++++++++++-
 2 files changed, 28 insertions(+), 3 deletions(-)

diff --git a/drivers/soc/cix/cix-bus-perf.c b/drivers/soc/cix/cix-bus-perf.c
index 7badbef0a4a83..ec82a485dea5d 100644
--- a/drivers/soc/cix/cix-bus-perf.c
+++ b/drivers/soc/cix/cix-bus-perf.c
@@ -155,11 +155,20 @@ static int cix_bus_perf_probe(struct platform_device *pdev)
 	opp = dev_pm_opp_find_freq_floor(dev, &freq);
 	if (!IS_ERR(opp)) {
 		bp->max_freq = freq;
-		bp->cur_freq = freq;
 		dev_pm_opp_put(opp);
 	}
 
-	dev_info(dev, "Frequency range: %lu - %lu Hz\n",
+	/* Pin to max frequency on boot */
+	ret = cix_bus_set_freq(dev, bp->max_freq);
+	if (ret) {
+		dev_err(dev, "failed to set max frequency: %d\n", ret);
+		pm_runtime_put(dev);
+		pm_runtime_disable(dev);
+		return ret;
+	}
+	bp->cur_freq = bp->max_freq;
+
+	dev_info(dev, "Frequency range: %lu - %lu Hz (pinned to max)\n",
 		 bp->min_freq, bp->max_freq);
 
 	return 0;
diff --git a/drivers/soc/cix/cix-ddr-lp.c b/drivers/soc/cix/cix-ddr-lp.c
index 0db9a82d7618b..09076f37a11c9 100644
--- a/drivers/soc/cix/cix-ddr-lp.c
+++ b/drivers/soc/cix/cix-ddr-lp.c
@@ -121,17 +121,33 @@ ATTRIBUTE_GROUPS(ddrlp);
 static int cix_ddrlp_probe(struct platform_device *pdev)
 {
 	struct cix_ddrlp_data *cix_ddrlp;
+	struct arm_smccc_res res;
 
 	cix_ddrlp = devm_kzalloc(&pdev->dev, sizeof(*cix_ddrlp), GFP_KERNEL);
 	if (!cix_ddrlp)
 		return -ENOMEM;
 
 	gdd = cix_ddrlp;
-	cix_ddrlp->value = 1;  /* DDR LP enabled by default */
 	cix_ddrlp->disable_depth = 0;
 	mutex_init(&cix_ddrlp->lock);
 	platform_set_drvdata(pdev, cix_ddrlp);
 
+	/*
+	 * TF-A's DDR LP handler saves register state on disable and restores
+	 * on enable. We must cycle through disable->enable on init to capture
+	 * the proper boot-time register values, otherwise the first enable
+	 * would restore zeros.
+	 */
+	arm_smccc_smc(CIX_SIP_SET_DDRLP, 0, 0, 0, 0, 0, 0, 0, &res);
+	if (res.a0) {
+		dev_warn(&pdev->dev, "DDR LP disable failed: %ld\n", res.a0);
+	}
+	arm_smccc_smc(CIX_SIP_SET_DDRLP, 1, 0, 0, 0, 0, 0, 0, &res);
+	if (res.a0) {
+		dev_warn(&pdev->dev, "DDR LP enable failed: %ld\n", res.a0);
+	}
+	cix_ddrlp->value = 1;
+
 	dev_info(&pdev->dev, "DDR low power control initialized\n");
 	return 0;
 }
