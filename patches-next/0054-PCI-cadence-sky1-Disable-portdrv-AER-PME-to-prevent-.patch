From 8fd8e776878dd67c8501c7a956113c55f736af0f Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Mon, 15 Dec 2025 09:16:51 +0800
Subject: [PATCH 54/73] PCI: cadence: sky1: Disable portdrv AER/PME to prevent
 IRQ conflicts

Sky1 PCIe controller handles AER and PME through platform-level
interrupts defined in device tree (pcie-aer-c/f/nf, pcie-local),
with custom handlers in the driver.

Without this fix, portdrv also registers handlers on the root port's
legacy interrupt, causing "irq N: nobody cared" errors during WiFi
hotplug stress testing due to duplicate/unhandled interrupts.

Set bridge->native_aer = 0 and bridge->native_pme = 0 to tell portdrv
that firmware (in this case, the platform driver) owns these services.
---
 drivers/pci/controller/cadence/pci-sky1.c | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/drivers/pci/controller/cadence/pci-sky1.c b/drivers/pci/controller/cadence/pci-sky1.c
index 0a9c9714bd5f0..99e847b283bfe 100644
--- a/drivers/pci/controller/cadence/pci-sky1.c
+++ b/drivers/pci/controller/cadence/pci-sky1.c
@@ -2347,6 +2347,19 @@ static int sky1_cdns_pcie_host_setup(struct cdns_pcie_rc *rc)
 
 	/* bridge->ops already set by sky1_pcie_probe() */
 
+	/*
+	 * Sky1 PCIe controller handles AER and PME through platform-level
+	 * interrupts (pcie-aer-c/f/nf, pcie-local) defined in device tree,
+	 * with custom handlers (sky1_pcie_aer_irq_handler, etc.).
+	 *
+	 * Disable portdrv's AER/PME services to prevent duplicate handling
+	 * and spurious "nobody cared" IRQ errors during hotplug. The root
+	 * port's legacy interrupt would otherwise be claimed by portdrv,
+	 * which doesn't recognize Sky1's interrupt sources.
+	 */
+	bridge->native_aer = 0;
+	bridge->native_pme = 0;
+
 	return sky1_pci_host_probe(bridge);
 }
 
