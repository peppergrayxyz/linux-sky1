From 7c04c64a6f928d3a3955118b75c70806fa2471ab Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 6 Dec 2025 20:45:39 +0800
Subject: [PATCH 36/73] rpmsg: char: Add Cix DSP audio services

Add 'audio-decoder' and 'audio-encoder' to the id_table.
This allows the rpmsg_char driver to bind to the Cix HiFi5 DSP
audio services automatically when they are announced via the
rpmsg Name Service. This creates the /dev/rpmsgX character
devices required by the vendor's libdsp_wrap.so userspace library.
---
 drivers/rpmsg/rpmsg_char.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/drivers/rpmsg/rpmsg_char.c b/drivers/rpmsg/rpmsg_char.c
index 96fcdd2d7093c..19b731514d6d6 100644
--- a/drivers/rpmsg/rpmsg_char.c
+++ b/drivers/rpmsg/rpmsg_char.c
@@ -523,6 +523,8 @@ static void rpmsg_chrdev_remove(struct rpmsg_device *rpdev)
 static struct rpmsg_device_id rpmsg_chrdev_id_table[] = {
 	{ .name	= "rpmsg-raw" },
 	{ .name	= "rpmsg_chrdev" },
+	{ .name = "audio-decoder" },
+	{ .name = "audio-encoder" },
 	{ },
 };
 MODULE_DEVICE_TABLE(rpmsg, rpmsg_chrdev_id_table);
