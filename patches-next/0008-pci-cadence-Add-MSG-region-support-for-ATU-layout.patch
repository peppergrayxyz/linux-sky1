From 23eb9197c3d7a78a80164524fa6f7ed675660cdb Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 29 Nov 2025 19:53:43 +0800
Subject: [PATCH 08/73] pci: cadence: Add MSG region support for ATU layout

Add msg_res field to struct cdns_pcie and set up ATU region 1 for
PCIe messaging (PME_TURN_OFF, etc.) when msg_res is defined.

This matches the vendor kernel ATU region layout:
- Region 0: Config space
- Region 1: MSG region (for PCIe messaging)
- Region 2+: Memory/IO windows

The Sky1 driver sets msg_res from the DTS "msg" memory region.
---
 drivers/pci/controller/cadence/pcie-cadence-host.c | 13 ++++++++++++-
 drivers/pci/controller/cadence/pcie-cadence.h      |  2 ++
 2 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/drivers/pci/controller/cadence/pcie-cadence-host.c b/drivers/pci/controller/cadence/pcie-cadence-host.c
index 84b11b2591f39..438c0bc882dc6 100644
--- a/drivers/pci/controller/cadence/pcie-cadence-host.c
+++ b/drivers/pci/controller/cadence/pcie-cadence-host.c
@@ -645,8 +645,19 @@ static int cdns_pcie_host_init_address_translation(struct cdns_pcie_rc *rc)
 	if (entry)
 		busnr = entry->res->start;
 
-	/* Set up outbound regions for memory/IO windows */
+	/*
+	 * Set up outbound ATU regions:
+	 * - Region 0: Config space (set up above)
+	 * - Region 1: MSG region for PCIe messaging (if msg_res defined)
+	 * - Region 2+: Memory/IO windows (or 1+ if no msg_res)
+	 */
 	r = 1;
+	if (pcie->msg_res) {
+		cdns_pcie_set_outbound_region_for_normal_msg(pcie, busnr, 0, r,
+							    pcie->msg_res->start);
+		r++;
+	}
+
 	resource_list_for_each_entry(entry, &bridge->windows) {
 		struct resource *res = entry->res;
 		u64 pci_addr = res->start - entry->offset;
diff --git a/drivers/pci/controller/cadence/pcie-cadence.h b/drivers/pci/controller/cadence/pcie-cadence.h
index dc77e1f2df7bd..5da4c36b25aa3 100644
--- a/drivers/pci/controller/cadence/pcie-cadence.h
+++ b/drivers/pci/controller/cadence/pcie-cadence.h
@@ -277,6 +277,7 @@ struct cdns_pcie_ops {
  * struct cdns_pcie - private data for Cadence PCIe controller drivers
  * @reg_base: IO mapped register base
  * @mem_res: start/end offsets in the physical system memory to map PCI accesses
+ * @msg_res: start/end offsets for PCIe msg region (optional, for ATU region 1)
  * @dev: PCIe controller
  * @is_rc: tell whether the PCIe controller mode is Root Complex or Endpoint.
  * @phy_count: number of supported PHY devices
@@ -288,6 +289,7 @@ struct cdns_pcie_ops {
 struct cdns_pcie {
 	void __iomem		*reg_base;
 	struct resource		*mem_res;
+	struct resource		*msg_res;
 	struct device		*dev;
 	bool			is_rc;
 	int			phy_count;
-- 
