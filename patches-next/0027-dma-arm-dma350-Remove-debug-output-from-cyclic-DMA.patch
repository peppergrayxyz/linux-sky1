From ffe2a1251d6dff36fc88bcfbb6f563f69c117568 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 4 Dec 2025 19:44:47 +0800
Subject: [PATCH 27/73] dma: arm-dma350: Remove debug output from cyclic DMA

Remove verbose dev_info debug messages added during development.
Keep dev_err for actual error conditions and dev_dbg for optional
tracing that can be enabled via dynamic debug.
---
 drivers/dma/arm-dma350.c | 41 ++++------------------------------------
 1 file changed, 4 insertions(+), 37 deletions(-)

diff --git a/drivers/dma/arm-dma350.c b/drivers/dma/arm-dma350.c
index b2f28897451bd..7ae54f52b47de 100644
--- a/drivers/dma/arm-dma350.c
+++ b/drivers/dma/arm-dma350.c
@@ -530,11 +530,8 @@ static enum dma_status d350_tx_status(struct dma_chan *chan, dma_cookie_t cookie
 static void d350_start_cyclic(struct d350_chan *dch)
 {
 	struct d350 *dmac = to_d350(dch->vc.chan.device);
-	struct device *dev = dch->vc.chan.device->dev;
 	dma_addr_t cmdlink_dma;
 
-	dev_info(dev, "=== d350_start_cyclic ===\n");
-
 	/*
 	 * For cyclic DMA, we use hardware command linking.
 	 * The DMA controller fetches commands from memory and
@@ -565,8 +562,6 @@ static void d350_start_cyclic(struct d350_chan *dch)
 
 	/* Set up and enable hardware command linking */
 	cmdlink_dma = d350_translate_addr(dmac, dch->desc->cmdlink_phys);
-	dev_info(dev, "cyclic: cmdlink_phys=%pad translated=%pad\n",
-		 &dch->desc->cmdlink_phys, &cmdlink_dma);
 
 	writel_relaxed(lower_32_bits(cmdlink_dma) | CH_LINKADDR_EN,
 		       dch->base + CH_LINKADDR);
@@ -574,23 +569,6 @@ static void d350_start_cyclic(struct d350_chan *dch)
 
 	/* Re-enable to start command fetch */
 	writel(CH_CMD_ENABLE, dch->base + CH_CMD);
-
-	dev_info(dev, "cyclic: DMA started, LINKADDR=0x%08x NSEC_INTREN=0x%08x\n",
-		 readl_relaxed(dch->base + CH_LINKADDR),
-		 readl_relaxed(dmac->base + DMA_NSEC_INTREN));
-
-	/* Debug: check status after a short delay */
-	udelay(100);
-	dev_info(dev, "cyclic: STATUS=0x%08x CTRL=0x%08x INTREN=0x%08x\n",
-		 readl_relaxed(dch->base + CH_STATUS),
-		 readl_relaxed(dch->base + CH_CTRL),
-		 readl_relaxed(dch->base + CH_INTREN));
-	dev_info(dev, "cyclic: SRCADDR=0x%08x DESADDR=0x%08x XSIZE=0x%08x\n",
-		 readl_relaxed(dch->base + CH_SRCADDR),
-		 readl_relaxed(dch->base + CH_DESADDR),
-		 readl_relaxed(dch->base + CH_XSIZE));
-	dev_info(dev, "cyclic: CHINTRSTATUS0=0x%08x (global pending interrupts)\n",
-		 readl_relaxed(dmac->base + DMA_CHINTRSTATUS0));
 }
 
 static void d350_start_next(struct d350_chan *dch)
@@ -670,7 +648,6 @@ static void d350_issue_pending(struct dma_chan *chan)
 static irqreturn_t d350_irq(int irq, void *data)
 {
 	struct d350_chan *dch = data;
-	struct device *dev = dch->vc.chan.device->dev;
 	struct virt_dma_desc *vd;
 	u32 ch_status;
 
@@ -678,8 +655,6 @@ static irqreturn_t d350_irq(int irq, void *data)
 	if (!ch_status)
 		return IRQ_NONE;
 
-	dev_info(dev, "=== d350_irq: status=0x%08x ===\n", ch_status);
-
 	/* Clear interrupt status */
 	writel_relaxed(ch_status, dch->base + CH_STATUS);
 
@@ -695,7 +670,8 @@ static irqreturn_t d350_irq(int irq, void *data)
 	if (ch_status & CH_STAT_INTR_ERR) {
 		u32 errinfo = readl_relaxed(dch->base + CH_ERRINFO);
 
-		dev_err(dev, "DMA error on channel, errinfo=0x%08x\n", errinfo);
+		dev_err(dch->vc.chan.device->dev,
+			"DMA error on channel, errinfo=0x%08x\n", errinfo);
 
 		if (errinfo & (CH_ERRINFO_AXIRDPOISERR | CH_ERRINFO_AXIRDRESPERR))
 			vd->tx_result.result = DMA_TRANS_READ_FAILED;
@@ -733,7 +709,8 @@ static irqreturn_t d350_irq(int irq, void *data)
 			d350_start_next(dch);
 		}
 	} else {
-		dev_warn(dev, "Unexpected IRQ source? 0x%08x\n", ch_status);
+		dev_warn(dch->vc.chan.device->dev,
+			 "Unexpected IRQ source? 0x%08x\n", ch_status);
 	}
 
 	spin_unlock(&dch->vc.lock);
@@ -874,10 +851,6 @@ static struct dma_async_tx_descriptor *d350_prep_dma_cyclic(
 	u8 transize;
 	size_t i;
 
-	dev_info(dev, "=== d350_prep_dma_cyclic called ===\n");
-	dev_info(dev, "cyclic: buf=%pad len=%zu period=%zu dir=%d req_line=%u\n",
-		 &buf_addr, buf_len, period_len, dir, dch->req_line);
-
 	/* Validate direction */
 	if (dir != DMA_MEM_TO_DEV && dir != DMA_DEV_TO_MEM) {
 		dev_err(dev, "cyclic: invalid direction %d\n", dir);
@@ -1039,14 +1012,8 @@ static struct dma_async_tx_descriptor *d350_prep_dma_cyclic(
 		cmd[13] = lower_32_bits(next_cmd_phys) | CH_LINKADDR_EN;
 		cmd[14] = upper_32_bits(next_cmd_phys);
 		cmd[15] = 0;	/* Padding */
-
-		dev_info(dev, "cyclic: period[%zu] src=%pad dst=%pad xsize=%u next=%pad\n",
-			i, &src_addr, &dst_addr, xsize, &next_cmd_phys);
 	}
 
-	dev_info(dev, "cyclic: descriptor created OK, periods=%zu cmdlink_phys=%pad\n",
-		 desc->num_periods, &desc->cmdlink_phys);
-
 	return vchan_tx_prep(&dch->vc, &desc->vd, flags);
 }
 
-- 
2.51.0

