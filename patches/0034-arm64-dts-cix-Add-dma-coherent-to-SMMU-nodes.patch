From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Wed, 4 Feb 2026 20:07:22 +1100
Subject: [PATCH] arm64: dts: cix: Add dma-coherent to SMMU nodes

The MMU-700 (SMMUv3.2) on Sky1 reports IDR0.COHACC=1, indicating
hardware support for coherent page table walks. The TRM confirms the
data fabric is coherent. Without the dma-coherent property, the
driver overrides the hardware capability and falls back to
non-coherent page table walks, printing:

  "IDR0.COHACC overridden by FW configuration (false)"

Add dma-coherent to all three SMMU nodes (syshub, mmhub, pciehub)
to enable coherent page table walks matching the hardware capability.
---
 arch/arm64/boot/dts/cix/sky1.dtsi | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index b26152c751e4e..0a84662f1d0c6 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -641,6 +641,7 @@ smmu_syshub: iommu@b0e0000 {
 			<GIC_SPI 91 IRQ_TYPE_EDGE_RISING 0>,
 			<GIC_SPI 95 IRQ_TYPE_EDGE_RISING 0>;
 		interrupt-names = "eventq", "priq", "cmdq-sync", "gerror";
+		dma-coherent;
 		status = "disabled";
 	};
 
@@ -653,6 +654,7 @@ smmu_mmhub: iommu@b1b0000 {
 			<GIC_SPI 110 IRQ_TYPE_EDGE_RISING 0>,
 			<GIC_SPI 114 IRQ_TYPE_EDGE_RISING 0>;
 		interrupt-names = "eventq", "priq", "cmdq-sync", "gerror";
+		dma-coherent;
 		status = "disabled";
 	};
 
@@ -665,6 +667,7 @@ smmu_pciehub: iommu@b010000 {
 			<GIC_SPI 76 IRQ_TYPE_EDGE_RISING 0>,
 			<GIC_SPI 80 IRQ_TYPE_EDGE_RISING 0>;
 		interrupt-names = "eventq", "priq", "cmdq-sync", "gerror";
+		dma-coherent;
 		status = "disabled";
 	};
 
