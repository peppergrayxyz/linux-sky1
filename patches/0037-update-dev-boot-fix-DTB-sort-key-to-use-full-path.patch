From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 5 Feb 2026 09:28:19 +1100
Subject: [PATCH] update-dev-boot: fix DTB sort key to use full path

The DTB glob matches produce paths like:
  /usr/lib/linux-image-6.18.2-sky1/cix/sky1-orion-o6.dtb
  /usr/lib/linux-image-6.18.8-sky1/cix/sky1-orion-o6.dtb

Sorting by p.name gives identical values (sky1-orion-o6.dtb) for all
matches, so the sort was unstable and could pick the wrong version.
Sort by str(p) instead so the parent directory name breaks the tie
and the latest kernel version is selected.
---
 scripts/update-dev-boot.py | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/scripts/update-dev-boot.py b/scripts/update-dev-boot.py
index fe5256a1bf5c8..5db9e92c07112 100755
--- a/scripts/update-dev-boot.py
+++ b/scripts/update-dev-boot.py
@@ -132,11 +132,13 @@ def sync_efi_files(board: sky1_lib.Board, dry_run: bool) -> None:
         )
 
         # Find installed DTB: /usr/lib/linux-image-*{suffix}/cix/{board}.dtb
+        # Sort by full path (not p.name which is identical for all matches)
+        # so the parent dir name (linux-image-6.18.8-sky1) picks the latest.
         dtb_matches = sorted(
             Path("/usr/lib").glob(
                 f"linux-image-*{suffix}/cix/{board.dts_base}.dtb"
             ),
-            key=lambda p: p.name,
+            key=lambda p: str(p),
             reverse=True,
         )
 
