From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 29 Nov 2025 19:50:09 +0800
Subject: [PATCH] pci: cadence: sky1: Use vendor-style PCI resource assignment

Add custom sky1_pci_host_probe() and sky1_cdns_pcie_host_setup()
functions that use the simpler vendor kernel (6.6) resource assignment
path instead of mainline's pci_assign_unassigned_root_bus_resources().

The mainline path has complex realloc detection that requires the
pci=realloc boot parameter on platforms where firmware doesn't properly
initialize PCIe bridge windows. The vendor-style path uses:
  pci_bus_size_bridges() + pci_bus_assign_resources()

This is a temporary workaround until firmware properly initializes
PCIe bridge windows. The fix is isolated to the Sky1 driver and
doesn't affect other platforms.
---
 drivers/pci/controller/cadence/pci-sky1.c | 90 ++++++++++++++++++++++-
 1 file changed, 88 insertions(+), 2 deletions(-)

diff --git a/drivers/pci/controller/cadence/pci-sky1.c b/drivers/pci/controller/cadence/pci-sky1.c
index efc5f1f08b711..24a301d17e8d6 100644
--- a/drivers/pci/controller/cadence/pci-sky1.c
+++ b/drivers/pci/controller/cadence/pci-sky1.c
@@ -2257,6 +2257,86 @@ static void sky1_pcie_x211_enum_lock(struct sky1_pcie *pcie, bool lock)
 	}
 }
 
+/*
+ * Custom host probe using vendor-style resource assignment.
+ *
+ * This is a temporary workaround for firmware not properly initializing
+ * PCIe bridge windows. The standard pci_host_probe() uses
+ * pci_assign_unassigned_root_bus_resources() which has complex realloc
+ * detection that requires pci=realloc boot parameter on this platform.
+ *
+ * This function uses the simpler vendor kernel (6.6) approach:
+ * pci_bus_size_bridges() + pci_bus_assign_resources(), which works
+ * without pci=realloc.
+ *
+ * TODO: Remove this workaround when firmware properly initializes
+ * PCIe bridge windows.
+ */
+static int sky1_pci_host_probe(struct pci_host_bridge *bridge)
+{
+	struct pci_bus *bus, *child;
+	int ret;
+
+	pci_lock_rescan_remove();
+	ret = pci_scan_root_bus_bridge(bridge);
+	pci_unlock_rescan_remove();
+	if (ret < 0) {
+		dev_err(bridge->dev.parent, "Scanning root bridge failed\n");
+		return ret;
+	}
+
+	bus = bridge->bus;
+
+	/* If we must preserve the resource configuration, claim now */
+	if (bridge->preserve_config)
+		pci_bus_claim_resources(bus);
+
+	/*
+	 * Vendor-style simple assignment path.
+	 * This sizes bridge windows based on device requirements,
+	 * then assigns resources. Works without pci=realloc.
+	 */
+	pci_bus_size_bridges(bus);
+	pci_bus_assign_resources(bus);
+
+	list_for_each_entry(child, &bus->children, node)
+		pcie_bus_configure_settings(child);
+
+	pci_lock_rescan_remove();
+	pci_bus_add_devices(bus);
+	pci_unlock_rescan_remove();
+
+	return 0;
+}
+
+/*
+ * Sky1-specific host setup that uses our custom probe.
+ *
+ * This replaces cdns_pcie_host_setup() to use sky1_pci_host_probe()
+ * instead of the standard pci_host_probe().
+ */
+static int sky1_cdns_pcie_host_setup(struct cdns_pcie_rc *rc)
+{
+	struct pci_host_bridge *bridge = pci_host_bridge_from_priv(rc);
+	enum cdns_pcie_rp_bar bar;
+	int ret;
+
+	ret = cdns_pcie_host_link_setup(rc);
+	if (ret)
+		return ret;
+
+	for (bar = RP_BAR0; bar <= RP_NO_BAR; bar++)
+		rc->avail_ib_bar[bar] = true;
+
+	ret = cdns_pcie_host_init(rc);
+	if (ret)
+		return ret;
+
+	/* bridge->ops already set by sky1_pcie_probe() */
+
+	return sky1_pci_host_probe(bridge);
+}
+
 static int sky1_pcie_really_probe(void *p)
 {
 	struct sky1_pcie *pcie = p;
@@ -2284,7 +2364,13 @@ static int sky1_pcie_really_probe(void *p)
 	}
 	sky1_pcie_enable_irq(pcie, true);
 
-	ret = cdns_pcie_host_setup(rc);
+	/*
+	 * Use our custom host setup which uses vendor-style resource
+	 * assignment (pci_bus_size_bridges + pci_bus_assign_resources).
+	 * This works without pci=realloc on platforms where firmware
+	 * doesn't properly initialize PCIe bridge windows.
+	 */
+	ret = sky1_cdns_pcie_host_setup(rc);
 	if (ret < 0)
 		goto err_ecam_free;
 
@@ -2404,7 +2490,7 @@ static int sky1_pcie_probe(struct platform_device *pdev)
 	cdns_pcie->dev = dev;
 	cdns_pcie->ops = &sky1_pcie_ops;
 	cdns_pcie->reg_base = pcie->reg_base;
-	/* Note: plat_emu and msg_res stored in pcie struct, not cdns_pcie (mainline) */
+	cdns_pcie->msg_res = pcie->msg_res;
 
 	pcie->cdns_pcie = cdns_pcie;
 	pcie->cdns_pcie_rc = rc;
