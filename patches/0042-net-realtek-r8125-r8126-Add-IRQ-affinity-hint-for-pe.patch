+static bool rtl8126_is_little_core(int cpu)
+{
+        unsigned long capacity = topology_get_cpu_scale(cpu);
+        return capacity < RTL8126_LITTLE_CORE_CAPACITY;
+}
+#endif
+
 static int rtl8126_alloc_irq(struct rtl8126_private *tp)
 {
         struct net_device *dev = tp->dev;
@@ -14006,6 +14023,18 @@ static int rtl8126_alloc_irq(struct rtl8126_private *tp)
         struct r8126_napi *r8126napi;
         int i = 0;
         const int len = sizeof(tp->irq_tbl[0].name);
+#ifdef CONFIG_ARM64
+        cpumask_var_t big_core_mask;
+        int cpu;
+
+        /* Build mask of performance cores for IRQ affinity */
+        if (zalloc_cpumask_var(&big_core_mask, GFP_KERNEL)) {
+                for_each_online_cpu(cpu) {
+                        if (!rtl8126_is_little_core(cpu))
+                                cpumask_set_cpu(cpu, big_core_mask);
+                }
+        }
+#endif
 
 #if defined(RTL_USE_NEW_INTR_API)
         for (i=0; i<tp->irq_nvecs; i++) {
@@ -14025,6 +14054,9 @@ static int rtl8126_alloc_irq(struct rtl8126_private *tp)
 
                 irq->vector = pci_irq_vector(tp->pci_dev, i);
                 irq->requested = 1;
+#ifdef CONFIG_ARM64
+                irq_set_affinity_hint(irq->vector, big_core_mask);
+#endif
         }
 #else
         unsigned long irq_flags = 0;
@@ -14062,6 +14094,9 @@ static int rtl8126_alloc_irq(struct rtl8126_private *tp)
         if (rc)
                 rtl8126_free_irq(tp);
 
+#ifdef CONFIG_ARM64
+        free_cpumask_var(big_core_mask);
+#endif
         return rc;
 }
 
