 {
@@ -154,7 +174,7 @@ static int panthor_devfreq_target(struct device *dev, unsigned long *freq,
 	spin_unlock_irqrestore(&pdevfreq->lock, irqflags);
 
 	/* Actual SCMI frequency change (may sleep on mailbox) */
