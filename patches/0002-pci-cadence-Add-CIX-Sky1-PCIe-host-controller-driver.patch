+#define SKY1_ASPM_STATE_L0S		(SKY1_ASPM_STATE_L0S_UP | SKY1_ASPM_STATE_L0S_DW)
+#define SKY1_ASPM_STATE_ALL		(SKY1_ASPM_STATE_L0S | SKY1_ASPM_STATE_L1 |	\
+					SKY1_ASPM_STATE_L1SS)
