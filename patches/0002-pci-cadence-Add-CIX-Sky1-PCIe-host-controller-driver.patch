 .../pci/controller/cadence/pci-sky1-debugfs.c | 1340 ++++++++
 .../pci/controller/cadence/pci-sky1-debugfs.h |   17 +
 drivers/pci/controller/cadence/pci-sky1.c     | 2811 +++++++++++++++++
 drivers/pci/controller/cadence/pci-sky1.h     |  196 ++
