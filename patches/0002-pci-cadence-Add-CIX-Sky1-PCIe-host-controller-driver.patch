+static void sky1_pcie_update_bits32(void __iomem *addr, u32 bits_msk, u32 vals)
+{
+	u32 value;
+
+	value = readl(addr);
+	value &= ~bits_msk;
+	value |= vals;
+	writel(value, addr);
+}
