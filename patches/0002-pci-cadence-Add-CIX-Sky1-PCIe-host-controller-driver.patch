diff --git a/drivers/pci/controller/cadence/Kconfig b/drivers/pci/controller/cadence/Kconfig
index 02a639e55fd8c..ad5ad2d534f94 100644
--- a/drivers/pci/controller/cadence/Kconfig
+++ b/drivers/pci/controller/cadence/Kconfig
@@ -77,4 +77,15 @@ config PCI_J721E_EP
 	  controller in endpoint mode. TI J721E PCIe controller uses Cadence PCIe
 	  core.
 
+config PCI_SKY1
+	bool "CIX Sky1 PCIe controller (host mode)"
+	depends on OF && (ARCH_CIX || COMPILE_TEST)
+	select PCIE_CADENCE_HOST
+	help
+	  Say Y here if you want to support the CIX Sky1 PCIe platform
+	  controller in host mode. CIX Sky1 PCIe controller uses Cadence PCIe
+	  core.
+
+	  e.g. Orion O6.
+
 endmenu
