+static bool cdns_i2s_sc_readable_reg(struct device *dev, unsigned int reg)
+{
+	switch (reg) {
+	case I2S_CTRL:
+	case I2S_CTRL_FDX:
+	case I2S_SRES:
+	case I2S_SRES_FDR:
+	case I2S_SRATE:
+	case I2S_STAT:
+	case I2S_FIFO_LEVEL:
+	case I2S_FIFO_AEMPTY:
+	case I2S_FIFO_AFULL:
+	case I2S_FIFO_LEVEL_FDR:
+	case I2S_FIFO_AEMPTY_FDR:
+	case I2S_FIFO_AFULL_FDR:
+	case I2S_TDM_CTRL:
+	case I2S_TDM_FD_DIR:
+		return true;
+	default:
+		return false;
+	}
+};
+
+static bool cdns_i2s_sc_writeable_reg(struct device *dev, unsigned int reg)
+{
+	switch (reg) {
+	case I2S_CTRL:
+	case I2S_CTRL_FDX:
+	case I2S_SRES:
+	case I2S_SRES_FDR:
+	case I2S_SRATE:
+	case I2S_STAT:
+	case I2S_FIFO_AEMPTY:
+	case I2S_FIFO_AFULL:
+	case I2S_FIFO_AEMPTY_FDR:
+	case I2S_FIFO_AFULL_FDR:
+	case I2S_TDM_CTRL:
+	case I2S_TDM_FD_DIR:
+		return true;
+	default:
+		return false;
+	}
+};
