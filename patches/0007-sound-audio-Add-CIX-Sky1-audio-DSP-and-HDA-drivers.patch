+static bool cdns_i2s_sc_volatile_reg(struct device *dev, unsigned int reg)
+{
+	switch (reg) {
+	case I2S_STAT:
+	case I2S_FIFO_LEVEL:
+	case I2S_FIFO_LEVEL_FDR:
+		return true;
+	default:
+		return false;
+	}
