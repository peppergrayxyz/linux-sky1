From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 7 Feb 2026 18:16:00 +1100
Subject: [PATCH] firmware: arm_scmi: Add ACPI boot support for CIX Sky1

Enable SCMI firmware communication under ACPI boot on CIX Sky1 SoCs.

When no DT node is present, enumerate all protocols reported by the
firmware via base protocol discovery, sharing the base transport
channel for all non-base protocols (mirroring the DT fallback when
child nodes lack their own mailboxes).

Also propagate fwnode to SCMI sub-devices, fix the transport probe
macro to pass fwnode when no DT node exists, simplify chan_available
for ACPI, and select 32-bit I/O operations for shared memory when
the reg-io-width property indicates it.
---
 drivers/firmware/arm_scmi/bus.c               |  3 ++
 drivers/firmware/arm_scmi/common.h            |  3 ++
 drivers/firmware/arm_scmi/driver.c            | 52 ++++++++++++++++++-
 drivers/firmware/arm_scmi/shmem.c             | 19 +++++--
 .../firmware/arm_scmi/transports/mailbox.c    |  4 --
 5 files changed, 73 insertions(+), 8 deletions(-)

diff --git a/drivers/firmware/arm_scmi/bus.c b/drivers/firmware/arm_scmi/bus.c
index c7698cfaa4e83..19da052838c45 100644
--- a/drivers/firmware/arm_scmi/bus.c
+++ b/drivers/firmware/arm_scmi/bus.c
@@ -466,6 +466,9 @@ __scmi_device_create(struct device_node *np, struct device *parent,
 	scmi_dev->protocol_id = protocol;
 	scmi_dev->dev.parent = parent;
 	device_set_node(&scmi_dev->dev, of_fwnode_handle(np));
+	/* ACPI: inherit parent fwnode when no DT node */
+	if (!np && parent)
+		scmi_dev->dev.fwnode = dev_fwnode(parent);
 	scmi_dev->dev.bus = &scmi_bus_type;
 	scmi_dev->dev.release = scmi_device_release;
 	dev_set_name(&scmi_dev->dev, "scmi_dev.%d", id);
diff --git a/drivers/firmware/arm_scmi/common.h b/drivers/firmware/arm_scmi/common.h
index d86babb90b4f8..8f37e66c772ca 100644
--- a/drivers/firmware/arm_scmi/common.h
+++ b/drivers/firmware/arm_scmi/common.h
@@ -495,6 +495,9 @@ static int __tag##_probe(struct platform_device *pdev)			       \
 		return -ENOMEM;						       \
 									       \
 	device_set_of_node_from_dev(&spdev->dev, dev);			       \
+	/* ACPI: propagate fwnode when no DT node is present */		       \
+	if (!spdev->dev.fwnode)						       \
+		spdev->dev.fwnode = dev_fwnode(dev);			       \
 									       \
 	strans.supplier = dev;						       \
 	memcpy(&strans.desc, &(__desc), sizeof(strans.desc));		       \
diff --git a/drivers/firmware/arm_scmi/driver.c b/drivers/firmware/arm_scmi/driver.c
index 5caa9191a8d1a..a34243fea3025 100644
--- a/drivers/firmware/arm_scmi/driver.c
+++ b/drivers/firmware/arm_scmi/driver.c
@@ -174,6 +174,9 @@ struct scmi_info {
 };
 
 #define handle_to_scmi_info(h)	container_of(h, struct scmi_info, handle)
+
+/* Sentinel stored in active_protocols IDR for ACPI-enumerated protocols */
+#define SCMI_NO_DT_NODE		((struct device_node *)0x1)
 #define tx_minfo_to_scmi_info(h) container_of(h, struct scmi_info, tx_minfo)
 #define bus_nb_to_scmi_info(nb)	container_of(nb, struct scmi_info, bus_nb)
 #define req_nb_to_scmi_info(nb)	container_of(nb, struct scmi_info, dev_req_nb)
@@ -2663,6 +2666,18 @@ static int scmi_chan_setup(struct scmi_info *info, struct device_node *of_node,
 	idx = tx ? 0 : 1;
 	idr = tx ? &info->tx_idr : &info->rx_idr;
 
+	/*
+	 * ACPI: no DT children describe per-protocol channels.
+	 * All non-base protocols share the base transport channel,
+	 * mirroring the DT fallback when children lack own mboxes.
+	 */
+	if (!of_node && prot_id != SCMI_PROTOCOL_BASE) {
+		cinfo = idr_find(idr, SCMI_PROTOCOL_BASE);
+		if (unlikely(!cinfo))
+			return -EINVAL;
+		goto idr_alloc;
+	}
+
 	if (!info->desc->ops->chan_available(of_node, idx)) {
 		cinfo = idr_find(idr, SCMI_PROTOCOL_BASE);
 		if (unlikely(!cinfo)) /* Possible only if platform has no Rx */
@@ -2871,6 +2886,8 @@ static int scmi_device_request_notifier(struct notifier_block *nb,
 	np = idr_find(&info->active_protocols, id_table->protocol_id);
 	if (!np)
 		return NOTIFY_DONE;
+	if (np == SCMI_NO_DT_NODE)
+		np = NULL;
 
 	dev_dbg(info->dev, "%sRequested device (%s) for protocol 0x%x\n",
 		action == SCMI_BUS_NOTIFY_DEVICE_REQUEST ? "" : "UN-",
@@ -3273,6 +3290,38 @@ static int scmi_probe(struct platform_device *pdev)
 		scmi_create_protocol_devices(child, info, prot_id, NULL);
 	}
 
+	/*
+	 * ACPI fallback: no DT children to iterate. Enumerate all
+	 * protocols reported by firmware via base protocol discovery.
+	 */
+	if (!np) {
+		int i;
+
+		for (i = 0; i < info->version.num_protocols; i++) {
+			u8 prot_id = info->protocols_imp[i];
+
+			if (!FIELD_FIT(MSG_PROTOCOL_ID_MASK, prot_id))
+				continue;
+
+			ret = scmi_txrx_setup(info, NULL, prot_id);
+			if (ret)
+				continue;
+
+			ret = idr_alloc(&info->active_protocols,
+					SCMI_NO_DT_NODE,
+					prot_id, prot_id + 1, GFP_KERNEL);
+			if (ret != prot_id) {
+				dev_err(dev,
+					"SCMI protocol %d already activated. Skip\n",
+					prot_id);
+				continue;
+			}
+
+			scmi_create_protocol_devices(NULL, info, prot_id,
+						     NULL);
+		}
+	}
+
 	return 0;
 
 notification_exit:
@@ -3316,7 +3365,8 @@ static void scmi_remove(struct platform_device *pdev)
 	mutex_unlock(&info->protocols_mtx);
 
 	idr_for_each_entry(&info->active_protocols, child, id)
-		of_node_put(child);
+		if (child != SCMI_NO_DT_NODE)
+			of_node_put(child);
 	idr_destroy(&info->active_protocols);
 
 	blocking_notifier_chain_unregister(&scmi_requested_devices_nh,
diff --git a/drivers/firmware/arm_scmi/shmem.c b/drivers/firmware/arm_scmi/shmem.c
index da61234b77fd4..c158ddd1fc4bc 100644
--- a/drivers/firmware/arm_scmi/shmem.c
+++ b/drivers/firmware/arm_scmi/shmem.c
@@ -258,10 +258,23 @@ static void __iomem *shmem_acpi_setup_iomap(struct scmi_chan_info *cinfo,
 	}
 
 	acpi_dev_free_resource_list(&res_list);
-	fwnode_handle_put(args.fwnode);
 
-	if (!IS_ERR(addr))
-		*ops = &shmem_io_ops_default;
+	if (!IS_ERR(addr)) {
+		u32 reg_io_width = 4;
+
+		fwnode_property_read_u32(args.fwnode,
+					"reg-io-width", &reg_io_width);
+		switch (reg_io_width) {
+		case 4:
+			*ops = &shmem_io_ops32;
+			break;
+		default:
+			*ops = &shmem_io_ops_default;
+			break;
+		}
+	}
+
+	fwnode_handle_put(args.fwnode);
 
 	return addr;
 }
diff --git a/drivers/firmware/arm_scmi/transports/mailbox.c b/drivers/firmware/arm_scmi/transports/mailbox.c
index 9c3f6f28cc6bd..0502edd332b9f 100644
--- a/drivers/firmware/arm_scmi/transports/mailbox.c
+++ b/drivers/firmware/arm_scmi/transports/mailbox.c
@@ -82,10 +82,6 @@ static bool mailbox_chan_available(struct device_node *of_node, int idx)
 {
 	int num_mb;
 
-	/*
-	 * In ACPI mode of_node is NULL; channel availability will be fully
-	 * validated later in mailbox_chan_validate() using _DSD properties.
-	 */
 	if (!of_node)
 		return true;
 
