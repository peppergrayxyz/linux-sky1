From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Wed, 4 Feb 2026 16:52:03 +1100
Subject: [PATCH] arm64: dts: cix: Add USB overcurrent and NVMe wake GPIOs on
 Orion O6

Wire up GPIO signals identified from schematic review:

USB overcurrent detection:
- sky1_usbss_0 (USB-C port 0): GPIO036 / s5_gpio0 25, active low
- sky1_usbss_2 (USB-C port 2): GPIO038 / s5_gpio0 27, active low
  (NX5P3290 FLT# output)

NVMe wake:
- pcie_x4_rc: GPIO018 / SFI_GPIO3 / s5_gpio1 3, active low
  (WAKE_SSD signal from M.2 M-Key NVMe slot)
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index 8d6fc38a3657c..8992a42a73d0a 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -397,6 +397,12 @@ CIX_PAD_SFI_GPIO1_FUNC_GPIO016 (PULL_UP|DS_LEVEL4) /* GPIO016 - S5_gpio1 1 */
 		>;
 	};
 
+	nvme_wake_gpio: nvme_wake_gpio {
+		sky1,pins = <
+			CIX_PAD_GPIO018_FUNC_SFI_GPIO3 (PULL_UP|DS_LEVEL4) /* GPIO018 - S5_gpio1 3 - WAKE_SSD */
+		>;
+	};
+
 	state_led_gpio: state_led_gpio {
 		sky1,pins = <
 			CIX_PAD_GPIO008_FUNC_GPIO008 (PULL_UP|DS_LEVEL4) /* GPIO008 - S5_gpio0 7 */
@@ -1473,6 +1479,7 @@ &usbc0_dp_phy {
 &sky1_usbss_0 {
 	pinctrl-names = "default";
 	pinctrl-0 = <&pinctrl_usb0>;
+	oc-gpio = <&s5_gpio0 25 IRQ_TYPE_LEVEL_LOW>;
 	sof_clk_freq = <8000000>;
 	lpm_clk_freq = <32000>;
 	status = "okay";
@@ -1557,6 +1564,7 @@ &usbc2_dp_phy {
 &sky1_usbss_2 {
 	pinctrl-names = "default";
 	pinctrl-0 = <&pinctrl_usb2>;
+	oc-gpio = <&s5_gpio0 27 IRQ_TYPE_LEVEL_LOW>;
 	sof_clk_freq = <8000000>;
 	lpm_clk_freq = <32000>;
 	status = "okay";
@@ -2174,8 +2182,9 @@ &pcie_x8_rc {
 &pcie_x4_rc {
 	plat-evk;
 	pinctrl-names = "default";
-	pinctrl-0 = <&pinctrl_pcie_x4_rc>;
+	pinctrl-0 = <&pinctrl_pcie_x4_rc>, <&nvme_wake_gpio>;
 	reset-gpios = <&s5_gpio0 3 GPIO_ACTIVE_HIGH>;
+	wake-gpios = <&s5_gpio1 3 GPIO_ACTIVE_LOW>;
 	vcc-pcie-supply = <&vdd_3v3_nvme>;
 	status = "okay";
 };
