+/*
+ * CIX Sky1 Cadence PCIe resource fixups for ACPI boot.
+ *
+ * Under ACPI, the DT platform driver (pci-sky1.c) cannot probe, so the
+ * MCFG quirk in pci-sky1-acpi.c handles full controller initialization
+ * (link quiesce, register writes, retrain).  These fixups run afterward
+ * in prepare_resources() to fix up the root bridge's resource windows.
+ *
+ * Problem 1 — MMIO window overlap with controller registers:
+ * The PNP0A08 root bridges declare MMIO windows starting at the Cadence
+ * controller's own message/IO register space.  The companion CIXH2020
+ * device correctly declares a DWordMemory starting 2MB higher (after the
+ * controller registers).  Under DT boot, the ranges property starts at
+ * the correct offset.  Under ACPI, we must trim the PNP0A08 window to
+ * match the CIXH2020 DWordMemory, otherwise BARs get assigned on top of
+ * controller registers and MMIO hits the wrong target.
+ *
+ * Problem 2 — D3hot hardware hang (belt-and-suspenders):
+ * The Cadence PCIe IP hangs if D3hot is entered via PCI PM.  The MCFG
+ * quirk init callback already writes POWER_STATE_CHANGE_CTRL = 0, but
+ * we also write it here as a safety net — this runs even if MCFG quirk
+ * matching fails (e.g., firmware update changes OEM revision).
+ *
+ * Problem 3 — Missing I/O port windows:
+ * The PNP0A08 root bridges lack DWordIO descriptors in their _CRS.
+ * The 1 MB I/O windows are declared only in the companion CIXH2020
+ * devices.  Without injection, devices with I/O BARs (e.g. RTL8126
+ * BAR 0) get assignment failures.  We extract DWordIO from the
+ * CIXH2020 _CRS and add it to the root bridge's resource list using
+ * the same lifecycle as acpi_pci_root_remap_iospace().
+ */
+#define CDNS_PCIE_POWER_STATE_CHANGE_CTRL	0x2430
+
+static void pci_acpi_cadence_sky1_fixups(struct acpi_pci_root_info *ci)
+{
+	struct acpi_device *adev;
+
+	for_each_acpi_dev_match(adev, "CIXH2020", NULL, -1) {
+		struct list_head resource_list;
+		struct resource_entry *rentry;
+		struct resource_entry *entry;
+		unsigned long long bbn;
+		bool ctrl_written = false;
+
+		if (ACPI_FAILURE(acpi_evaluate_integer(adev->handle,
+						       "_BBN", NULL, &bbn)))
+			continue;
+
+		if (bbn != ci->root->secondary.start)
+			continue;
+
+		/* Found the companion CIXH2020 for this root bridge */
+		INIT_LIST_HEAD(&resource_list);
+		if (acpi_dev_get_resources(adev, &resource_list,
+					   NULL, NULL) <= 0)
+			goto next;
+
+		list_for_each_entry(rentry, &resource_list, node) {
+			resource_size_t size = resource_size(rentry->res);
+
+			if (resource_type(rentry->res) != IORESOURCE_MEM)
+				continue;
+
+			/*
+			 * First 64K resource is the controller register bank.
+			 * Write once to disable HW-autonomous D-state changes.
+			 */
+			if (size == SZ_64K && !ctrl_written) {
+				void __iomem *base;
+
+				base = ioremap(rentry->res->start, SZ_64K);
+				if (base) {
+					writel(0, base +
+					       CDNS_PCIE_POWER_STATE_CHANGE_CTRL);
+					iounmap(base);
+					dev_info(&adev->dev,
+						 "disabled HW power state changes (bus %llu)\n",
+						 bbn);
+				}
+				ctrl_written = true;
+			}
+		}
+
+		/*
+		 * Trim root bridge MMIO windows to match the actual
+		 * outbound PCIe windows declared by CIXH2020.  The
+		 * PNP0A08 root bridge windows include Cadence controller
+		 * register space at the start which is not PCIe-reachable.
+		 *
+		 * Match by: CIXH2020 window resource has same end address
+		 * as the root bridge window but starts later.
+		 */
+		resource_list_for_each_entry(entry, &ci->resources) {
+			struct resource *res = entry->res;
+
+			if (!(res->flags & IORESOURCE_MEM))
+				continue;
+
+			list_for_each_entry(rentry, &resource_list, node) {
+				if (resource_type(rentry->res) != IORESOURCE_MEM)
+					continue;
+				if (!(rentry->res->flags & IORESOURCE_WINDOW))
+					continue;
+				if (rentry->res->end != res->end)
+					continue;
+				if (rentry->res->start <= res->start)
+					continue;
+
+				dev_info(&adev->dev,
+					 "trimming MMIO window [mem %#llx-%#llx] to [mem %#llx-%#llx] (bus %llu)\n",
+					 (unsigned long long)res->start,
+					 (unsigned long long)res->end,
+					 (unsigned long long)rentry->res->start,
+					 (unsigned long long)res->end, bbn);
+				res->start = rentry->res->start;
+				break;
+			}
+		}
+		/*
+		 * Inject I/O port resources from companion CIXH2020 _CRS.
+		 * PNP0A08 root bridges lack DWordIO — the 1 MB I/O windows
+		 * are only in the companion.  Skip if the root bridge already
+		 * has I/O resources (future firmware might add them).
+		 */
+		resource_list_for_each_entry(entry, &ci->resources) {
+			if (entry->res->flags & IORESOURCE_IO)
+				goto skip_io;
+		}
+
+#ifdef PCI_IOBASE
+		list_for_each_entry(rentry, &resource_list, node) {
+			resource_size_t cpu_addr, pci_addr, length;
+			struct resource *io_res;
+			unsigned long port;
+
+			if (resource_type(rentry->res) != IORESOURCE_IO)
+				continue;
+
+			cpu_addr = rentry->res->start;
+			pci_addr = cpu_addr - rentry->offset;
+			length = resource_size(rentry->res);
+
+			if (pci_register_io_range(&ci->bridge->fwnode,
+						  cpu_addr, length))
+				continue;
+
+			port = pci_address_to_pio(cpu_addr);
+			if (port == (unsigned long)-1)
+				continue;
+
+			io_res = kzalloc(sizeof(*io_res), GFP_KERNEL);
+			if (!io_res)
+				continue;
+
+			io_res->flags = IORESOURCE_IO | IORESOURCE_WINDOW;
+			io_res->name = ci->name;
+			io_res->start = port;
+			io_res->end = port + length - 1;
+
+			if (pci_remap_iospace(io_res, cpu_addr) < 0) {
+				kfree(io_res);
+				continue;
+			}
+
+			pci_add_resource_offset(&ci->resources, io_res,
+						port - pci_addr);
+			dev_info(&adev->dev,
+				 "injected I/O %pa to %pR (bus %llu)\n",
+				 &cpu_addr, io_res, bbn);
+		}
+#endif
+skip_io:
+		acpi_dev_free_resource_list(&resource_list);
+next:
+		acpi_dev_put(adev);
+		break;
+	}
+}
+
 static int pci_acpi_root_prepare_resources(struct acpi_pci_root_info *ci)
 {
 	struct resource_entry *entry, *tmp;
@@ -1606,6 +1787,9 @@ static int pci_acpi_root_prepare_resources(struct acpi_pci_root_info *ci)
 		if (!(entry->res->flags & IORESOURCE_WINDOW))
 			resource_list_destroy_entry(entry);
 	}
+
+	pci_acpi_cadence_sky1_fixups(ci);
+
 	return status;
 }
 
diff --git a/drivers/pci/quirks.c b/drivers/pci/quirks.c
index b86b17304c1d0..43ca6b172a8c8 100644
--- a/drivers/pci/quirks.c
+++ b/drivers/pci/quirks.c
@@ -6366,3 +6366,41 @@ static void pci_mask_replay_timer_timeout(struct pci_dev *pdev)
