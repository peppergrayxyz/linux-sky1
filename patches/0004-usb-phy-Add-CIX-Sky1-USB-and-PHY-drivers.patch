diff --git a/drivers/phy/cix/Kconfig b/drivers/phy/cix/Kconfig
new file mode 100644
index 0000000000000..dcf77de2ffedb
--- /dev/null
+++ b/drivers/phy/cix/Kconfig
@@ -0,0 +1,36 @@
+# SPDX-License-Identifier: GPL-2.0-only
+
+config PHY_CIX_PCIE
+	bool "CIX Sky1 PCIe PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the PCIe PHY on CIX Sky1 SoCs.
+	  This driver provides PHY support for the Cadence PCIe controller
+	  on CIX Sky1 platforms.
+
+config PHY_CIX_USB2
+	bool "CIX Sky1 USB2 PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB2 PHY on CIX Sky1 SoCs.
+
+config PHY_CIX_USB3
+	bool "CIX Sky1 USB3 PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB3 PHY on CIX Sky1 SoCs.
+
+config PHY_CIX_USBDP
+	bool "CIX Sky1 USB-DP combo PHY driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on OF
+	select GENERIC_PHY
+	help
+	  Enable this to support the USB-DP combo PHY on CIX Sky1 SoCs.
+	  This PHY supports both USB3 and DisplayPort alternate mode.
diff --git a/drivers/phy/cix/Makefile b/drivers/phy/cix/Makefile
new file mode 100644
index 0000000000000..8ab9af6e060b1
--- /dev/null
+++ b/drivers/phy/cix/Makefile
@@ -0,0 +1,5 @@
+# SPDX-License-Identifier: GPL-2.0
+obj-$(CONFIG_PHY_CIX_PCIE)	+= phy-cix-pcie.o
+obj-$(CONFIG_PHY_CIX_USB2)	+= phy-cix-usb2.o
+obj-$(CONFIG_PHY_CIX_USB3)	+= phy-cix-usb3.o
+obj-$(CONFIG_PHY_CIX_USBDP)	+= phy-cix-usbdp.o
