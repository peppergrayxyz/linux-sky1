+/* Regmap-based mux operations */
+static u8 sky1_audss_mux_get_parent(struct clk_hw *hw)
+{
+	struct clk_mux *mux = to_clk_mux(hw);
+	struct sky1_clk_mux *sky1_mux = container_of(mux, struct sky1_clk_mux, mux);
+	u32 val;
+
+	regmap_read(sky1_mux->regmap, sky1_mux->offset, &val);
+	val = (val >> mux->shift) & mux->mask;
+
+	return clk_mux_val_to_index(hw, mux->table, mux->flags, val);
+}
+
+static int sky1_audss_mux_set_parent(struct clk_hw *hw, u8 index)
+{
+	struct clk_mux *mux = to_clk_mux(hw);
+	struct sky1_clk_mux *sky1_mux = container_of(mux, struct sky1_clk_mux, mux);
+	u32 val = clk_mux_index_to_val(mux->table, mux->flags, index);
+	unsigned long flags = 0;
+
+	if (mux->lock)
+		spin_lock_irqsave(mux->lock, flags);
+
+	regmap_update_bits(sky1_mux->regmap, sky1_mux->offset,
+			   mux->mask << mux->shift, val << mux->shift);
+
+	if (mux->lock)
+		spin_unlock_irqrestore(mux->lock, flags);
+
+	return 0;
+}
+
+static int sky1_audss_mux_determine_rate(struct clk_hw *hw,
+					 struct clk_rate_request *req)
+{
+	struct clk_mux *mux = to_clk_mux(hw);
+
+	return clk_mux_determine_rate_flags(hw, req, mux->flags);
+}
+
+static const struct clk_ops sky1_audss_mux_ops = {
+	.get_parent = sky1_audss_mux_get_parent,
+	.set_parent = sky1_audss_mux_set_parent,
+	.determine_rate = sky1_audss_mux_determine_rate,
+};
+
+/* Regmap-based divider operations */
+static unsigned long sky1_audss_div_recalc_rate(struct clk_hw *hw,
+						unsigned long parent_rate)
+{
+	struct clk_divider *div = to_clk_divider(hw);
+	struct sky1_clk_divider *sky1_div = container_of(div, struct sky1_clk_divider, div);
+	u32 val;
+
+	regmap_read(sky1_div->regmap, sky1_div->offset, &val);
+	val = (val >> div->shift) & clk_div_mask(div->width);
+
+	return divider_recalc_rate(hw, parent_rate, val, div->table,
+				   div->flags, div->width);
+}
+
+static long sky1_audss_div_round_rate(struct clk_hw *hw, unsigned long rate,
+				      unsigned long *prate)
+{
+	struct clk_divider *div = to_clk_divider(hw);
+
+	return divider_round_rate(hw, rate, prate, div->table,
+				  div->width, div->flags);
+}
+
+static int sky1_audss_div_set_rate(struct clk_hw *hw, unsigned long rate,
+				   unsigned long parent_rate)
+{
+	struct clk_divider *div = to_clk_divider(hw);
+	struct sky1_clk_divider *sky1_div = container_of(div, struct sky1_clk_divider, div);
+	unsigned long flags = 0;
+	int value;
+
+	value = divider_get_val(rate, parent_rate, div->table,
+				div->width, div->flags);
+	if (value < 0)
+		return value;
+
+	if (div->lock)
+		spin_lock_irqsave(div->lock, flags);
+
+	regmap_update_bits(sky1_div->regmap, sky1_div->offset,
+			   clk_div_mask(div->width) << div->shift,
+			   (u32)value << div->shift);
+
+	if (div->lock)
+		spin_unlock_irqrestore(div->lock, flags);
+
+	return 0;
+}
+
+static const struct clk_ops sky1_audss_div_ops = {
+	.recalc_rate = sky1_audss_div_recalc_rate,
+	.round_rate = sky1_audss_div_round_rate,
+	.set_rate = sky1_audss_div_set_rate,
+};
+
+/* Regmap-based gate operations with pm_runtime for power domain management */
+static void sky1_audss_gate_endisable(struct clk_hw *hw, int enable)
+{
+	struct clk_gate *gate = to_clk_gate(hw);
+	struct sky1_clk_gate *sky1_gate = container_of(gate, struct sky1_clk_gate, gate);
+	int set = gate->flags & CLK_GATE_SET_TO_DISABLE ? 1 : 0;
+	unsigned long flags;
+	u32 reg;
+
+	set ^= enable;
+
+	if (gate->lock)
+		spin_lock_irqsave(gate->lock, flags);
+
+	regmap_read(sky1_gate->regmap, sky1_gate->offset, &reg);
+
+	if (set)
+		reg |= BIT(gate->bit_idx);
+	else
+		reg &= ~BIT(gate->bit_idx);
+
+	regmap_write(sky1_gate->regmap, sky1_gate->offset, reg);
+
+	if (gate->lock)
+		spin_unlock_irqrestore(gate->lock, flags);
+}
+
+/*
+ * Gate prepare: Resume AUDSS clock controller if suspended.
+ * Called from process context, so pm_runtime_get_sync() is safe.
+ */
+static int sky1_audss_gate_prepare(struct clk_hw *hw)
+{
+	struct clk_gate *gate = to_clk_gate(hw);
+	struct sky1_clk_gate *sky1_gate = container_of(gate, struct sky1_clk_gate, gate);
+	int ret;
+
+	dev_info(sky1_gate->dev, "gate_prepare: bit %d\n", gate->bit_idx);
+
+	ret = pm_runtime_get_sync(sky1_gate->dev);
+	if (ret < 0) {
+		pm_runtime_put_noidle(sky1_gate->dev);
+		dev_err(sky1_gate->dev, "failed to resume for clock prepare: %d\n", ret);
+		return ret;
+	}
+
+	dev_info(sky1_gate->dev, "gate_prepare: bit %d done, ret=%d\n",
+		 gate->bit_idx, ret);
+	return 0;
+}
+
+/*
+ * Gate unprepare: Allow AUDSS clock controller to suspend.
+ * Called from process context, so pm_runtime_put() is safe.
+ */
+static void sky1_audss_gate_unprepare(struct clk_hw *hw)
+{
+	struct clk_gate *gate = to_clk_gate(hw);
+	struct sky1_clk_gate *sky1_gate = container_of(gate, struct sky1_clk_gate, gate);
+
+	pm_runtime_put(sky1_gate->dev);
+}
+
+/*
+ * Gate enable: Toggle the clock gate. Device is already active from prepare().
+ * Called from atomic context, no sleeping allowed.
+ */
+static int sky1_audss_gate_enable(struct clk_hw *hw)
+{
+	struct clk_gate *gate = to_clk_gate(hw);
+	struct sky1_clk_gate *sky1_gate = container_of(gate, struct sky1_clk_gate, gate);
+
+	dev_dbg(sky1_gate->dev, "gate_enable: bit %d\n", gate->bit_idx);
+	sky1_audss_gate_endisable(hw, 1);
+	return 0;
+}
+
+/*
+ * Gate disable: Toggle the clock gate. Device stays active until unprepare().
+ * Called from atomic context, no sleeping allowed.
+ */
+static void sky1_audss_gate_disable(struct clk_hw *hw)
+{
+	sky1_audss_gate_endisable(hw, 0);
+}
+
+static int sky1_audss_gate_is_enabled(struct clk_hw *hw)
+{
+	struct clk_gate *gate = to_clk_gate(hw);
+	struct sky1_clk_gate *sky1_gate = container_of(gate, struct sky1_clk_gate, gate);
+	u32 val;
+
+	regmap_read(sky1_gate->regmap, sky1_gate->offset, &val);
+
+	if (gate->flags & CLK_GATE_SET_TO_DISABLE)
+		val ^= BIT(gate->bit_idx);
+
+	return !!(val & BIT(gate->bit_idx));
+}
+
+static const struct clk_ops sky1_audss_gate_ops = {
+	.prepare = sky1_audss_gate_prepare,
+	.unprepare = sky1_audss_gate_unprepare,
+	.enable = sky1_audss_gate_enable,
+	.disable = sky1_audss_gate_disable,
+	.is_enabled = sky1_audss_gate_is_enabled,
+};
+
+static struct clk_hw *sky1_audss_clk_register(struct device *dev,
+					      const char *name,
+					      const char * const *parent_names,
+					      int num_parents,
+					      struct regmap *regmap,
+					      struct muxdiv_cfg *mux_cfg,
+					      struct muxdiv_cfg *div_cfg,
+					      struct gate_cfg *gate_cfg,
+					      unsigned long flags)
+{
+	struct sky1_clk_mux *sky1_mux = NULL;
+	struct sky1_clk_divider *sky1_div = NULL;
+	struct sky1_clk_gate *sky1_gate = NULL;
+	const struct clk_ops *mux_ops = NULL;
+	const struct clk_ops *div_ops = NULL;
+	const struct clk_ops *gate_ops = NULL;
+	struct clk_parent_data *pdata;
+	struct clk_hw *hw;
+	int i;
+
+	pdata = devm_kcalloc(dev, num_parents, sizeof(*pdata), GFP_KERNEL);
+	if (!pdata)
+		return ERR_PTR(-ENOMEM);
+
+	for (i = 0; i < num_parents; i++)
+		pdata[i].fw_name = parent_names[i];
+
+	if (mux_cfg->offset >= 0) {
+		sky1_mux = devm_kzalloc(dev, sizeof(*sky1_mux), GFP_KERNEL);
+		if (!sky1_mux)
+			return ERR_PTR(-ENOMEM);
+
+		sky1_mux->mux.shift = mux_cfg->shift;
+		sky1_mux->mux.mask = BIT(mux_cfg->width) - 1;
+		sky1_mux->mux.flags = mux_cfg->flags;
+		sky1_mux->mux.lock = &sky1_audss_lock;
+		sky1_mux->regmap = regmap;
+		sky1_mux->offset = mux_cfg->offset;
+		mux_ops = &sky1_audss_mux_ops;
+	}
+
+	if (div_cfg->offset >= 0) {
+		sky1_div = devm_kzalloc(dev, sizeof(*sky1_div), GFP_KERNEL);
+		if (!sky1_div)
+			return ERR_PTR(-ENOMEM);
+
+		sky1_div->div.shift = div_cfg->shift;
+		sky1_div->div.width = div_cfg->width;
+		sky1_div->div.flags = div_cfg->flags | CLK_DIVIDER_POWER_OF_TWO;
+		sky1_div->div.lock = &sky1_audss_lock;
+		sky1_div->regmap = regmap;
+		sky1_div->offset = div_cfg->offset;
+		div_ops = &sky1_audss_div_ops;
+	}
+
+	if (gate_cfg->offset >= 0) {
+		sky1_gate = devm_kzalloc(dev, sizeof(*sky1_gate), GFP_KERNEL);
+		if (!sky1_gate)
+			return ERR_PTR(-ENOMEM);
+
+		sky1_gate->gate.bit_idx = gate_cfg->shift;
+		sky1_gate->gate.flags = gate_cfg->flags;
+		sky1_gate->gate.lock = &sky1_audss_lock;
+		sky1_gate->regmap = regmap;
+		sky1_gate->offset = gate_cfg->offset;
+		sky1_gate->dev = dev;
+		gate_ops = &sky1_audss_gate_ops;
+	}
+
+	hw = devm_clk_hw_register_composite_pdata(dev, name,
+			pdata, num_parents,
+			sky1_mux ? &sky1_mux->mux.hw : NULL, mux_ops,
+			sky1_div ? &sky1_div->div.hw : NULL, div_ops,
+			sky1_gate ? &sky1_gate->gate.hw : NULL, gate_ops,
+			flags);
+	if (IS_ERR(hw))
+		dev_err(dev, "failed to register %s: %ld\n", name, PTR_ERR(hw));
+
+	return hw;
+}
+
+/* Helper functions for parent clock management */
+static int sky1_audss_clks_enable(struct sky1_audss_priv *priv)
+{
+	int i, ret;
+
+	for (i = 0; i < SKY1_AUDSS_CLKS_NUM; i++) {
+		ret = clk_prepare_enable(priv->parent_clks[i]);
+		if (ret) {
+			dev_err(priv->dev, "failed to enable %s\n",
+				sky1_audss_clk_names[i]);
+			goto err_clks;
+		}
+	}
+	return 0;
+
+err_clks:
+	while (--i >= 0)
+		clk_disable_unprepare(priv->parent_clks[i]);
+	return ret;
+}
+
+static void sky1_audss_clks_disable(struct sky1_audss_priv *priv)
+{
+	int i;
+
+	for (i = 0; i < SKY1_AUDSS_CLKS_NUM; i++)
+		clk_disable_unprepare(priv->parent_clks[i]);
+}
+
+/* Runtime PM callbacks */
+static int __maybe_unused sky1_audss_clk_runtime_suspend(struct device *dev)
+{
+	struct sky1_audss_priv *priv = dev_get_drvdata(dev);
+	int i;
+
+	/* Save register state before power down */
+	for (i = 0; i < ARRAY_SIZE(sky1_audss_reg_save); i++)
+		regmap_read(priv->regmap, sky1_audss_reg_save[i][0],
+			    &sky1_audss_reg_save[i][1]);
+
+	sky1_audss_clks_disable(priv);
+
+	return 0;
+}
+
+static int __maybe_unused sky1_audss_clk_runtime_resume(struct device *dev)
+{
+	struct sky1_audss_priv *priv = dev_get_drvdata(dev);
+	int i, ret;
+
+	ret = sky1_audss_clks_enable(priv);
+	if (ret) {
+		dev_err(dev, "failed to enable clocks\n");
+		return ret;
+	}
+
+	/* Release NOC reset */
+	reset_control_deassert(priv->rst_noc);
+
+	/* Restore RCSU remap */
+	writel(SKY1_AUDSS_RCSU_REMAP_VAL, priv->rcsu_base + SKY1_AUDSS_RCSU_REMAP);
+
+	/* Restore register state */
+	for (i = 0; i < ARRAY_SIZE(sky1_audss_reg_save); i++)
+		regmap_write(priv->regmap, sky1_audss_reg_save[i][0],
+			     sky1_audss_reg_save[i][1]);
+
+	return 0;
+}
+
+static const struct dev_pm_ops sky1_audss_clk_pm_ops = {
+	SET_RUNTIME_PM_OPS(sky1_audss_clk_runtime_suspend,
+			   sky1_audss_clk_runtime_resume, NULL)
+	SET_LATE_SYSTEM_SLEEP_PM_OPS(pm_runtime_force_suspend,
+				     pm_runtime_force_resume)
+};
+
+static int sky1_audss_clk_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct device_node *parent_np;
+	struct sky1_audss_priv *priv;
+	struct clk_hw **clk_table;
+	int i, ret;
+
+	priv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	priv->dev = dev;
+
+	/* Get regmap from parent syscon */
+	parent_np = of_get_parent(dev->of_node);
+	priv->regmap = syscon_node_to_regmap(parent_np);
+	of_node_put(parent_np);
+
+	if (IS_ERR(priv->regmap))
+		return dev_err_probe(dev, PTR_ERR(priv->regmap),
+				     "failed to get parent regmap\n");
+
+	/* Get parent clocks from SCMI */
+	for (i = 0; i < SKY1_AUDSS_CLKS_NUM; i++) {
+		priv->parent_clks[i] = devm_clk_get(dev, sky1_audss_clk_names[i]);
+		if (IS_ERR(priv->parent_clks[i]))
+			return dev_err_probe(dev, PTR_ERR(priv->parent_clks[i]),
+					     "failed to get %s\n", sky1_audss_clk_names[i]);
+	}
+
+	/* Allocate clock data */
+	priv->clk_data = devm_kzalloc(dev, struct_size(priv->clk_data, hws, AUDSS_MAX_CLKS),
+				      GFP_KERNEL);
+	if (!priv->clk_data)
+		return -ENOMEM;
+
+	priv->clk_data->num = AUDSS_MAX_CLKS;
+	clk_table = priv->clk_data->hws;
+
+	platform_set_drvdata(pdev, priv);
+
+	/*
+	 * Enable runtime PM to allow the clock core to use runtime PM
+	 * for the registered clocks. Mark device as active before
+	 * enabling clocks.
+	 */
+	pm_runtime_get_noresume(dev);
+	pm_runtime_set_active(dev);
+	pm_runtime_enable(dev);
+
+	/* Enable parent clocks and set default rates */
+	ret = sky1_audss_clks_enable(priv);
+	if (ret) {
+		dev_err(dev, "failed to enable clocks\n");
+		goto err_pm;
+	}
+
+	for (i = 0; i < SKY1_AUDSS_CLKS_NUM; i++) {
+		ret = clk_set_rate(priv->parent_clks[i], sky1_audss_clk_rates[i]);
+		if (ret)
+			dev_warn(dev, "failed to set rate for %s\n", sky1_audss_clk_names[i]);
+	}
+
+	/* Get and deassert NOC reset */
+	priv->rst_noc = devm_reset_control_get(dev, "noc");
+	if (IS_ERR(priv->rst_noc)) {
+		ret = dev_err_probe(dev, PTR_ERR(priv->rst_noc),
+				    "failed to get noc reset\n");
+		goto err_clks;
+	}
+
+	reset_control_assert(priv->rst_noc);
+	usleep_range(1, 2);
+	reset_control_deassert(priv->rst_noc);
+
+	/* Map RCSU for DSP initialization */
+	priv->rcsu_base = ioremap(SKY1_AUDSS_RCSU_ADDR, SKY1_AUDSS_RCSU_LEN);
+	if (!priv->rcsu_base) {
+		ret = -ENOMEM;
+		goto err_clks;
+	}
+
+	/* Configure RCSU address remap and timeout */
+	writel(SKY1_AUDSS_RCSU_REMAP_VAL, priv->rcsu_base + SKY1_AUDSS_RCSU_REMAP);
+	writel(SKY1_AUDSS_RCSU_TIMEOUT_EN |
+	       FIELD_PREP(GENMASK(15, 0), SKY1_AUDSS_RCSU_TIMEOUT_VAL),
+	       priv->rcsu_base + SKY1_AUDSS_RCSU_TIMEOUT);
+
+	/* Register fixed divider clocks */
+	clk_table[CLK_AUD_CLK4_DIV2] =
+		devm_clk_hw_register_fixed_factor(dev, "audio_clk4_div2",
+						  "audio_clk4", CLK_GET_RATE_NOCACHE, 1, 2);
+	clk_table[CLK_AUD_CLK4_DIV4] =
+		devm_clk_hw_register_fixed_factor(dev, "audio_clk4_div4",
+						  "audio_clk4", CLK_GET_RATE_NOCACHE, 1, 4);
+	clk_table[CLK_AUD_CLK5_DIV2] =
+		devm_clk_hw_register_fixed_factor(dev, "audio_clk5_div2",
+						  "audio_clk5", CLK_GET_RATE_NOCACHE, 1, 2);
+
+	/* Register composite clocks */
+	for (i = 0; i < ARRAY_SIZE(audss_clks); i++) {
+		clk_table[audss_clks[i].id] = sky1_audss_clk_register(dev,
+			audss_clks[i].name,
+			audss_clks[i].parent_names,
+			audss_clks[i].num_parents,
+			priv->regmap,
+			audss_clks[i].mux_cfg,
+			audss_clks[i].div_cfg,
+			audss_clks[i].gate_cfg,
+			audss_clks[i].flags);
+	}
+
+	/* Check all clocks registered successfully */
+	for (i = 0; i < AUDSS_MAX_CLKS; i++) {
+		if (IS_ERR(clk_table[i])) {
+			ret = PTR_ERR(clk_table[i]);
+			dev_err(dev, "failed to register clock %d: %d\n", i, ret);
+			goto err_rcsu;
+		}
+	}
+
+	ret = devm_of_clk_add_hw_provider(dev, of_clk_hw_onecell_get, priv->clk_data);
+	if (ret) {
+		dev_err(dev, "failed to add clock provider: %d\n", ret);
+		goto err_rcsu;
+	}
+
+	/*
+	 * Keep AUDSS active after probe. Consumers like DMA-350 need the
+	 * clock controller to be powered when they enable clocks during
+	 * their probe. We rely on the gate prepare/unprepare callbacks
+	 * to manage runtime PM reference counting during normal operation.
+	 *
+	 * The initial pm_runtime_get_noresume() reference is kept - we
+	 * don't call pm_runtime_put_sync() here.
+	 */
+	dev_info(dev, "registered %d clocks\n", AUDSS_MAX_CLKS);
+	return 0;
+
+err_rcsu:
+	iounmap(priv->rcsu_base);
+err_clks:
+	sky1_audss_clks_disable(priv);
+err_pm:
+	pm_runtime_put_sync(dev);
+	pm_runtime_disable(dev);
+	return ret;
+}
+
+static void sky1_audss_clk_remove(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct sky1_audss_priv *priv = platform_get_drvdata(pdev);
+
+	iounmap(priv->rcsu_base);
+
+	/* Force suspend if not already suspended */
+	if (!pm_runtime_status_suspended(dev))
+		pm_runtime_force_suspend(dev);
+
+	pm_runtime_disable(dev);
+}
+
+static const struct of_device_id sky1_audss_clk_of_match[] = {
+	{ .compatible = "cix,sky1-audss-clock" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, sky1_audss_clk_of_match);
+
+static struct platform_driver sky1_audss_clk_driver = {
+	.probe = sky1_audss_clk_probe,
+	.remove = sky1_audss_clk_remove,
+	.driver = {
+		.name = "sky1-audss-clk",
+		.of_match_table = sky1_audss_clk_of_match,
+		.pm = &sky1_audss_clk_pm_ops,
+	},
+};
+module_platform_driver(sky1_audss_clk_driver);
+
+MODULE_AUTHOR("Joakim Zhang <joakim.zhang@cixtech.com>");
+MODULE_DESCRIPTION("CIX Sky1 Audio Subsystem Clock Controller");
+MODULE_LICENSE("GPL");
