 };
 
 &thermal_zones {
-	cpu-m1-thermal {
+	tz-cpu-6-7 {
 		polling-delay-passive = <100>;
 		polling-delay = <1000>;
 		thermal-sensors = <&scmi_sensor CPU_M1_TEMP_SENSOR_ID>;
@@ -2376,7 +2376,7 @@ map1 {
 		};
 	};
 
