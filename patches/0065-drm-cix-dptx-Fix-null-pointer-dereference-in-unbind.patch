From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 27 Dec 2025 23:29:15 +1100
Subject: [PATCH] drm/cix: dptx: Fix null pointer dereference in unbind

Check if dpsub->link is valid before calling device_link_del(). The link
can be NULL if component binding failed before link creation.
---
 drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c b/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
index 18b3c6a5ad939..8cfe75180379e 100644
--- a/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
+++ b/drivers/gpu/drm/cix/dptx/trilin_dptx_cix.c
@@ -188,7 +188,8 @@ static void trilin_dptx_cix_unbind(struct device *comp, struct device *master,
 
 	trilin_dp_remove(dpsub);
 
-	device_link_del(dpsub->link);
+	if (dpsub->link)
+		device_link_del(dpsub->link);
 }
 
 static const struct component_ops trilin_dptx_cix_ops = {
