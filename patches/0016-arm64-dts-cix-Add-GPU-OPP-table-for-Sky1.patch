From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sun, 1 Feb 2026 23:21:49 +1100
Subject: [PATCH] arm64: dts: cix: Add GPU OPP table for Sky1

Add operating-points-v2 table documenting the GPU frequency levels from
the CIX P1 GPU Development Guide: 350, 600, 800, and 1000 MHz.

The SCMI perf domain (domain 0) provides these dynamically at runtime
via the Panthor SCMI devfreq integration. This DT table serves as
documentation and fallback for configurations without SCMI DVFS.

The vendor guide also defines 72 MHz (2 cores) and 216 MHz (6 cores)
DCS levels, but Panthor does not support Dynamic Core Scaling so
those are omitted.
---
 arch/arm64/boot/dts/cix/sky1.dtsi | 27 +++++++++++++++++++++++++++
 1 file changed, 27 insertions(+)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 728cc7bc750a6..fdc23eca42478 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -3037,6 +3037,32 @@ gpu_protected_memory_allocator: protected-memory-allocator {
 			memory-region = <&mali_protected>;
 		};
 
+		gpu_opp_table: opp-table-gpu {
+			compatible = "operating-points-v2";
+
+			/*
+			 * GPU OPP levels from CIX P1 GPU Development Guide.
+			 * The SCMI perf domain (domain 0) provides these dynamically
+			 * at runtime; this table serves as documentation and fallback.
+			 *
+			 * The vendor guide also defines 72 MHz (2 cores) and 216 MHz
+			 * (6 cores) DCS levels, but Panthor does not support Dynamic
+			 * Core Scaling so those are omitted.
+			 */
+			opp-350000000 {
+				opp-hz = /bits/ 64 <350000000>;
+			};
+			opp-600000000 {
+				opp-hz = /bits/ 64 <600000000>;
+			};
+			opp-800000000 {
+				opp-hz = /bits/ 64 <800000000>;
+			};
+			opp-1000000000 {
+				opp-hz = /bits/ 64 <1000000000>;
+			};
+		};
+
 		gpu: gpu@15010000 {
 			compatible = "arm,mali-valhall";
 			reg = <0x0 0x15000000 0x0 0x10000>,
@@ -3050,6 +3076,7 @@ gpu: gpu@15010000 {
 			system-coherency = <0>;
 			physical-memory-group-manager = <&gpu_physical_memory_group_manager>;
 			protected-memory-allocator = <&gpu_protected_memory_allocator>;
+			operating-points-v2 = <&gpu_opp_table>;
 			power-domains = <&smc_devpd SKY1_PD_GPU>, <&scmi_dvfs 0>;
 			power-domain-names = "pd_gpu", "perf";
 			clocks = <&scmi_clk CLK_TREE_GPU_CLK_CORE>, <&scmi_clk CLK_TREE_GPU_CLK_STACKS>,
