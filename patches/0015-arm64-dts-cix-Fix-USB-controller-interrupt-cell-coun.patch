 arch/arm64/boot/dts/cix/sky1.dtsi | 80 +++++++++++++++----------------
 1 file changed, 40 insertions(+), 40 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 94f16aa9461a2..2bbcc25b6970f 100644
