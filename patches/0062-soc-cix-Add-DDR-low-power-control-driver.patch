From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 27 Dec 2025 23:27:20 +1100
Subject: [PATCH] soc: cix: Add DDR low power control driver

Add driver for controlling DDR self-refresh and power-down states on CIX
Sky1 SoC. The driver uses SMC calls to TF-A firmware (SIP 0xc2000010) to
enable/disable DDR low power modes.

Provides sysfs interface at /sys/devices/platform/cix_ddr_lp/on for
runtime control (1=enabled, 0=disabled). DDR LP is enabled by default.
---
 drivers/soc/cix/Kconfig      |  16 ++++
 drivers/soc/cix/Makefile     |   1 +
 drivers/soc/cix/cix-ddr-lp.c | 156 +++++++++++++++++++++++++++++++++++
 3 files changed, 173 insertions(+)
 create mode 100644 drivers/soc/cix/cix-ddr-lp.c

diff --git a/drivers/soc/cix/Kconfig b/drivers/soc/cix/Kconfig
index 1d475bd15464e..554f668237b8a 100644
--- a/drivers/soc/cix/Kconfig
+++ b/drivers/soc/cix/Kconfig
@@ -12,3 +12,19 @@ config CIX_SKY1_SOCINFO
 
 	  This driver can also be built as a module. If so, the module
 	  will be called sky1-socinfo.
+
+config CIX_DDR_LP
+	tristate "CIX DDR Low Power control driver"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on HAVE_ARM_SMCCC
+	default ARCH_CIX
+	help
+	  Say yes here to enable support for the CIX DDR low power control
+	  driver. This allows enabling/disabling DDR self-refresh and power-down
+	  states via SMC calls to TF-A firmware.
+
+	  The driver exposes a sysfs interface at /sys/devices/.../on to control
+	  DDR low power mode (1=enabled, 0=disabled).
+
+	  This driver can also be built as a module. If so, the module
+	  will be called cix-ddr-lp.
diff --git a/drivers/soc/cix/Makefile b/drivers/soc/cix/Makefile
index a7c720e53ab82..1887354b09aaf 100644
--- a/drivers/soc/cix/Makefile
+++ b/drivers/soc/cix/Makefile
@@ -1,2 +1,3 @@
 # SPDX-License-Identifier: GPL-2.0-only
 obj-$(CONFIG_CIX_SKY1_SOCINFO)	+= sky1-socinfo.o
+obj-$(CONFIG_CIX_DDR_LP)	+= cix-ddr-lp.o
diff --git a/drivers/soc/cix/cix-ddr-lp.c b/drivers/soc/cix/cix-ddr-lp.c
new file mode 100644
index 0000000000000..0db9a82d7618b
--- /dev/null
+++ b/drivers/soc/cix/cix-ddr-lp.c
@@ -0,0 +1,156 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * CIX DDR Low Power driver
+ *
+ * Controls DDR self-refresh and power-down states via SMC call to TF-A.
+ *
+ * Copyright 2024 Cix Technology Group Co., Ltd.
+ */
+
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/of.h>
+#include <linux/arm-smccc.h>
+
+#define CIX_SIP_SET_DDRLP	0xc2000010
+
+struct cix_ddrlp_data {
+	int value;
+	int disable_depth;
+	struct mutex lock;
+};
+
+static struct cix_ddrlp_data *gdd;
+
+static int cix_disable_ddrlp(struct cix_ddrlp_data *dd)
+{
+	struct arm_smccc_res res;
+
+	mutex_lock(&dd->lock);
+	if (dd->disable_depth != 0) {
+		dd->disable_depth++;
+		mutex_unlock(&dd->lock);
+		return 0;
+	}
+
+	arm_smccc_smc(CIX_SIP_SET_DDRLP, 0, 0, 0, 0, 0, 0, 0, &res);
+	if (res.a0) {
+		mutex_unlock(&dd->lock);
+		return -EIO;
+	}
+	dd->disable_depth++;
+	dd->value = 0;
+	mutex_unlock(&dd->lock);
+	return 0;
+}
+
+static int cix_enable_ddrlp(struct cix_ddrlp_data *dd)
+{
+	struct arm_smccc_res res;
+
+	mutex_lock(&dd->lock);
+	if (dd->disable_depth == 0) {
+		mutex_unlock(&dd->lock);
+		return 0;
+	}
+	dd->disable_depth--;
+	if (dd->disable_depth == 0) {
+		arm_smccc_smc(CIX_SIP_SET_DDRLP, 1, 0, 0, 0, 0, 0, 0, &res);
+		if (res.a0) {
+			mutex_unlock(&dd->lock);
+			return -EIO;
+		}
+		dd->value = 1;
+	}
+	mutex_unlock(&dd->lock);
+	return 0;
+}
+
+int cix_set_ddrlp(int on)
+{
+	if (!gdd)
+		return -ENODEV;
+
+	if (on)
+		return cix_enable_ddrlp(gdd);
+	else
+		return cix_disable_ddrlp(gdd);
+}
+EXPORT_SYMBOL(cix_set_ddrlp);
+
+static ssize_t on_show(struct device *dev,
+		       struct device_attribute *attr, char *buf)
+{
+	struct cix_ddrlp_data *dd = dev_get_drvdata(dev);
+
+	return sysfs_emit(buf, "%d\n", dd->value);
+}
+
+static ssize_t on_store(struct device *dev, struct device_attribute *attr,
+			const char *buf, size_t count)
+{
+	int ret;
+	int value;
+	struct cix_ddrlp_data *dd = dev_get_drvdata(dev);
+
+	ret = kstrtoint(buf, 0, &value);
+	if (ret)
+		return -EINVAL;
+
+	if (value != 0 && value != 1)
+		return -EINVAL;
+
+	if (value == dd->value)
+		return count;
+
+	ret = cix_set_ddrlp(value);
+	if (ret < 0) {
+		dev_err(dev, "failed to set DDR LP: %d\n", ret);
+		return ret;
+	}
+	return count;
+}
+static DEVICE_ATTR_RW(on);
+
+static struct attribute *ddrlp_attrs[] = {
+	&dev_attr_on.attr,
+	NULL,
+};
+ATTRIBUTE_GROUPS(ddrlp);
+
+static int cix_ddrlp_probe(struct platform_device *pdev)
+{
+	struct cix_ddrlp_data *cix_ddrlp;
+
+	cix_ddrlp = devm_kzalloc(&pdev->dev, sizeof(*cix_ddrlp), GFP_KERNEL);
+	if (!cix_ddrlp)
+		return -ENOMEM;
+
+	gdd = cix_ddrlp;
+	cix_ddrlp->value = 1;  /* DDR LP enabled by default */
+	cix_ddrlp->disable_depth = 0;
+	mutex_init(&cix_ddrlp->lock);
+	platform_set_drvdata(pdev, cix_ddrlp);
+
+	dev_info(&pdev->dev, "DDR low power control initialized\n");
+	return 0;
+}
+
+static const struct of_device_id cix_ddrlp_of_match[] = {
+	{ .compatible = "cix,ddr-lp" },
+	{},
+};
+MODULE_DEVICE_TABLE(of, cix_ddrlp_of_match);
+
+static struct platform_driver cix_ddrlp_driver = {
+	.probe = cix_ddrlp_probe,
+	.driver = {
+		.name = "cix-ddr-lp",
+		.of_match_table = cix_ddrlp_of_match,
+		.dev_groups = ddrlp_groups,
+	},
+};
+module_platform_driver(cix_ddrlp_driver);
+
+MODULE_DESCRIPTION("CIX DDR Low Power Driver");
+MODULE_LICENSE("GPL");
