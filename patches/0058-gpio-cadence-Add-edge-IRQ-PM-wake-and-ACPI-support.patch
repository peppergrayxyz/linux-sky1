From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 5 Feb 2026 23:57:33 +1100
Subject: [PATCH] gpio: cadence: Add edge IRQ, PM, wake, and ACPI support

Extend the Cadence GPIO driver with features needed for Sky1 platform:

- Edge interrupt support (RISING, FALLING, BOTH) via IRQ_ANY_EDGE register
- PM suspend/resume with full register save/restore
- Wake source support via irq_set_wake callback
- ACPI device ID support (CIXH1002, CIXH1003)
- Sky1 PDC integration for system wake configuration
- Optional reset control for resume recovery
- gpio-io-mask property for input-only pin protection
- Shutdown handler for wake configuration before reboot

Use LATE_SYSTEM_SLEEP_PM_OPS for proper GPIO controller ordering
during suspend/resume. Add IRQCHIP_MASK_ON_SUSPEND flag for correct
IRQ handling. Sky1 PDC calls are conditional based on platform
detection via match data.
---
 drivers/gpio/gpio-cadence.c | 253 +++++++++++++++++++++++++++++++-----
 1 file changed, 219 insertions(+), 34 deletions(-)

diff --git a/drivers/gpio/gpio-cadence.c b/drivers/gpio/gpio-cadence.c
index b75734ca22dd7..e2ca7b20fa776 100644
--- a/drivers/gpio/gpio-cadence.c
+++ b/drivers/gpio/gpio-cadence.c
@@ -8,14 +8,19 @@
  *  Boris Brezillon <boris.brezillon@free-electrons.com>
  */
 
+#include <linux/acpi.h>
+#include <linux/arm-smccc.h>
 #include <linux/cleanup.h>
 #include <linux/clk.h>
 #include <linux/gpio/driver.h>
-#include <linux/interrupt.h>
 #include <linux/gpio/generic.h>
+#include <linux/interrupt.h>
 #include <linux/kernel.h>
 #include <linux/module.h>
 #include <linux/platform_device.h>
+#include <linux/pm.h>
+#include <linux/property.h>
+#include <linux/reset.h>
 #include <linux/spinlock.h>
 
 #define CDNS_GPIO_BYPASS_MODE		0x00
@@ -31,10 +36,31 @@
 #define CDNS_GPIO_IRQ_VALUE		0x28
 #define CDNS_GPIO_IRQ_ANY_EDGE		0x2c
 
+/* Sky1 Power Domain Controller SMC interface */
+#define SKY1_SIP_GPIO_PDC		0xC2000009
+#define SKY1_SIP_GPIO_PDC_SET_WAKE	0x02
+
+struct cdns_gpio_saved_regs {
+	u32 bypass_mode;
+	u32 direction_mode;
+	u32 output_en;
+	u32 output_value;
+	u32 irq_en;
+	u32 irq_type;
+	u32 irq_value;
+	u32 irq_any_edge;
+};
+
 struct cdns_gpio_chip {
 	struct gpio_generic_chip gen_gc;
 	void __iomem *regs;
 	u32 bypass_orig;
+	struct clk *pclk;
+	struct reset_control *rst;
+	u32 wake_active;
+	u32 hw_irq;
+	bool has_sky1_pdc;
+	struct cdns_gpio_saved_regs saved_regs;
 };
 
 static int cdns_gpio_request(struct gpio_chip *chip, unsigned int offset)
@@ -82,35 +108,54 @@ static int cdns_gpio_irq_set_type(struct irq_data *d, unsigned int type)
 {
 	struct gpio_chip *chip = irq_data_get_irq_chip_data(d);
 	struct cdns_gpio_chip *cgpio = gpiochip_get_data(chip);
-	u32 int_value;
-	u32 int_type;
 	u32 mask = BIT(d->hwirq);
-	int ret = 0;
+	u32 int_value, int_type, int_any_edge;
 
 	guard(gpio_generic_lock)(&cgpio->gen_gc);
 
 	int_value = ioread32(cgpio->regs + CDNS_GPIO_IRQ_VALUE) & ~mask;
 	int_type = ioread32(cgpio->regs + CDNS_GPIO_IRQ_TYPE) & ~mask;
+	int_any_edge = ioread32(cgpio->regs + CDNS_GPIO_IRQ_ANY_EDGE) & ~mask;
 
-	/*
-	 * The GPIO controller doesn't have an ACK register.
-	 * All interrupt statuses are cleared on a status register read.
-	 * Don't support edge interrupts for now.
-	 */
-
-	if (type == IRQ_TYPE_LEVEL_HIGH) {
+	switch (type) {
+	case IRQ_TYPE_EDGE_RISING:
+		int_value |= mask;
+		break;
+	case IRQ_TYPE_EDGE_FALLING:
+		break;
+	case IRQ_TYPE_EDGE_BOTH:
+		int_any_edge |= mask;
+		break;
+	case IRQ_TYPE_LEVEL_HIGH:
 		int_type |= mask;
 		int_value |= mask;
-	} else if (type == IRQ_TYPE_LEVEL_LOW) {
+		break;
+	case IRQ_TYPE_LEVEL_LOW:
 		int_type |= mask;
-	} else {
+		break;
+	default:
 		return -EINVAL;
 	}
 
 	iowrite32(int_value, cgpio->regs + CDNS_GPIO_IRQ_VALUE);
 	iowrite32(int_type, cgpio->regs + CDNS_GPIO_IRQ_TYPE);
+	iowrite32(int_any_edge, cgpio->regs + CDNS_GPIO_IRQ_ANY_EDGE);
 
-	return ret;
+	return 0;
+}
+
+static int cdns_gpio_irq_set_wake(struct irq_data *d, unsigned int enable)
+{
+	struct gpio_chip *chip = irq_data_get_irq_chip_data(d);
+	struct cdns_gpio_chip *cgpio = gpiochip_get_data(chip);
+	irq_hw_number_t hwirq = irqd_to_hwirq(d);
+
+	if (enable)
+		cgpio->wake_active |= BIT(hwirq);
+	else
+		cgpio->wake_active &= ~BIT(hwirq);
+
+	return 0;
 }
 
 static void cdns_gpio_irq_handler(struct irq_desc *desc)
@@ -137,10 +182,106 @@ static const struct irq_chip cdns_gpio_irqchip = {
 	.irq_mask	= cdns_gpio_irq_mask,
 	.irq_unmask	= cdns_gpio_irq_unmask,
 	.irq_set_type	= cdns_gpio_irq_set_type,
-	.flags		= IRQCHIP_IMMUTABLE,
+	.irq_set_wake	= cdns_gpio_irq_set_wake,
+	.flags		= IRQCHIP_IMMUTABLE | IRQCHIP_MASK_ON_SUSPEND,
 	GPIOCHIP_IRQ_RESOURCE_HELPERS,
 };
 
+#ifdef CONFIG_PM_SLEEP
+static void cdns_gpio_save_regs(struct cdns_gpio_chip *cgpio)
+{
+	cgpio->saved_regs.bypass_mode = ioread32(cgpio->regs + CDNS_GPIO_BYPASS_MODE);
+	cgpio->saved_regs.direction_mode = ioread32(cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
+	cgpio->saved_regs.output_en = ioread32(cgpio->regs + CDNS_GPIO_OUTPUT_EN);
+	cgpio->saved_regs.output_value = ioread32(cgpio->regs + CDNS_GPIO_OUTPUT_VALUE);
+	cgpio->saved_regs.irq_en = ioread32(cgpio->regs + CDNS_GPIO_IRQ_MASK);
+	cgpio->saved_regs.irq_type = ioread32(cgpio->regs + CDNS_GPIO_IRQ_TYPE);
+	cgpio->saved_regs.irq_value = ioread32(cgpio->regs + CDNS_GPIO_IRQ_VALUE);
+	cgpio->saved_regs.irq_any_edge = ioread32(cgpio->regs + CDNS_GPIO_IRQ_ANY_EDGE);
+}
+
+static void cdns_gpio_restore_regs(struct cdns_gpio_chip *cgpio)
+{
+	iowrite32(cgpio->saved_regs.bypass_mode, cgpio->regs + CDNS_GPIO_BYPASS_MODE);
+	iowrite32(cgpio->saved_regs.direction_mode, cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
+	iowrite32(cgpio->saved_regs.output_en, cgpio->regs + CDNS_GPIO_OUTPUT_EN);
+	iowrite32(cgpio->saved_regs.output_value, cgpio->regs + CDNS_GPIO_OUTPUT_VALUE);
+	iowrite32(cgpio->saved_regs.irq_type, cgpio->regs + CDNS_GPIO_IRQ_TYPE);
+	iowrite32(cgpio->saved_regs.irq_value, cgpio->regs + CDNS_GPIO_IRQ_VALUE);
+	iowrite32(cgpio->saved_regs.irq_any_edge, cgpio->regs + CDNS_GPIO_IRQ_ANY_EDGE);
+	iowrite32(~cgpio->saved_regs.irq_en, cgpio->regs + CDNS_GPIO_IRQ_EN);
+}
+
+static void cdns_gpio_sky1_set_wake(struct cdns_gpio_chip *cgpio, bool suspend)
+{
+	struct arm_smccc_res res;
+
+	if (!cgpio->has_sky1_pdc)
+		return;
+
+	arm_smccc_smc(SKY1_SIP_GPIO_PDC, SKY1_SIP_GPIO_PDC_SET_WAKE,
+		      cgpio->hw_irq - 32, suspend ? 1 : 0,
+		      cgpio->wake_active, 0, 0, 0, &res);
+}
+
+static int cdns_gpio_suspend(struct device *dev)
+{
+	struct cdns_gpio_chip *cgpio = dev_get_drvdata(dev);
+
+	cdns_gpio_save_regs(cgpio);
+
+	/* Mask non-wake interrupts */
+	iowrite32(~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
+
+	cdns_gpio_sky1_set_wake(cgpio, true);
+
+	if (cgpio->pclk)
+		clk_disable_unprepare(cgpio->pclk);
+
+	return 0;
+}
+
+static int cdns_gpio_resume(struct device *dev)
+{
+	struct cdns_gpio_chip *cgpio = dev_get_drvdata(dev);
+	int ret;
+
+	if (cgpio->pclk) {
+		ret = clk_prepare_enable(cgpio->pclk);
+		if (ret) {
+			dev_err(dev, "Failed to enable clock: %d\n", ret);
+			return ret;
+		}
+	}
+
+	if (cgpio->rst)
+		reset_control_reset(cgpio->rst);
+
+	cdns_gpio_restore_regs(cgpio);
+
+	return 0;
+}
+
+static void cdns_gpio_shutdown(struct platform_device *pdev)
+{
+	struct cdns_gpio_chip *cgpio = platform_get_drvdata(pdev);
+
+	/* Mask non-wake interrupts */
+	iowrite32(~cgpio->wake_active, cgpio->regs + CDNS_GPIO_IRQ_DIS);
+
+	cdns_gpio_sky1_set_wake(cgpio, true);
+
+	if (cgpio->pclk)
+		clk_disable_unprepare(cgpio->pclk);
+}
+#else
+static void cdns_gpio_shutdown(struct platform_device *pdev) {}
+#endif
+
+static const struct dev_pm_ops cdns_gpio_pm_ops = {
+	LATE_SYSTEM_SLEEP_PM_OPS(cdns_gpio_suspend, cdns_gpio_resume)
+};
+
 static int cdns_gpio_probe(struct platform_device *pdev)
 {
 	struct gpio_generic_chip_config config = { };
@@ -148,7 +289,7 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	int ret, irq;
 	u32 dir_prev;
 	u32 num_gpios = 32;
-	struct clk *clk;
+	u32 io_mask = 0;
 
 	cgpio = devm_kzalloc(&pdev->dev, sizeof(*cgpio), GFP_KERNEL);
 	if (!cgpio)
@@ -158,22 +299,30 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	if (IS_ERR(cgpio->regs))
 		return PTR_ERR(cgpio->regs);
 
-	of_property_read_u32(pdev->dev.of_node, "ngpios", &num_gpios);
+	/* Use device_property for DT/ACPI compatibility */
+	device_property_read_u32(&pdev->dev, "ngpios", &num_gpios);
 
 	if (num_gpios > 32) {
 		dev_err(&pdev->dev, "ngpios must be less or equal 32\n");
 		return -EINVAL;
 	}
 
+	/* Optional mask of pins that should remain inputs (hardware safety) */
+	device_property_read_u32(&pdev->dev, "gpio-io-mask", &io_mask);
+
+	/* Detect Sky1 platform for PDC wake integration */
+	cgpio->has_sky1_pdc = !!device_get_match_data(&pdev->dev);
+
 	/*
 	 * Set all pins as inputs by default, otherwise:
 	 * gpiochip_lock_as_irq:
 	 * tried to flag a GPIO set as output for IRQ
 	 * Generic GPIO driver stores the direction value internally,
 	 * so it needs to be changed before gpio_generic_chip_init() is called.
+	 * Apply io_mask to force certain pins as inputs (hardware safety).
 	 */
 	dir_prev = ioread32(cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
-	iowrite32(GENMASK(num_gpios - 1, 0),
+	iowrite32(GENMASK(num_gpios - 1, 0) & ~io_mask,
 		  cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
 
 	config.dev = &pdev->dev;
@@ -198,21 +347,37 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 	cgpio->gen_gc.gc.request = cdns_gpio_request;
 	cgpio->gen_gc.gc.free = cdns_gpio_free;
 
-	clk = devm_clk_get_enabled(&pdev->dev, NULL);
-	if (IS_ERR(clk)) {
-		ret = PTR_ERR(clk);
-		dev_err(&pdev->dev,
-			"Failed to retrieve peripheral clock, %d\n", ret);
+	/* Clock - use optional for manual PM control */
+	cgpio->pclk = devm_clk_get_optional(&pdev->dev, NULL);
+	if (IS_ERR(cgpio->pclk)) {
+		ret = PTR_ERR(cgpio->pclk);
+		dev_err(&pdev->dev, "Failed to get clock: %d\n", ret);
 		goto err_revert_dir;
 	}
 
-	/*
-	 * Optional irq_chip support
-	 */
-	irq = platform_get_irq(pdev, 0);
-	if (irq >= 0) {
+	if (cgpio->pclk) {
+		ret = clk_prepare_enable(cgpio->pclk);
+		if (ret) {
+			dev_err(&pdev->dev, "Failed to enable clock: %d\n", ret);
+			goto err_revert_dir;
+		}
+	}
+
+	/* Optional reset control */
+	cgpio->rst = devm_reset_control_get_optional_shared(&pdev->dev, NULL);
+	if (IS_ERR(cgpio->rst)) {
+		ret = PTR_ERR(cgpio->rst);
+		dev_err(&pdev->dev, "Failed to get reset: %d\n", ret);
+		goto err_disable_clk;
+	}
+
+	/* Optional irq_chip support */
+	irq = platform_get_irq_optional(pdev, 0);
+	if (irq > 0) {
 		struct gpio_irq_chip *girq;
 
+		cgpio->hw_irq = irq;
+
 		girq = &cgpio->gen_gc.gc.irq;
 		gpio_irq_chip_set_chip(girq, &cdns_gpio_irqchip);
 		girq->parent_handler = cdns_gpio_irq_handler;
@@ -222,31 +387,35 @@ static int cdns_gpio_probe(struct platform_device *pdev)
 					     GFP_KERNEL);
 		if (!girq->parents) {
 			ret = -ENOMEM;
-			goto err_revert_dir;
+			goto err_disable_clk;
 		}
 		girq->parents[0] = irq;
 		girq->default_type = IRQ_TYPE_NONE;
-		girq->handler = handle_level_irq;
+		girq->handler = handle_bad_irq;
 	}
 
 	ret = devm_gpiochip_add_data(&pdev->dev, &cgpio->gen_gc.gc, cgpio);
 	if (ret < 0) {
 		dev_err(&pdev->dev, "Could not register gpiochip, %d\n", ret);
-		goto err_revert_dir;
+		goto err_disable_clk;
 	}
 
 	cgpio->bypass_orig = ioread32(cgpio->regs + CDNS_GPIO_BYPASS_MODE);
 
-	/*
-	 * Enable gpio outputs, ignored for input direction
-	 */
+	/* Enable gpio outputs, ignored for input direction */
 	iowrite32(GENMASK(num_gpios - 1, 0),
 		  cgpio->regs + CDNS_GPIO_OUTPUT_EN);
 	iowrite32(0, cgpio->regs + CDNS_GPIO_BYPASS_MODE);
 
+	/* Disable all IRQs initially */
+	iowrite32(GENMASK(num_gpios - 1, 0), cgpio->regs + CDNS_GPIO_IRQ_DIS);
+
 	platform_set_drvdata(pdev, cgpio);
 	return 0;
 
+err_disable_clk:
+	if (cgpio->pclk)
+		clk_disable_unprepare(cgpio->pclk);
 err_revert_dir:
 	iowrite32(dir_prev, cgpio->regs + CDNS_GPIO_DIRECTION_MODE);
 
@@ -258,21 +427,37 @@ static void cdns_gpio_remove(struct platform_device *pdev)
 	struct cdns_gpio_chip *cgpio = platform_get_drvdata(pdev);
 
 	iowrite32(cgpio->bypass_orig, cgpio->regs + CDNS_GPIO_BYPASS_MODE);
+
+	if (cgpio->pclk)
+		clk_disable_unprepare(cgpio->pclk);
 }
 
 static const struct of_device_id cdns_of_ids[] = {
 	{ .compatible = "cdns,gpio-r1p02" },
+	{ .compatible = "cix,sky1-gpio", .data = (void *)1 },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, cdns_of_ids);
 
+#ifdef CONFIG_ACPI
+static const struct acpi_device_id cdns_acpi_ids[] = {
+	{ "CIXH1002", 1 },
+	{ "CIXH1003", 1 },
+	{ /* sentinel */ },
+};
+MODULE_DEVICE_TABLE(acpi, cdns_acpi_ids);
+#endif
+
 static struct platform_driver cdns_gpio_driver = {
 	.driver = {
 		.name = "cdns-gpio",
 		.of_match_table = cdns_of_ids,
+		.acpi_match_table = ACPI_PTR(cdns_acpi_ids),
+		.pm = pm_ptr(&cdns_gpio_pm_ops),
 	},
 	.probe = cdns_gpio_probe,
 	.remove = cdns_gpio_remove,
+	.shutdown = cdns_gpio_shutdown,
 };
 module_platform_driver(cdns_gpio_driver);
 
