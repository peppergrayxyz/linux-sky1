From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 5 Feb 2026 23:07:36 +1100
Subject: [PATCH] iommu/arm-smmu-v3: Add PCIe ATS override option for Sky1

Sky1's PCIe controller has a DTI (Distributed Translation Interface)
ATS Master that can send translated TLP messages to the SMMU even when
endpoint devices don't support ATS. This causes F_TRANSL_FORBIDDEN
errors because the SMMU rejects unexpected translated traffic.

Add ARM_SMMU_OPT_PCIE_ATS_OVERRIDE option that enables EATS (Enhanced
ATS) for all PCIe devices, allowing the SMMU to accept translated
transactions regardless of endpoint ATS capability.

The option is enabled via "cix,pcie-ats-override" DT property on the
SMMU node. Enable it for smmu_pciehub on Sky1 platforms.
---
 arch/arm64/boot/dts/cix/sky1.dtsi           |  7 +++++++
 drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.c | 11 +++++++++--
 drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.h |  1 +
 3 files changed, 17 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 76b9e659e480e..3c184d900be95 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -676,6 +676,13 @@ smmu_pciehub: iommu@b010000 {
 		arm,boot-active-sids = <0x0000 0x0100 0x3000 0x3100
 					0x6000 0x6100 0x9000 0x9100
 					0xc000 0xc100>;
+		/*
+		 * Sky1 PCIe controller's DTI ATS Master can send translated
+		 * TLP messages even when endpoint devices don't support ATS.
+		 * Enable EATS (Enhanced ATS) for all PCIe devices to accept
+		 * these translated transactions instead of generating errors.
+		 */
+		cix,pcie-ats-override;
 		status = "disabled";
 	};
 
diff --git a/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.c b/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.c
index f278e4ce82c29..42a97ddfab42a 100644
--- a/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.c
+++ b/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.c
@@ -81,6 +81,7 @@ DEFINE_MUTEX(arm_smmu_asid_lock);
 static struct arm_smmu_option_prop arm_smmu_options[] = {
 	{ ARM_SMMU_OPT_SKIP_PREFETCH, "hisilicon,broken-prefetch-cmd" },
 	{ ARM_SMMU_OPT_PAGE0_REGS_ONLY, "cavium,cn9900-broken-page1-regspace"},
+	{ ARM_SMMU_OPT_PCIE_ATS_OVERRIDE, "cix,pcie-ats-override" },
 	{ 0, NULL},
 };
 
@@ -1624,7 +1625,10 @@ void arm_smmu_make_cdtable_ste(struct arm_smmu_ste *target,
 			 STRTAB_STE_1_S1STALLD :
 			 0) |
 		FIELD_PREP(STRTAB_STE_1_EATS,
-			   ats_enabled ? STRTAB_STE_1_EATS_TRANS : 0));
+			   (ats_enabled ||
+			    ((smmu->options & ARM_SMMU_OPT_PCIE_ATS_OVERRIDE) &&
+			     dev_is_pci(master->dev))) ?
+				STRTAB_STE_1_EATS_TRANS : 0));
 
 	if ((smmu->features & ARM_SMMU_FEAT_ATTR_TYPES_OVR) &&
 	    s1dss == STRTAB_STE_1_S1DSS_BYPASS)
@@ -1676,7 +1680,10 @@ void arm_smmu_make_s2_domain_ste(struct arm_smmu_ste *target,
 
 	target->data[1] = cpu_to_le64(
 		FIELD_PREP(STRTAB_STE_1_EATS,
-			   ats_enabled ? STRTAB_STE_1_EATS_TRANS : 0));
+			   (ats_enabled ||
+			    ((smmu->options & ARM_SMMU_OPT_PCIE_ATS_OVERRIDE) &&
+			     dev_is_pci(master->dev))) ?
+				STRTAB_STE_1_EATS_TRANS : 0));
 
 	if (pgtbl_cfg->quirks & IO_PGTABLE_QUIRK_ARM_S2FWB)
 		target->data[1] |= cpu_to_le64(STRTAB_STE_1_S2FWB);
diff --git a/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.h b/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.h
index 9c9b9dd8fcce2..0ba303a065ae6 100644
--- a/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.h
+++ b/drivers/iommu/arm/arm-smmu-v3/arm-smmu-v3.h
@@ -777,6 +777,7 @@ struct arm_smmu_device {
 #define ARM_SMMU_OPT_MSIPOLL		(1 << 2)
 #define ARM_SMMU_OPT_CMDQ_FORCE_SYNC	(1 << 3)
 #define ARM_SMMU_OPT_TEGRA241_CMDQV	(1 << 4)
+#define ARM_SMMU_OPT_PCIE_ATS_OVERRIDE	(1 << 5)
 	u32				options;
 
 	struct arm_smmu_cmdq		cmdq;
