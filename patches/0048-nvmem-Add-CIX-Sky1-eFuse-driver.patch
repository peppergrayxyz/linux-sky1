From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Wed, 10 Dec 2025 14:34:26 +0800
Subject: [PATCH] nvmem: Add CIX Sky1 eFuse driver

Add NVMEM driver for CIX Sky1 SoC eFuse access. The driver reads
one-time programmable fuse data via ARM SMCCC firmware calls to the
secure monitor (ATF).

The efuse contains chip identification data including:
- OPN (Ordering Part Number) at offset 0x4dc
- NPU harvesting information

Ported from vendor kernel with mainline coding style improvements:
- Use devm_nvmem_register() for cleanup
- Proper ARM_SMCCC_CALL_VAL() macro usage
- Standard nvmem_config initialization
---
 drivers/nvmem/Kconfig      | 11 +++++
 drivers/nvmem/Makefile     |  2 +
 drivers/nvmem/sky1-nvmem.c | 93 ++++++++++++++++++++++++++++++++++++++
 3 files changed, 106 insertions(+)
 create mode 100644 drivers/nvmem/sky1-nvmem.c

diff --git a/drivers/nvmem/Kconfig b/drivers/nvmem/Kconfig
index e0d88d3199c11..4c82593bff2f0 100644
--- a/drivers/nvmem/Kconfig
+++ b/drivers/nvmem/Kconfig
@@ -364,6 +364,17 @@ config NVMEM_SPMI_SDAM
 	  Qualcomm Technologies, Inc. PMICs. It provides the clients
 	  an interface to read/write to the SDAM module's shared memory.
 
+config NVMEM_SKY1
+	tristate "CIX Sky1 eFuse support"
+	depends on ARCH_CIX || COMPILE_TEST
+	depends on HAVE_ARM_SMCCC
+	help
+	  This driver provides read support for the eFuse on CIX Sky1 SoCs.
+	  The efuse data is accessed via ARM SMCCC firmware calls.
+
+	  This driver can also be built as a module. If so, the module
+	  will be called nvmem-sky1.
+
 config NVMEM_SPRD_EFUSE
 	tristate "Spreadtrum SoC eFuse Support"
 	depends on ARCH_SPRD || COMPILE_TEST
diff --git a/drivers/nvmem/Makefile b/drivers/nvmem/Makefile
index 70a4464dcb1e2..4764d860f663a 100644
--- a/drivers/nvmem/Makefile
+++ b/drivers/nvmem/Makefile
@@ -72,6 +72,8 @@ obj-$(CONFIG_NVMEM_SNVS_LPGPR)		+= nvmem_snvs_lpgpr.o
 nvmem_snvs_lpgpr-y			:= snvs_lpgpr.o
 obj-$(CONFIG_NVMEM_SPMI_SDAM)		+= nvmem_qcom-spmi-sdam.o
 nvmem_qcom-spmi-sdam-y			+= qcom-spmi-sdam.o
+obj-$(CONFIG_NVMEM_SKY1)		+= nvmem-sky1.o
+nvmem-sky1-y				:= sky1-nvmem.o
 obj-$(CONFIG_NVMEM_SPRD_EFUSE)		+= nvmem_sprd_efuse.o
 nvmem_sprd_efuse-y			:= sprd-efuse.o
 obj-$(CONFIG_NVMEM_STM32_ROMEM)		+= nvmem_stm32_romem.o
diff --git a/drivers/nvmem/sky1-nvmem.c b/drivers/nvmem/sky1-nvmem.c
new file mode 100644
index 0000000000000..aaf55aa4db236
--- /dev/null
+++ b/drivers/nvmem/sky1-nvmem.c
@@ -0,0 +1,93 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Sky1 NVMEM (eFuse) driver
+ *
+ * Copyright 2024 Cix Technology Group Co., Ltd.
+ *
+ * Reads efuse data via ARM SMCCC firmware interface.
+ */
+
+#include <linux/arm-smccc.h>
+#include <linux/module.h>
+#include <linux/nvmem-provider.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+
+/* SMC function ID for fuse read request */
+#define SKY1_SIP_FUSE_READ	\
+	ARM_SMCCC_CALL_VAL(ARM_SMCCC_FAST_CALL, ARM_SMCCC_SMC_32, \
+			   62, 9)
+
+struct sky1_nvmem {
+	struct device *dev;
+};
+
+static int sky1_nvmem_read(void *context, unsigned int offset,
+			   void *val, size_t bytes)
+{
+	struct sky1_nvmem *priv = context;
+	struct arm_smccc_res res;
+	u8 *buf = val;
+	size_t i;
+
+	for (i = 0; i < bytes; i++) {
+		arm_smccc_smc(SKY1_SIP_FUSE_READ, offset + i, 1,
+			      0, 0, 0, 0, 0, &res);
+		if (res.a0 == 0) {
+			dev_err(priv->dev, "Failed to read fuse at offset %u\n",
+				offset + (unsigned int)i);
+			return -EIO;
+		}
+		buf[i] = res.a1 & 0xff;
+	}
+
+	return 0;
+}
+
+static int sky1_nvmem_probe(struct platform_device *pdev)
+{
+	struct nvmem_config config = {
+		.name = "sky1-efuse",
+		.dev = &pdev->dev,
+		.owner = THIS_MODULE,
+		.word_size = 1,
+		.size = 0x500,  /* Total efuse size - OPN at 0x4dc needs 0x4e4 */
+		.read_only = true,
+		.reg_read = sky1_nvmem_read,
+		.add_legacy_fixed_of_cells = true,
+	};
+	struct sky1_nvmem *priv;
+	struct nvmem_device *nvmem;
+
+	priv = devm_kzalloc(&pdev->dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	priv->dev = &pdev->dev;
+	config.priv = priv;
+
+	nvmem = devm_nvmem_register(&pdev->dev, &config);
+	if (IS_ERR(nvmem))
+		return PTR_ERR(nvmem);
+
+	return 0;
+}
+
+static const struct of_device_id sky1_nvmem_of_match[] = {
+	{ .compatible = "cix,sky1-nvmem-fw" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, sky1_nvmem_of_match);
+
+static struct platform_driver sky1_nvmem_driver = {
+	.probe = sky1_nvmem_probe,
+	.driver = {
+		.name = "sky1-nvmem",
+		.of_match_table = sky1_nvmem_of_match,
+	},
+};
+module_platform_driver(sky1_nvmem_driver);
+
+MODULE_AUTHOR("Cix Technology Group Co., Ltd.");
+MODULE_DESCRIPTION("Sky1 NVMEM (eFuse) driver");
+MODULE_LICENSE("GPL");
