From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 30 Jan 2026 14:20:16 +1100
Subject: [PATCH] misc: armchina-npu: Fix iommu_dma_cookie struct layout for
 kernel 6.18

The driver's private copy of struct iommu_dma_cookie had iovad inside a
union at offset 8 (after an enum field), but the kernel's actual layout
in drivers/iommu/dma-iommu.c places iovad directly at offset 0 with no
enum prefix. This mismatch caused the driver to compute a wrong pointer
to the iova_domain, resulting in a kernel panic in reserve_iova() during
NPU probe (level 3 translation fault on a spinlock at an invalid address).

Fix by removing the stale enum and union wrapper so iovad sits at offset 0,
matching the kernel's actual struct layout.
---
 drivers/misc/armchina-npu/aipu_mm.c | 21 +++++++++------------
 1 file changed, 9 insertions(+), 12 deletions(-)

diff --git a/drivers/misc/armchina-npu/aipu_mm.c b/drivers/misc/armchina-npu/aipu_mm.c
index e300215680795..acd18f1e60c7c 100755
--- a/drivers/misc/armchina-npu/aipu_mm.c
+++ b/drivers/misc/armchina-npu/aipu_mm.c
@@ -29,19 +29,16 @@
 #define IOVA_FREE  false
 #define IOVA_ALLOC true
 
-enum iommu_dma_cookie_type {
-	IOMMU_DMA_IOVA_COOKIE,
-	IOMMU_DMA_MSI_COOKIE,
-};
-
+/*
+ * Partial redefinition of the kernel-private struct iommu_dma_cookie
+ * (defined in drivers/iommu/dma-iommu.c). Only the iovad field is accessed
+ * by this driver; it must be at offset 0 to match the kernel's layout.
+ *
+ * WARNING: This is fragile — if the kernel reorders iommu_dma_cookie fields,
+ * this will break. A proper fix would avoid accessing IOMMU internals entirely.
+ */
 struct iommu_dma_cookie {
-	enum iommu_dma_cookie_type	type;
-	union {
-		struct iova_domain	iovad;
-		dma_addr_t		msi_iova;
-	};
-	struct list_head		msi_page_list;
-	struct iommu_domain		*fq_domain;
+	struct iova_domain	iovad;
 };
 
 static struct aipu_mem_region *aipu_mm_find_region_no_lock(struct aipu_memory_manager *mm,
