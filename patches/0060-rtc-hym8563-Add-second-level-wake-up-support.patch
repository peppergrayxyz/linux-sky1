From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 6 Feb 2026 00:14:10 +1100
Subject: [PATCH] rtc: hym8563: Add second-level wake-up support

The HYM8563 RTC has two wake mechanisms:
- Alarm Function (AF): minute-level precision, for delays >= 256s
- Timer Function (TF): second-level precision, for delays < 256s

Previously only the alarm function was used, limiting wake precision
to one minute. This adds support for the timer function to enable
second-level precision wake-up for short delays.

For alarms less than 256 seconds in the future, use the timer counter
with a 1Hz clock source. For longer delays, continue using the
traditional alarm registers with minute precision.

A minimum delay of 3 seconds is enforced to avoid races with system
sleep entry.
---
 drivers/rtc/rtc-hym8563.c | 139 ++++++++++++++++++++++++++++----------
 1 file changed, 105 insertions(+), 34 deletions(-)

diff --git a/drivers/rtc/rtc-hym8563.c b/drivers/rtc/rtc-hym8563.c
index 7a170c0f97109..dfb01448c67ed 100644
--- a/drivers/rtc/rtc-hym8563.c
+++ b/drivers/rtc/rtc-hym8563.c
@@ -162,19 +162,28 @@ static int hym8563_rtc_alarm_irq_enable(struct device *dev,
 					unsigned int enabled)
 {
 	struct i2c_client *client = to_i2c_client(dev);
-	int data;
+	int data, tmr_ctl;
 
 	data = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
 	if (data < 0)
 		return data;
 
-	if (enabled)
-		data |= HYM8563_CTL2_AIE;
-	else
-		data &= ~HYM8563_CTL2_AIE;
+	if (enabled) {
+		/* Check if timer is active - use TIE, otherwise AIE */
+		tmr_ctl = i2c_smbus_read_byte_data(client, HYM8563_TMR_CTL);
+		if (tmr_ctl >= 0 && (tmr_ctl & HYM8563_TMR_CTL_ENABLE)) {
+			data |= HYM8563_CTL2_TIE;
+			data &= ~HYM8563_CTL2_AIE;
+		} else {
+			data |= HYM8563_CTL2_AIE;
+			data &= ~HYM8563_CTL2_TIE;
+		}
+	} else {
+		data &= ~(HYM8563_CTL2_AIE | HYM8563_CTL2_TIE);
+	}
 
 	return i2c_smbus_write_byte_data(client, HYM8563_CTL2, data);
-};
+}
 
 static int hym8563_rtc_read_alarm(struct device *dev, struct rtc_wkalrm *alm)
 {
@@ -207,46 +216,104 @@ static int hym8563_rtc_read_alarm(struct device *dev, struct rtc_wkalrm *alm)
 	if (ret < 0)
 		return ret;
 
-	if (ret & HYM8563_CTL2_AIE)
-		alm->enabled = 1;
+	alm->enabled = !!(ret & (HYM8563_CTL2_AIE | HYM8563_CTL2_TIE));
 
 	return 0;
 }
 
+/*
+ * For short delays (< 256 seconds), use the timer function which provides
+ * second-level precision. For longer delays, use the traditional alarm
+ * function which has minute-level precision.
+ */
 static int hym8563_rtc_set_alarm(struct device *dev, struct rtc_wkalrm *alm)
 {
 	struct i2c_client *client = to_i2c_client(dev);
 	struct rtc_time *alm_tm = &alm->time;
+	struct rtc_time now_tm;
+	time64_t now_secs, alm_secs, diff_secs;
 	u8 buf[4];
 	int ret;
 
-	ret = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
+	ret = hym8563_rtc_read_time(dev, &now_tm);
 	if (ret < 0)
 		return ret;
 
-	ret &= ~HYM8563_CTL2_AIE;
+	now_secs = rtc_tm_to_time64(&now_tm);
+	alm_secs = rtc_tm_to_time64(alm_tm);
+	diff_secs = alm_secs - now_secs;
 
+	if (diff_secs <= 0)
+		return -EINVAL;
+
+	/* Minimum 3 seconds to avoid race with sleep entry */
+	if (diff_secs < 3)
+		diff_secs = 3;
+
+	/* Disable all alarm/timer interrupts first */
+	ret = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
+	if (ret < 0)
+		return ret;
+
+	ret &= ~(HYM8563_CTL2_AIE | HYM8563_CTL2_TIE);
 	ret = i2c_smbus_write_byte_data(client, HYM8563_CTL2, ret);
 	if (ret < 0)
 		return ret;
 
-	buf[0] = (alm_tm->tm_min < 60 && alm_tm->tm_min >= 0) ?
-			bin2bcd(alm_tm->tm_min) : HYM8563_ALM_BIT_DISABLE;
+	if (diff_secs < 256) {
+		/* Use timer function for second-level precision */
+		ret = i2c_smbus_write_byte_data(client, HYM8563_TMR_CTL, 0);
+		if (ret < 0)
+			return ret;
 
-	buf[1] = (alm_tm->tm_hour < 24 && alm_tm->tm_hour >= 0) ?
-			bin2bcd(alm_tm->tm_hour) : HYM8563_ALM_BIT_DISABLE;
+		ret = i2c_smbus_write_byte_data(client, HYM8563_TMR_CNT,
+						(u8)diff_secs);
+		if (ret < 0)
+			return ret;
 
-	buf[2] = (alm_tm->tm_mday <= 31 && alm_tm->tm_mday >= 1) ?
-			bin2bcd(alm_tm->tm_mday) : HYM8563_ALM_BIT_DISABLE;
+		/* Enable timer with 1Hz clock source */
+		ret = i2c_smbus_write_byte_data(client, HYM8563_TMR_CTL,
+						HYM8563_TMR_CTL_ENABLE |
+						HYM8563_TMR_CTL_1);
+		if (ret < 0)
+			return ret;
 
-	buf[3] = (alm_tm->tm_wday < 7 && alm_tm->tm_wday >= 0) ?
-			bin2bcd(alm_tm->tm_wday) : HYM8563_ALM_BIT_DISABLE;
+		if (alm->enabled) {
+			ret = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
+			if (ret < 0)
+				return ret;
 
-	ret = i2c_smbus_write_i2c_block_data(client, HYM8563_ALM_MIN, 4, buf);
-	if (ret < 0)
-		return ret;
+			ret |= HYM8563_CTL2_TIE;
+			return i2c_smbus_write_byte_data(client,
+							 HYM8563_CTL2, ret);
+		}
+	} else {
+		/* Use alarm function for longer delays */
+		buf[0] = (alm_tm->tm_min < 60 && alm_tm->tm_min >= 0) ?
+				bin2bcd(alm_tm->tm_min) : HYM8563_ALM_BIT_DISABLE;
+		buf[1] = (alm_tm->tm_hour < 24 && alm_tm->tm_hour >= 0) ?
+				bin2bcd(alm_tm->tm_hour) : HYM8563_ALM_BIT_DISABLE;
+		buf[2] = (alm_tm->tm_mday <= 31 && alm_tm->tm_mday >= 1) ?
+				bin2bcd(alm_tm->tm_mday) : HYM8563_ALM_BIT_DISABLE;
+		buf[3] = HYM8563_ALM_BIT_DISABLE; /* weekday not used */
+
+		ret = i2c_smbus_write_i2c_block_data(client, HYM8563_ALM_MIN,
+						     4, buf);
+		if (ret < 0)
+			return ret;
+
+		if (alm->enabled) {
+			ret = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
+			if (ret < 0)
+				return ret;
 
-	return hym8563_rtc_alarm_irq_enable(dev, alm->enabled);
+			ret |= HYM8563_CTL2_AIE;
+			return i2c_smbus_write_byte_data(client,
+							 HYM8563_CTL2, ret);
+		}
+	}
+
+	return 0;
 }
 
 static const struct rtc_class_ops hym8563_rtc_ops = {
@@ -406,10 +473,8 @@ static struct clk *hym8563_clkout_register_clk(struct hym8563 *hym8563)
 #endif
 
 /*
- * The alarm interrupt is implemented as a level-low interrupt in the
- * hym8563, while the timer interrupt uses a falling edge.
- * We don't use the timer at all, so the interrupt is requested to
- * use the level-low trigger.
+ * Handle both alarm and timer interrupts. The timer interrupt is used
+ * for second-level precision wake-up (delays < 256 seconds).
  */
 static irqreturn_t hym8563_irq(int irq, void *dev_id)
 {
@@ -419,22 +484,29 @@ static irqreturn_t hym8563_irq(int irq, void *dev_id)
 
 	rtc_lock(hym8563->rtc);
 
-	/* Clear the alarm flag */
-
 	data = i2c_smbus_read_byte_data(client, HYM8563_CTL2);
 	if (data < 0) {
-		dev_err(&client->dev, "%s: error reading i2c data %d\n",
+		dev_err(&client->dev, "%s: error reading CTL2: %d\n",
 			__func__, data);
 		goto out;
 	}
 
-	data &= ~HYM8563_CTL2_AF;
+	/* Handle timer interrupt - disable timer after firing */
+	if (data & HYM8563_CTL2_TF) {
+		ret = i2c_smbus_write_byte_data(client, HYM8563_TMR_CTL, 0);
+		if (ret < 0)
+			dev_err(&client->dev, "failed to disable timer\n");
+		data &= ~HYM8563_CTL2_TF;
+	}
+
+	/* Handle alarm interrupt */
+	if (data & HYM8563_CTL2_AF)
+		data &= ~HYM8563_CTL2_AF;
 
 	ret = i2c_smbus_write_byte_data(client, HYM8563_CTL2, data);
-	if (ret < 0) {
-		dev_err(&client->dev, "%s: error writing i2c data %d\n",
+	if (ret < 0)
+		dev_err(&client->dev, "%s: error writing CTL2: %d\n",
 			__func__, ret);
-	}
 
 out:
 	rtc_unlock(hym8563->rtc);
@@ -553,7 +625,6 @@ static int hym8563_probe(struct i2c_client *client)
 		(ret & HYM8563_SEC_VL) ? "invalid" : "valid");
 
 	hym8563->rtc->ops = &hym8563_rtc_ops;
-	set_bit(RTC_FEATURE_ALARM_RES_MINUTE, hym8563->rtc->features);
 	clear_bit(RTC_FEATURE_UPDATE_INTERRUPT, hym8563->rtc->features);
 
 #ifdef CONFIG_COMMON_CLK
