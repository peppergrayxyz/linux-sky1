 arch/arm64/boot/dts/cix/Makefile              |    1 +
 .../boot/dts/cix/sky1-orangepi-6-plus.dts     | 2270 +++++++++++++++++
 arch/arm64/boot/dts/cix/sky1.dtsi             |    1 +
 3 files changed, 2272 insertions(+)
 create mode 100644 arch/arm64/boot/dts/cix/sky1-orangepi-6-plus.dts

