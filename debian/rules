#!/usr/bin/make -f

export DH_VERBOSE = 1
export ARCH = arm64
export CROSS_COMPILE =

KERNEL_VERSION = 6.18.0
LOCALVERSION = -sky1
FULL_VERSION = $(KERNEL_VERSION)$(LOCALVERSION)

# Source directory
KSRC = $(CURDIR)/linux-$(KERNEL_VERSION)

%:
	dh $@

override_dh_auto_configure:
	# Extract kernel source
	tar xf linux-$(KERNEL_VERSION).tar.xz
	# Apply patches
	cd $(KSRC) && \
	for p in $(CURDIR)/debian/patches/*.patch; do \
		patch -p1 < "$$p"; \
	done
	# Copy config
	cp debian/config/arm64/config $(KSRC)/.config
	# Set localversion
	echo "$(LOCALVERSION)" > $(KSRC)/localversion

override_dh_auto_build:
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) olddefconfig
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) -j$$(nproc) Image modules dtbs

override_dh_auto_install:
	# Install modules
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) \
		INSTALL_MOD_PATH=$(CURDIR)/debian/linux-image-$(FULL_VERSION) \
		modules_install
	# Install kernel image
	install -D -m 644 $(KSRC)/arch/arm64/boot/Image \
		$(CURDIR)/debian/linux-image-$(FULL_VERSION)/boot/vmlinuz-$(FULL_VERSION)
	# Install System.map
	install -D -m 644 $(KSRC)/System.map \
		$(CURDIR)/debian/linux-image-$(FULL_VERSION)/boot/System.map-$(FULL_VERSION)
	# Install config
	install -D -m 644 $(KSRC)/.config \
		$(CURDIR)/debian/linux-image-$(FULL_VERSION)/boot/config-$(FULL_VERSION)
	# Install DTBs
	install -D -m 644 $(KSRC)/arch/arm64/boot/dts/cix/sky1-orion-o6.dtb \
		$(CURDIR)/debian/linux-dtbs-$(FULL_VERSION)/boot/dtbs/$(FULL_VERSION)/cix/sky1-orion-o6.dtb
	# Install headers
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) \
		INSTALL_HDR_PATH=$(CURDIR)/debian/linux-headers-$(FULL_VERSION)/usr \
		headers_install

override_dh_auto_clean:
	rm -rf $(KSRC)

override_dh_strip:
	# Skip stripping kernel modules
	@true
