#!/usr/bin/make -f

export DH_VERBOSE = 1
export ARCH = arm64
export CROSS_COMPILE =

KERNEL_VERSION = 6.18.2
LOCALVERSION = -sky1
FULL_VERSION = $(KERNEL_VERSION)$(LOCALVERSION)
# Package names use major.minor only
PKG_VERSION = 6.18-sky1

# Source directory
KSRC = $(CURDIR)/linux-$(KERNEL_VERSION)

%:
	dh $@

override_dh_auto_configure:
	# Extract kernel source
	tar xf linux-$(KERNEL_VERSION).tar.xz
	# Apply patches
	cd $(KSRC) && \
	for p in $(CURDIR)/debian/patches/*.patch; do \
		patch -p1 < "$$p"; \
	done
	# Copy config
	cp debian/config/arm64/config $(KSRC)/.config
	# Set localversion
	echo "$(LOCALVERSION)" > $(KSRC)/localversion

override_dh_auto_build:
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) olddefconfig
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) -j$$(nproc) Image modules dtbs

override_dh_auto_install:
	# Install modules
	$(MAKE) -C $(KSRC) ARCH=$(ARCH) \
		INSTALL_MOD_PATH=$(CURDIR)/debian/linux-image-$(PKG_VERSION) \
		modules_install
	# Remove build/source symlinks - these are provided by linux-headers
	rm -f $(CURDIR)/debian/linux-image-$(PKG_VERSION)/lib/modules/$(FULL_VERSION)/build
	rm -f $(CURDIR)/debian/linux-image-$(PKG_VERSION)/lib/modules/$(FULL_VERSION)/source
	# Install kernel image
	install -D -m 644 $(KSRC)/arch/arm64/boot/Image \
		$(CURDIR)/debian/linux-image-$(PKG_VERSION)/boot/vmlinuz-$(FULL_VERSION)
	# Install System.map
	install -D -m 644 $(KSRC)/System.map \
		$(CURDIR)/debian/linux-image-$(PKG_VERSION)/boot/System.map-$(FULL_VERSION)
	# Install config
	install -D -m 644 $(KSRC)/.config \
		$(CURDIR)/debian/linux-image-$(PKG_VERSION)/boot/config-$(FULL_VERSION)
	# Install DTBs
	install -D -m 644 $(KSRC)/arch/arm64/boot/dts/cix/sky1-orion-o6.dtb \
		$(CURDIR)/debian/linux-dtbs-$(PKG_VERSION)/boot/dtbs/$(FULL_VERSION)/cix/sky1-orion-o6.dtb
	# Install kernel headers for building external modules (DKMS)
	# Note: DO NOT use headers_install here - that's for linux-libc-dev (UAPI headers)
	# Instead, install the kernel build headers to /usr/src/
	install -d $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)
	# Copy necessary files for building modules
	cp $(KSRC)/.config $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/
	cp $(KSRC)/Makefile $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/
	cp $(KSRC)/Module.symvers $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/
	cp -a $(KSRC)/include $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/
	install -d $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/arch/arm64
	cp -a $(KSRC)/arch/arm64/include $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/arch/arm64/
	cp -a $(KSRC)/arch/arm64/Makefile $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/arch/arm64/
	cp -a $(KSRC)/scripts $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/
	install -d $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/tools
	cp -a $(KSRC)/tools/objtool $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/usr/src/linux-headers-$(FULL_VERSION)/tools/ 2>/dev/null || true
	# Create symlink in /lib/modules for DKMS
	install -d $(CURDIR)/debian/linux-headers-$(PKG_VERSION)/lib/modules/$(FULL_VERSION)
	ln -sf /usr/src/linux-headers-$(FULL_VERSION) \
		$(CURDIR)/debian/linux-headers-$(PKG_VERSION)/lib/modules/$(FULL_VERSION)/build

override_dh_auto_clean:
	rm -rf $(KSRC)

override_dh_strip:
	# Skip stripping kernel modules
	@true

override_dh_installdeb:
	dh_installdeb
	# Add initramfs hooks to postinst
	@echo '#!/bin/sh' > $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo 'set -e' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo 'KERNEL_VERSION="$(FULL_VERSION)"' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo 'if [ "$$1" = "configure" ]; then' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '    if [ -e /boot/System.map-$$KERNEL_VERSION ]; then' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '        depmod -a -F /boot/System.map-$$KERNEL_VERSION $$KERNEL_VERSION || true' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '    fi' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '    if command -v update-initramfs >/dev/null 2>&1; then' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '        update-initramfs -c -k $$KERNEL_VERSION || true' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo '    fi' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo 'fi' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@echo 'exit 0' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	@chmod 755 $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postinst
	# Add initramfs cleanup to postrm
	@echo '#!/bin/sh' > $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo 'set -e' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo 'KERNEL_VERSION="$(FULL_VERSION)"' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo 'if [ "$$1" = "remove" ] || [ "$$1" = "purge" ]; then' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo '    rm -f /boot/initrd.img-$$KERNEL_VERSION' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo 'fi' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@echo 'exit 0' >> $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
	@chmod 755 $(CURDIR)/debian/linux-image-$(PKG_VERSION)/DEBIAN/postrm
