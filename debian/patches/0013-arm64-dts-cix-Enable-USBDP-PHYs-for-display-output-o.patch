From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sun, 30 Nov 2025 19:54:16 +0800
Subject: [PATCH] arm64: dts: cix: Enable USBDP PHYs for display output on
 Orion O6

Enable the USBDP PHYs needed for display output:

- usbc_phy0: Enable with mode-switch for Type-C DP Alt mode
- usbc_phy1: Enable with default_conf=0x02 (pure DP) for HDMI output

The HDMI output uses the DP TX connected to usbc_phy1, which must be
configured in pure DP mode (not USB/DP combo) since it's a fixed
HDMI connector, not a Type-C port.

Also add build-install.sh helper script.
---
 arch/arm64/boot/dts/cix/sky1-orion-o6.dts |  7 ++-
 scripts/build-install.sh                  | 72 +++++++++++++++++++++++
 2 files changed, 76 insertions(+), 3 deletions(-)
 create mode 100755 scripts/build-install.sh

diff --git a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
index 354e639e34fd..a1eca8415360 100644
--- a/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
+++ b/arch/arm64/boot/dts/cix/sky1-orion-o6.dts
@@ -1359,11 +1359,11 @@ &macb1 {
 	status = "disabled";
 };
 
-/* USB PHYs disabled to bypass boot hang - PCIe/USB shared SerDes conflict */
+/* USBDP PHY - needed for DP TX output */
 &usbc_phy0 {
 	orientation-switch;
 	svid = <0xff01>;
-	status = "disabled";
+	status = "okay";
 	default_conf = /bits/ 8 <0x03>;
 	mode-switch;
 
@@ -1411,7 +1411,8 @@ cdnsp_0_role_switch: endpoint@0 {
 };
 
 &usbc_phy1 {
-	status = "disabled";
+	status = "okay";
+	default_conf = /bits/ 8 <0x02>;  /* UDPHY_MODE_DP - pure DP for HDMI output */
 };
 
 &usb3_phy1 {
diff --git a/scripts/build-install.sh b/scripts/build-install.sh
new file mode 100755
index 000000000000..80f27c3b9a7d
--- /dev/null
+++ b/scripts/build-install.sh
@@ -0,0 +1,72 @@
+#!/bin/bash
+# Build and install mainline kernel for Orion O6
+# Usage: ./scripts/build-install.sh [clean]
+
+set -e
+
+KERNEL_IMAGE="IMAGE-6.18-rc7-mainline-cix"
+DTB_FILE="SKY1-ORION-O6-6.18-rc7-mainline-cix.DTB"
+EFI_DIR="/boot/efi"
+JOBS=$(nproc)
+
+cd "$(dirname "$0")/.."
+
+echo "=== Orion O6 Mainline Kernel Build ==="
+echo "Working directory: $(pwd)"
+echo "Using $JOBS parallel jobs"
+echo
+
+# Clean build if requested
+if [ "$1" = "clean" ]; then
+    echo ">>> Cleaning build..."
+    make clean
+    echo
+fi
+
+# Build kernel, modules, and device trees
+echo ">>> Building kernel, modules, and DTBs..."
+make -j$JOBS Image modules dtbs
+
+echo
+echo ">>> Installing modules..."
+sudo make modules_install
+
+echo
+echo ">>> Copying kernel image to EFI..."
+sudo cp arch/arm64/boot/Image "$EFI_DIR/$KERNEL_IMAGE"
+
+echo ">>> Copying DTB to EFI..."
+sudo cp arch/arm64/boot/dts/cix/sky1-orion-o6.dtb "$EFI_DIR/$DTB_FILE"
+
+echo ">>> Syncing EFI filesystem..."
+sync
+
+# Verify the copy was successful by comparing file sizes
+SRC_SIZE=$(stat -c%s arch/arm64/boot/Image)
+DST_SIZE=$(stat -c%s "$EFI_DIR/$KERNEL_IMAGE")
+if [ "$SRC_SIZE" != "$DST_SIZE" ]; then
+    echo "ERROR: Kernel image size mismatch!"
+    echo "  Source: $SRC_SIZE bytes"
+    echo "  Dest:   $DST_SIZE bytes"
+    exit 1
+fi
+
+SRC_SIZE=$(stat -c%s arch/arm64/boot/dts/cix/sky1-orion-o6.dtb)
+DST_SIZE=$(stat -c%s "$EFI_DIR/$DTB_FILE")
+if [ "$SRC_SIZE" != "$DST_SIZE" ]; then
+    echo "ERROR: DTB file size mismatch!"
+    echo "  Source: $SRC_SIZE bytes"
+    echo "  Dest:   $DST_SIZE bytes"
+    exit 1
+fi
+
+echo
+echo "=== Build Complete ==="
+echo "Kernel:  $EFI_DIR/$KERNEL_IMAGE"
+echo "DTB:     $EFI_DIR/$DTB_FILE"
+echo "Modules: /lib/modules/$(make -s kernelrelease)"
+echo
+ls -la "$EFI_DIR/$KERNEL_IMAGE" "$EFI_DIR/$DTB_FILE"
+echo
+echo "Verified: EFI files match build artifacts."
+echo "Ready to reboot. Use menu entry 3 (dev) for latest build."
