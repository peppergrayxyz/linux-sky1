From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 4 Dec 2025 17:29:57 +0800
Subject: [PATCH] dma: arm-dma350: Fix address translation and add reserved
 memory support

Fix DMA-350 cyclic audio support for Sky1 SoC:

- Add reserved memory support via of_reserved_mem_device_init() so
  DMA buffers are allocated from the audio_alsa reserved region
  (0xd0000000) which is accessible to the DMA-350 controller.

- Fix d350_translate_addr() to properly translate both RAM and
  register addresses. The DMA-350 on Sky1 has a different memory
  view: registers at 0x20000000+, RAM at 0x30000000+.

- Translate peripheral device addresses in d350_prep_dma_cyclic()
  so I2S FIFO addresses are correctly mapped for the DMA controller.

- Add memory-region property to audss_dmac in device tree.

Basic audio playback tested working on HDMI output (hw:0,1).
Interrupt handling still needs work.
---
 arch/arm64/boot/dts/cix/sky1.dtsi |  1 +
 drivers/dma/arm-dma350.c          | 52 ++++++++++++++++++++++++++++---
 2 files changed, 49 insertions(+), 4 deletions(-)

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index 53290d9c4939..b36c100aee06 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -1109,6 +1109,7 @@ audss_dmac: dma-controller@07010000 {
 			arm,remote-ctrl = <&audss_cru>;
 			resets = <&audss_rst AUDSS_DMAC_SW_RST_N>;
 			reset-names = "dma_reset";
+			memory-region = <&audio_alsa>;
 			status = "disabled";
 		};
 
diff --git a/drivers/dma/arm-dma350.c b/drivers/dma/arm-dma350.c
index b17797e256a7..d85cea1952f5 100644
--- a/drivers/dma/arm-dma350.c
+++ b/drivers/dma/arm-dma350.c
@@ -10,6 +10,7 @@
 #include <linux/io.h>
 #include <linux/of.h>
 #include <linux/of_dma.h>
+#include <linux/of_reserved_mem.h>
 #include <linux/module.h>
 #include <linux/platform_device.h>
 #include <linux/pm_runtime.h>
@@ -266,11 +267,17 @@ static inline struct d350 *to_d350(struct dma_device *dma)
 	return container_of(dma, struct d350, dma);
 }
 
-/* Translate CPU address to DMA-350 view for RAM addresses */
+/* Translate CPU address to DMA-350 view */
 static inline dma_addr_t d350_translate_addr(struct d350 *dmac, dma_addr_t addr)
 {
+	/* Translate RAM addresses (e.g., 0xc0000000+ -> 0x30000000+) */
 	if (dmac->addr_xlat.ram_cpu && addr >= dmac->addr_xlat.ram_cpu)
 		return addr - dmac->addr_xlat.ram_cpu + dmac->addr_xlat.ram_dma;
+
+	/* Translate register/peripheral addresses using base offset */
+	if (dmac->addr_xlat.reg_cpu && dmac->addr_xlat.reg_dma)
+		return addr - dmac->addr_xlat.reg_cpu + dmac->addr_xlat.reg_dma;
+
 	return addr;
 }
 
@@ -511,8 +518,11 @@ static enum dma_status d350_tx_status(struct dma_chan *chan, dma_cookie_t cookie
 static void d350_start_cyclic(struct d350_chan *dch)
 {
 	struct d350 *dmac = to_d350(dch->vc.chan.device);
+	struct device *dev = dch->vc.chan.device->dev;
 	dma_addr_t cmdlink_dma;
 
+	dev_info(dev, "=== d350_start_cyclic ===\n");
+
 	/*
 	 * For cyclic DMA, we use hardware command linking.
 	 * The DMA controller fetches commands from memory and
@@ -536,12 +546,29 @@ static void d350_start_cyclic(struct d350_chan *dch)
 
 	/* Set up and enable hardware command linking */
 	cmdlink_dma = d350_translate_addr(dmac, dch->desc->cmdlink_phys);
+	dev_info(dev, "cyclic: cmdlink_phys=%pad translated=%pad\n",
+		 &dch->desc->cmdlink_phys, &cmdlink_dma);
+
 	writel_relaxed(lower_32_bits(cmdlink_dma) | CH_LINKADDR_EN,
 		       dch->base + CH_LINKADDR);
 	writel_relaxed(upper_32_bits(cmdlink_dma), dch->base + CH_LINKADDRHI);
 
 	/* Re-enable to start command fetch */
 	writel(CH_CMD_ENABLE, dch->base + CH_CMD);
+
+	dev_info(dev, "cyclic: DMA started, LINKADDR=0x%08x\n",
+		 readl_relaxed(dch->base + CH_LINKADDR));
+
+	/* Debug: check status after a short delay */
+	udelay(100);
+	dev_info(dev, "cyclic: STATUS=0x%08x CTRL=0x%08x INTREN=0x%08x\n",
+		 readl_relaxed(dch->base + CH_STATUS),
+		 readl_relaxed(dch->base + CH_CTRL),
+		 readl_relaxed(dch->base + CH_INTREN));
+	dev_info(dev, "cyclic: SRCADDR=0x%08x DESADDR=0x%08x XSIZE=0x%08x\n",
+		 readl_relaxed(dch->base + CH_SRCADDR),
+		 readl_relaxed(dch->base + CH_DESADDR),
+		 readl_relaxed(dch->base + CH_XSIZE));
 }
 
 static void d350_start_next(struct d350_chan *dch)
@@ -629,6 +656,8 @@ static irqreturn_t d350_irq(int irq, void *data)
 	if (!ch_status)
 		return IRQ_NONE;
 
+	dev_info(dev, "=== d350_irq: status=0x%08x ===\n", ch_status);
+
 	/* Clear interrupt status */
 	writel_relaxed(ch_status, dch->base + CH_STATUS);
 
@@ -805,6 +834,10 @@ static struct dma_async_tx_descriptor *d350_prep_dma_cyclic(
 	u8 transize;
 	size_t i;
 
+	dev_info(dev, "=== d350_prep_dma_cyclic called ===\n");
+	dev_info(dev, "cyclic: buf=%pad len=%zu period=%zu dir=%d req_line=%u\n",
+		 &buf_addr, buf_len, period_len, dir, dch->req_line);
+
 	/* Validate direction */
 	if (dir != DMA_MEM_TO_DEV && dir != DMA_DEV_TO_MEM) {
 		dev_err(dev, "cyclic: invalid direction %d\n", dir);
@@ -825,10 +858,10 @@ static struct dma_async_tx_descriptor *d350_prep_dma_cyclic(
 
 	/* Get device address and transfer size from slave config */
 	if (dir == DMA_MEM_TO_DEV) {
-		dev_addr = dch->slave_cfg.dst_addr;
+		dev_addr = d350_translate_addr(dmac, dch->slave_cfg.dst_addr);
 		transize = ffs(dch->slave_cfg.dst_addr_width) - 1;
 	} else {
-		dev_addr = dch->slave_cfg.src_addr;
+		dev_addr = d350_translate_addr(dmac, dch->slave_cfg.src_addr);
 		transize = ffs(dch->slave_cfg.src_addr_width) - 1;
 	}
 
@@ -967,10 +1000,13 @@ static struct dma_async_tx_descriptor *d350_prep_dma_cyclic(
 		cmd[14] = upper_32_bits(next_cmd_phys);
 		cmd[15] = 0;	/* Padding */
 
-		dev_dbg(dev, "cyclic: period[%zu] src=%pad dst=%pad xsize=%u next=%pad\n",
+		dev_info(dev, "cyclic: period[%zu] src=%pad dst=%pad xsize=%u next=%pad\n",
 			i, &src_addr, &dst_addr, xsize, &next_cmd_phys);
 	}
 
+	dev_info(dev, "cyclic: descriptor created OK, periods=%zu cmdlink_phys=%pad\n",
+		 desc->num_periods, &desc->cmdlink_phys);
+
 	return vchan_tx_prep(&dch->vc, &desc->vd, flags);
 }
 
@@ -1077,6 +1113,13 @@ static int d350_probe(struct platform_device *pdev)
 	dmac->base = base;
 	platform_set_drvdata(pdev, dmac);
 
+	/* Initialize reserved memory region if specified in DT */
+	ret = of_reserved_mem_device_init(dev);
+	if (ret && ret != -ENODEV) {
+		dev_err(dev, "Failed to initialize reserved memory: %d\n", ret);
+		goto err_pm_put;
+	}
+
 	reg = readl_relaxed(base + DMAINFO + DMA_BUILDCFG1);
 	dmac->nreq = FIELD_GET(DMA_CFG_NUM_TRIGGER_IN, reg);
 
@@ -1218,6 +1261,7 @@ static void d350_remove(struct platform_device *pdev)
 
 	of_dma_controller_free(pdev->dev.of_node);
 	dma_async_device_unregister(&dmac->dma);
+	of_reserved_mem_device_release(&pdev->dev);
 	pm_runtime_put_sync(&pdev->dev);
 	pm_runtime_disable(&pdev->dev);
 }
