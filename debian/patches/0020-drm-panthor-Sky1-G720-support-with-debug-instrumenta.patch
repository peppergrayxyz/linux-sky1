+# GPU Panthor Sky1 Vendor Driver Analysis
+
+**Date**: 2025-12-01
+**Hardware**: Radxa Orion O6 (CIX Sky1 SoC)
+**GPU**: ARM Immortalis G720 MC10 (arch 12.8)
+**Kernel**: Linux 6.18-rc7
+
+---
+
+## Executive Summary
+
+This document details a comprehensive investigation comparing the vendor DKMS GPU driver (kbase) with the mainline Panthor driver for the CIX Sky1 SoC. The goal is to identify all Sky1-specific initialization and configuration that must be ported to Panthor for GPU rendering to work.
+
+**Critical Finding (2025-12-01)**: The vendor kernel uses **kbase** (mali_kbase), NOT panthor, for GPU operation:
+- Vendor DT: `compatible = "arm,mali-valhall"` → kbase driver
+- Mainline DT: `compatible = "cix,sky1-mali"` → panthor driver
+
+**All hardware initialization workarounds have been ported** (Q-channel, AMBA_ENABLE, LS_MEM, PWR_OVERRIDE1, etc.), but GPU rendering still fails with "CSG update request timedout". This indicates a fundamental difference in how kbase vs panthor handles CSF firmware communication.
+
+**Status**: Hardware init matches vendor, but panthor CSF interface may need upstream fixes for G720.
+
+---
+
+## Investigation Methodology
+
+### 1. Source Identification
+
+Located all Sky1/CIX-specific code in vendor DKMS driver:
+
+```bash
+find /home/radxa/cix-drivers-dkms/src/gpu -type f \( -name "*.c" -o -name "*.h" \) \
+  | xargs grep -l -i "sky1\|cix\|CONFIG_ARCH_CIX"
+```
+
+**Key files identified**:
+- `platform/sky1/mali_kbase_config_platform.h` - Platform configuration header
+- `platform/sky1/mali_kbase_config_sky1.c` - Platform initialization
+- `platform/sky1/mali_kbase_runtime_pm.c` - Power management callbacks
+- `backend/gpu/mali_kbase_pm_driver.c` - PM driver with LS_MEM counter init
+- `backend/gpu/mali_kbase_cache_policy_backend.c` - Coherency configuration
+
+### 2. Register Mapping
+
+Cross-referenced vendor register enums with actual offsets:
+
+| Register | Vendor Name | Offset | Purpose |
+|----------|-------------|--------|---------|
+| RCSU PGCTRL | `GPU_RCSU_HWREG_PGCTRL` | 0x218 | Q-channel clock gating |
+| RCSU STRAP_PIN1 | `GPU_RCSU_HWREG_STRAP_PIN1` | 0x304 | Shader core harvesting |
+| LS_MEM CSHW | `GPU_RESERVED__CSHW` | 0x306C | Performance counter config |
+| LS_MEM SHADER | `GPU_RESERVED__SHADER` | 0x3070 | Performance counter config |
+| LS_MEM TILE | `GPU_RESERVED__TILE` | 0x3074 | Performance counter config |
+| LS_MEM MEMSYS | `GPU_RESERVED__MEMSYS` | 0x307C | Performance counter config |
+| CONFIG_INIT | `GPU_RESERVED__CONFIG_INIT` | 0x3068 | Counter initialization trigger |
+| AMBA_ENABLE | `GPU_CONTROL__AMBA_ENABLE` | 0x304 | Coherency protocol (arch12+) |
+| PWR_KEY | `GPU_CONTROL__PWR_KEY` | GPU reg | Power override unlock |
+| PWR_OVERRIDE1 | `GPU_CONTROL__PWR_OVERRIDE1` | GPU reg | Power transition latency |
+
+### 3. Execution Flow Tracing
+
+Traced vendor initialization by following function call chains:
+
+```
+probe
+  → kbase_platform_sky1_init()
+  → pm_callback_power_on()
+    → enable_gpu_power_control()
+    → execute_gpu_reset()
+    → gpu_qchannel_clock_gating_switch(true)
+  → [L2 power on path in pm_driver.c]
+    → kbase_enable_ls_mem_counter()
+    → kbase_cache_set_coherency_mode()
+    → kbase_amba_set_shareable_cache_support()
+```
+
+---
+
+## Vendor Driver Analysis
+
+### Platform Initialization (`kbase_platform_sky1_init`)
+
+```c
+static int kbase_platform_sky1_init(struct kbase_device *kbdev)
+{
+    // 1. Attach power domains
+    sky1_gpu_attach_pd(kbdev);  // pd_gpu and perf domains
+
+    // 2. Get reset control
+    kbdev->gpu_reset = devm_reset_control_get(kbdev->dev, "gpu_reset");
+
+    // 3. ioremap PM shared addresses
+    kbdev->clk_response_addr = ioremap(PM_CLK_RESPONSE_ADDR, SZ_4K);
+    kbdev->dynamic_power_addr = ioremap(PM_POWER_SHARE_ADDR, SZ_4K);
+
+    // 4. Read shader core harvesting
+    harvesting_reg_val = sky1_rcsu_reg_read32(kbdev, GPU_RCSU_HWREG_STRAP_PIN1);
+    kbdev->harvesting_core_mask = ~((harvesting_reg_val & 0xFFFFFF0) >> 4)
+                                   & MALI_TITAN_MC10_CORE_MASK;
+}
+```
+
+### Power-On Sequence (`pm_callback_power_on`)
+
+```c
+static int pm_callback_power_on(struct kbase_device *kbdev)
+{
+    // 1. Enable clocks and regulators
+    enable_gpu_power_control(kbdev);
+
+    // 2. First power-on only: reset + Q-channel enable
+    if (need_reset_flag) {
+        execute_gpu_reset(kbdev);           // Assert + deassert reset
+        gpu_qchannel_clock_gating_switch(kbdev, true);  // RCSU 0x218
+        need_reset_flag = false;
+    }
+    return 1;
+}
+```
+
+### Q-Channel Clock Gating
+
+```c
+static int gpu_qchannel_clock_gating_switch(struct kbase_device *kbdev, bool enable)
+{
+    uint32_t reg = sky1_rcsu_reg_read32(kbdev, GPU_RCSU_HWREG_PGCTRL);
+    reg = enable ? (reg | GPU_RCSU_QCHANNEL_CLOCK_GATE_ENABLE) :
+                   (reg & ~GPU_RCSU_QCHANNEL_CLOCK_GATE_ENABLE);
+    sky1_rcsu_reg_write32(kbdev, GPU_RCSU_HWREG_PGCTRL, reg);
+    return 0;
+}
+```
+
+**Purpose**: The Q-channel protocol allows the GPU to communicate with the RCSU (Reset and Clock Sequencing Unit) for dynamic clock gating. Without this, the GPU cannot properly manage its clock states during operation.
+
+### LS_MEM Counter Initialization
+
+Called after L2 power-on in `mali_kbase_pm_driver.c:4442`:
+
+```c
+void kbase_enable_ls_mem_counter(struct kbase_device *kbdev)
+{
+    kbase_reg_write32(kbdev, GPU_RESERVED_ENUM(CSHW), 0xFFFFFFFF);    // 0x306C
+    kbase_reg_write32(kbdev, GPU_RESERVED_ENUM(MEMSYS), 0xFFFFFFFF);  // 0x307C
+    kbase_reg_write32(kbdev, GPU_RESERVED_ENUM(TILE), 0xFFFFFFFF);    // 0x3074
+    kbase_reg_write32(kbdev, GPU_RESERVED_ENUM(SHADER), 0xFFFFFFFF);  // 0x3070
+    kbase_reg_write32(kbdev, GPU_RESERVED_ENUM(CONFIG_INIT), 0x1);    // 0x3068
+}
+```
+
+### Coherency Configuration (Arch 12+)
+
+```c
+void kbase_cache_set_coherency_mode(struct kbase_device *kbdev, u32 mode)
+{
+    kbdev->current_gpu_coherency_mode = mode;
+
+    if (kbdev->gpu_props.gpu_id.arch_id >= GPU_ID_ARCH_MAKE(12, 0, 1)) {
+        // AMBA_ENABLE present from arch 12.0.1
+        u32 val = kbase_reg_read32(kbdev, GPU_CONTROL_ENUM(AMBA_ENABLE));
+        val = AMBA_ENABLE_COHERENCY_PROTOCOL_SET(val, mode);
+        kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(AMBA_ENABLE), val);
+    } else {
+        // Fallback for older architectures
+        kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(COHERENCY_ENABLE), mode);
+    }
+}
+
+void kbase_amba_set_shareable_cache_support(struct kbase_device *kbdev)
+{
+    if (kbdev->system_coherency != COHERENCY_NONE) {
+        u32 val = kbase_reg_read32(kbdev, GPU_CONTROL_ENUM(AMBA_FEATURES));
+        if (AMBA_FEATURES_SHAREABLE_CACHE_SUPPORT_GET(val)) {
+            val = kbase_reg_read32(kbdev, GPU_CONTROL_ENUM(AMBA_ENABLE));
+            val = AMBA_ENABLE_SHAREABLE_CACHE_SUPPORT_SET(val, 1);
+            kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(AMBA_ENABLE), val);
+        }
+    }
+}
+```
+
+**Key insight**: For arch12+ (G720), coherency is configured via `AMBA_ENABLE` (0x304), not the older `GPU_COHERENCY_PROTOCOL` register. Both are at offset 0x304 but used differently.
+
+### Soft Reset Callback
+
+```c
+static int pm_callback_soft_reset(struct kbase_device *kbdev)
+{
+    // Unlock power override register
+    kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(PWR_KEY), 0x2968A819);
+    // Set maximum power transition latency
+    kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(PWR_OVERRIDE1), 0xFFFFFF);
+    // Issue soft reset
+    kbase_reg_write32(kbdev, GPU_CONTROL_ENUM(GPU_COMMAND), GPU_COMMAND_SOFT_RESET);
+    return 0;
+}
+```
+
+### Runtime PM Callbacks
+
+```c
+static int pm_callback_runtime_on(struct kbase_device *kbdev)
+{
+    // Re-enable Q-channel after power gate reset
+    gpu_qchannel_clock_gating_switch(kbdev, true);
+    return 0;
+}
+
+static void pm_callback_runtime_off(struct kbase_device *kbdev)
+{
+    gpu_qchannel_clock_gating_switch(kbdev, false);
+}
+```
+
