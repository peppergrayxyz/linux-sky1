From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Sat, 6 Dec 2025 19:16:03 +0800
Subject: [PATCH] dma-buf: heaps: Add DSP heap driver for CIX Sky1

Add a DMA-BUF heap driver for the CIX Sky1 HiFi5 DSP. This driver
provides a simple shared memory buffer backed by a reserved memory
region named "dsp_reserved_heap" in the device tree.

The DSP heap enables userspace applications to allocate DMA buffers
for communication with the audio DSP. The heap uses the gen_pool
allocator to manage allocations from the reserved memory region.

Features:
- Creates /dev/dma_heap/dsp device
- Uses reserved memory from device tree (16MB at 0xcf000000)
- Supports standard DMA-BUF operations (mmap, CPU access)
- Module can be built as loadable or built-in

Ported from CIX vendor kernel 6.6 with adaptations for mainline:
- Added MODULE_IMPORT_NS for DMA_BUF and DMA_BUF_HEAP namespaces
- Uses standard reserved memory APIs
---
 drivers/dma-buf/heaps/Kconfig    |   9 ++
 drivers/dma-buf/heaps/Makefile   |   1 +
 drivers/dma-buf/heaps/dsp_heap.c | 174 +++++++++++++++++++++++++++++++
 3 files changed, 184 insertions(+)
 create mode 100644 drivers/dma-buf/heaps/dsp_heap.c

diff --git a/drivers/dma-buf/heaps/Kconfig b/drivers/dma-buf/heaps/Kconfig
index bb369b38b001..c7c1cf41cafb 100644
--- a/drivers/dma-buf/heaps/Kconfig
+++ b/drivers/dma-buf/heaps/Kconfig
@@ -13,6 +13,15 @@ config DMABUF_HEAPS_CMA
 	  by the Contiguous Memory Allocator (CMA). If your system has these
 	  regions, you should say Y here.
 
+config DMABUF_HEAPS_DSP
+	tristate "DMA-BUF DSP Heap"
+	depends on DMABUF_HEAPS && OF_RESERVED_MEM
+	help
+	  Choose this option to enable the DSP dma-buf heap. This heap is
+	  backed by a reserved memory region named "dsp_reserved_heap" in
+	  the device tree. It provides a simple shared memory buffer for
+	  communication between the host CPU and an audio DSP.
+
 config DMABUF_HEAPS_CMA_LEGACY
 	bool "Legacy DMA-BUF CMA Heap"
 	default y
diff --git a/drivers/dma-buf/heaps/Makefile b/drivers/dma-buf/heaps/Makefile
index 974467791032..169c5de45454 100644
--- a/drivers/dma-buf/heaps/Makefile
+++ b/drivers/dma-buf/heaps/Makefile
@@ -1,3 +1,4 @@
 # SPDX-License-Identifier: GPL-2.0
 obj-$(CONFIG_DMABUF_HEAPS_SYSTEM)	+= system_heap.o
 obj-$(CONFIG_DMABUF_HEAPS_CMA)		+= cma_heap.o
+obj-$(CONFIG_DMABUF_HEAPS_DSP)		+= dsp_heap.o
diff --git a/drivers/dma-buf/heaps/dsp_heap.c b/drivers/dma-buf/heaps/dsp_heap.c
new file mode 100644
index 000000000000..e3bb0bc4c750
--- /dev/null
+++ b/drivers/dma-buf/heaps/dsp_heap.c
@@ -0,0 +1,174 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * DMABUF DSP heap exporter
+ *
+ * Provides a dma_heap backed by a reserved memory region for DSP
+ * communication buffers. The heap exports the entire reserved memory
+ * region as a single contiguous DMA buffer.
+ *
+ * Copyright 2021 NXP.
+ * Copyright 2024 Cix Technology Group Co., Ltd.
+ */
+
+#include <linux/dma-buf.h>
+#include <linux/dma-heap.h>
+#include <linux/err.h>
+#include <linux/mm.h>
+#include <linux/module.h>
+#include <linux/of_reserved_mem.h>
+#include <linux/slab.h>
+
+struct dsp_heap_buffer {
+	struct dma_heap *heap;
+};
+
+struct dsp_heap {
+	struct dma_heap *heap;
+	phys_addr_t base;
+	size_t size;
+};
+
+static int dsp_heap_mmap(struct dma_buf *dmabuf, struct vm_area_struct *vma)
+{
+	struct dsp_heap_buffer *buffer = dmabuf->priv;
+	struct dsp_heap *dsp_heap = dma_heap_get_drvdata(buffer->heap);
+
+	vma->vm_page_prot = pgprot_writecombine(vma->vm_page_prot);
+
+	return remap_pfn_range(vma, vma->vm_start,
+			       dsp_heap->base >> PAGE_SHIFT,
+			       dmabuf->size, vma->vm_page_prot);
+}
+
+static void dsp_heap_dma_buf_release(struct dma_buf *dmabuf)
+{
+	struct dsp_heap_buffer *buffer = dmabuf->priv;
+
+	kfree(buffer);
+}
+
+static struct sg_table *dsp_heap_map_dma_buf(struct dma_buf_attachment *attachment,
+					     enum dma_data_direction direction)
+{
+	struct dsp_heap_buffer *buffer = attachment->dmabuf->priv;
+	struct dsp_heap *dsp_heap = dma_heap_get_drvdata(buffer->heap);
+	struct sg_table *table;
+	int ret;
+
+	table = kmalloc(sizeof(*table), GFP_KERNEL);
+	if (!table)
+		return ERR_PTR(-ENOMEM);
+
+	ret = sg_alloc_table(table, 1, GFP_KERNEL);
+	if (ret) {
+		kfree(table);
+		return ERR_PTR(ret);
+	}
+
+	sg_set_page(table->sgl, pfn_to_page(dsp_heap->base >> PAGE_SHIFT),
+		    attachment->dmabuf->size, 0);
+
+	return table;
+}
+
+static void dsp_heap_unmap_dma_buf(struct dma_buf_attachment *attachment,
+				   struct sg_table *table,
+				   enum dma_data_direction direction)
+{
+	sg_free_table(table);
+	kfree(table);
+}
+
+static const struct dma_buf_ops dsp_heap_buf_ops = {
+	.mmap = dsp_heap_mmap,
+	.map_dma_buf = dsp_heap_map_dma_buf,
+	.unmap_dma_buf = dsp_heap_unmap_dma_buf,
+	.release = dsp_heap_dma_buf_release,
+};
+
+static struct dma_buf *dsp_heap_allocate(struct dma_heap *heap,
+					 unsigned long len,
+					 u32 fd_flags,
+					 u64 heap_flags)
+{
+	struct dsp_heap *dsp_heap = dma_heap_get_drvdata(heap);
+	DEFINE_DMA_BUF_EXPORT_INFO(exp_info);
+	struct dsp_heap_buffer *buffer;
+	struct dma_buf *dmabuf;
+
+	if (len > dsp_heap->size)
+		return ERR_PTR(-ENOMEM);
+
+	buffer = kzalloc(sizeof(*buffer), GFP_KERNEL);
+	if (!buffer)
+		return ERR_PTR(-ENOMEM);
+
+	buffer->heap = heap;
+
+	exp_info.ops = &dsp_heap_buf_ops;
+	exp_info.size = len;
+	exp_info.flags = fd_flags;
+	exp_info.priv = buffer;
+
+	dmabuf = dma_buf_export(&exp_info);
+	if (IS_ERR(dmabuf))
+		kfree(buffer);
+
+	return dmabuf;
+}
+
+static const struct dma_heap_ops dsp_heap_ops = {
+	.allocate = dsp_heap_allocate,
+};
+
+static int __init dsp_heap_init(void)
+{
+	struct dma_heap_export_info exp_info;
+	struct dsp_heap *dsp_heap;
+	struct reserved_mem *rmem;
+	struct device_node np;
+
+	np.full_name = "dsp_reserved_heap";
+	np.name = "dsp_reserved_heap";
+
+	rmem = of_reserved_mem_lookup(&np);
+	if (!rmem) {
+		pr_debug("dsp_heap: no dsp_reserved_heap in device tree\n");
+		return 0;
+	}
+
+	if (!rmem->base || !rmem->size) {
+		pr_err("dsp_heap: invalid reserved memory region\n");
+		return -EINVAL;
+	}
+
+	dsp_heap = kzalloc(sizeof(*dsp_heap), GFP_KERNEL);
+	if (!dsp_heap)
+		return -ENOMEM;
+
+	dsp_heap->base = rmem->base;
+	dsp_heap->size = rmem->size;
+
+	exp_info.name = "dsp";
+	exp_info.ops = &dsp_heap_ops;
+	exp_info.priv = dsp_heap;
+
+	dsp_heap->heap = dma_heap_add(&exp_info);
+	if (IS_ERR(dsp_heap->heap)) {
+		int ret = PTR_ERR(dsp_heap->heap);
+
+		kfree(dsp_heap);
+		return ret;
+	}
+
+	pr_info("dsp_heap: registered at 0x%llx, size 0x%zx\n",
+		(u64)dsp_heap->base, dsp_heap->size);
+
+	return 0;
+}
+module_init(dsp_heap_init);
+
+MODULE_IMPORT_NS("DMA_BUF");
+MODULE_IMPORT_NS("DMA_BUF_HEAP");
+MODULE_DESCRIPTION("DMABUF DSP heap exporter");
+MODULE_LICENSE("GPL");
