+	pcie_capability_write_dword(rc_pdev, PCI_EXP_LNKCTL, reg);
+	reg = ep_linkctrl_default | PCI_EXP_LNKCTL_ASPM_L1;
+	pcie_capability_write_dword(ep_pdev, PCI_EXP_LNKCTL, reg);
