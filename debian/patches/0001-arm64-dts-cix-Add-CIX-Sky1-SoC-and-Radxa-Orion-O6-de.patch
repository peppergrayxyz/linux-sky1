+static int sky1_pcie_get_max_lane_count(struct sky1_pcie *pcie)
+{
+	int ret = 0;
+
+	switch (pcie->num_lanes) {
+	case 8:
+		ret = 3;
+		break;
+	case 4:
+		ret = 2;
+		break;
+	case 2:
+		ret = 1;
+		break;
+	case 1:
+		ret = 0;
+		break;
+	default:
+		ret = -EINVAL;
+		break;
+	}
+
+	return ret;
+}
