+#define XEC_USBSSP_CHICKEN_BITS_3	0x2230
+
+#define D_XEC_CFG_3XPORT_MODE_VALUE		0xa0031e07
+#define XEC_CFG_3XPORT_MODE_VALUE		0xa0031e07
