+		"null", // [21]
+		"null", // [22]
+		"null", // [23]
+		"null", // [24]
+		"null", // [25]
+		"null", // [26]
+		"null", // [27]
+		"null", // [28]
+		"null", // [29]
+		"null", // [30]
+		"null", // [31]
+	};
+
+	if (code < ERR_MSG_LEN) {
+		if (err == PCIE_LOCAL_ERR0)
+			return local_err0_int_msg[code];
+		else if (err == PCIE_LOCAL_ERR1)
+			return local_err1_int_msg[code];
+	}
+	return "Unknown";
+}
