+/* SPDX-License-Identifier: GPL-2.0 */
+
+#ifndef __LINUX_CDNSP_SKY1_H
+#define __LINUX_CDNSP_SKY1_H
+#include <linux/of_platform.h>
+#include <linux/clk.h>
+#include <linux/reset.h>
+#include <linux/gpio/consumer.h>
+
