From 1b14fc2c5ba4601bee327d3a06f06bcd206fc78d Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Fri, 13 Feb 2026 17:55:33 +1100
Subject: [PATCH 118/118] drm/panthor: add ACE-Lite coherency and NC memattr
 fallback for Sky1

Replace the single boolean coherent field with an enum
panthor_coherency_mode whose values match the GPU_COHERENCY_PROTOCOL
register encoding (ACE_LITE=0, ACE=1, NONE=31).

On CIX Sky1 platforms, enable ACE-Lite bus coherency so GPU L2
evictions route through the CHI fabric HN-F nodes and are absorbed into
the SLC.  However, ACE-Lite alone is not sufficient to guarantee DRAM
visibility for non-snooping masters like the DPU: the GPU L2 may not
evict in time.  Therefore, when no IOMMU is present to override memory
attributes at the bus level, force NC memattr for any non-ACE coherency
mode (both NONE and ACE-Lite).

The GPU hardware supports full ACE (128/256-bit AMBA 4 ACE master) but
the Sky1 platform uses ACE-Lite (DT system-coherency=0).

Also program the SHAREABLE_CACHE_SUPPORT bit in GPU_COHERENCY_PROTOCOL
when reported by GPU_COHERENCY_FEATURES, and add a force_noncoherent
module parameter for debugging.
---
 drivers/gpu/drm/panthor/panthor_device.c | 42 +++++++++++++++++++-----
 drivers/gpu/drm/panthor/panthor_device.h | 25 ++++++++++++--
 drivers/gpu/drm/panthor/panthor_gem.c    |  2 +-
 drivers/gpu/drm/panthor/panthor_gpu.c    | 12 +++++--
 drivers/gpu/drm/panthor/panthor_mmu.c    | 34 ++++++++++++-------
 drivers/gpu/drm/panthor/panthor_regs.h   |  1 +
 6 files changed, 91 insertions(+), 25 deletions(-)

diff --git a/drivers/gpu/drm/panthor/panthor_device.c b/drivers/gpu/drm/panthor/panthor_device.c
index 1c99e8420c9f0..b0db883e247a9 100644
--- a/drivers/gpu/drm/panthor/panthor_device.c
+++ b/drivers/gpu/drm/panthor/panthor_device.c
@@ -5,7 +5,9 @@
 
 #include <linux/clk.h>
 #include <linux/delay.h>
+#include <linux/iommu.h>
 #include <linux/mm.h>
+#include <linux/moduleparam.h>
 #include <linux/of.h>
 #include <linux/platform_device.h>
 #include <linux/pm_domain.h>
@@ -134,21 +136,40 @@ static int sky1_smc_scmi_power_set(struct device *dev, u32 domain, u32 state)
 	return 0;
 }
 
+static bool panthor_force_noncoherent;
+module_param_named(force_noncoherent, panthor_force_noncoherent, bool, 0444);
+MODULE_PARM_DESC(force_noncoherent,
+	"Force GPU to non-coherent mode even when firmware reports coherent");
+
 static int panthor_gpu_coherency_init(struct panthor_device *ptdev)
 {
-	ptdev->coherent = device_get_dma_attr(ptdev->base.dev) == DEV_DMA_COHERENT;
+	bool dma_coherent = device_get_dma_attr(ptdev->base.dev) == DEV_DMA_COHERENT;
 
-	if (!ptdev->coherent)
+	/*
+	 * Sky1 SoC: The GPU hardware supports full ACE (128/256-bit AMBA 4
+	 * ACE master), but the platform uses ACE-Lite (DT system-coherency=0).
+	 * The DPU is non-snooping and reads from SLC/DRAM, so ACE-Lite is the
+	 * correct choice: GPU L2 evictions route through HN-F and are absorbed
+	 * into the SLC, making WB data visible to the DPU without NC memattr.
+	 */
+	if (panthor_is_sky1(ptdev)) {
+		ptdev->coherency_mode = PANTHOR_COHERENCY_ACE_LITE;
+		drm_info(&ptdev->base, "Using ACE-Lite bus coherency (Sky1)\n");
+	} else if (panthor_force_noncoherent || !dma_coherent) {
+		ptdev->coherency_mode = PANTHOR_COHERENCY_NONE;
+	} else {
+		ptdev->coherency_mode = PANTHOR_COHERENCY_ACE_LITE;
+	}
+
+	if (ptdev->coherency_mode == PANTHOR_COHERENCY_NONE)
 		return 0;
 
-	/* Check if the ACE-Lite coherency protocol is actually supported by the GPU.
-	 * ACE protocol has never been supported for command stream frontend GPUs.
-	 */
-	if ((gpu_read(ptdev, GPU_COHERENCY_FEATURES) &
-		      GPU_COHERENCY_PROT_BIT(ACE_LITE)))
+	/* Verify hardware supports the selected protocol. */
+	if (gpu_read(ptdev, GPU_COHERENCY_FEATURES) &
+	    GPU_COHERENCY_PROT_BIT(ACE_LITE))
 		return 0;
 
-	drm_err(&ptdev->base, "Coherency not supported by the device");
+	drm_err(&ptdev->base, "ACE-Lite not supported by hardware");
 	return -ENOTSUPP;
 }
 
@@ -578,6 +599,11 @@ int panthor_device_init(struct panthor_device *ptdev)
 	if (ret)
 		goto err_unplug_gpu;
 
+	if (ptdev->coherency_mode == PANTHOR_COHERENCY_NONE &&
+	    !device_iommu_mapped(ptdev->base.dev))
+		drm_info(&ptdev->base,
+			 "GPU not behind IOMMU; using non-cacheable memory attributes\n");
+
 	ret = panthor_mmu_init(ptdev);
 	if (ret)
 		goto err_unplug_gpu;
diff --git a/drivers/gpu/drm/panthor/panthor_device.h b/drivers/gpu/drm/panthor/panthor_device.h
index 75817ca820a81..d07b4968f4961 100644
--- a/drivers/gpu/drm/panthor/panthor_device.h
+++ b/drivers/gpu/drm/panthor/panthor_device.h
@@ -19,6 +19,27 @@
 #include <drm/gpu_scheduler.h>
 #include <drm/panthor_drm.h>
 
+/**
+ * enum panthor_coherency_mode - GPU bus coherency protocol
+ *
+ * Determines how the GPU participates in the system coherency fabric.
+ * Values match the GPU_COHERENCY_PROTOCOL register encoding.
+ */
+enum panthor_coherency_mode {
+	/** @PANTHOR_COHERENCY_ACE_LITE: GPU is RN-I on CHI fabric.
+	 * L2 evictions route through HN-F/SLC, making WB data visible
+	 * to non-snooping masters. No NC memattr needed. */
+	PANTHOR_COHERENCY_ACE_LITE = 0,
+
+	/** @PANTHOR_COHERENCY_ACE: Full CPU-GPU coherency via snooping.
+	 * Page table walks use outer-shareable, GEM uses cached mappings. */
+	PANTHOR_COHERENCY_ACE = 1,
+
+	/** @PANTHOR_COHERENCY_NONE: GPU outside coherency domain.
+	 * Requires NC memattr when no IOMMU is present. */
+	PANTHOR_COHERENCY_NONE = 31,
+};
+
 struct panthor_csf;
 struct panthor_csf_ctx;
 struct panthor_device;
@@ -143,8 +164,8 @@ struct panthor_device {
 		struct clk *backup[2];
 	} clks;
 
-	/** @coherent: True if the CPU/GPU are memory coherent. */
-	bool coherent;
+	/** @coherency_mode: GPU bus coherency protocol. */
+	enum panthor_coherency_mode coherency_mode;
 
 	/** @gpu_info: GPU information. */
 	struct drm_panthor_gpu_info gpu_info;
diff --git a/drivers/gpu/drm/panthor/panthor_gem.c b/drivers/gpu/drm/panthor/panthor_gem.c
index fbde78db270a4..f7320a1d5fa3d 100644
--- a/drivers/gpu/drm/panthor/panthor_gem.c
+++ b/drivers/gpu/drm/panthor/panthor_gem.c
@@ -237,7 +237,7 @@ struct drm_gem_object *panthor_gem_create_object(struct drm_device *ddev, size_t
 		return ERR_PTR(-ENOMEM);
 
 	obj->base.base.funcs = &panthor_gem_funcs;
-	obj->base.map_wc = !ptdev->coherent;
+	obj->base.map_wc = ptdev->coherency_mode != PANTHOR_COHERENCY_ACE;
 	mutex_init(&obj->label.lock);
 
 	panthor_gem_debugfs_bo_init(obj);
diff --git a/drivers/gpu/drm/panthor/panthor_gpu.c b/drivers/gpu/drm/panthor/panthor_gpu.c
index e711a0a8da9ec..b292c0038d6cd 100644
--- a/drivers/gpu/drm/panthor/panthor_gpu.c
+++ b/drivers/gpu/drm/panthor/panthor_gpu.c
@@ -51,8 +51,16 @@ struct panthor_gpu {
 
 static void panthor_gpu_coherency_set(struct panthor_device *ptdev)
 {
-	gpu_write(ptdev, GPU_COHERENCY_PROTOCOL,
-		ptdev->coherent ? GPU_COHERENCY_PROT_BIT(ACE_LITE) : GPU_COHERENCY_NONE);
+	u32 val = ptdev->coherency_mode;
+
+	if (val != PANTHOR_COHERENCY_NONE) {
+		u32 features = gpu_read(ptdev, GPU_COHERENCY_FEATURES);
+
+		if (features & GPU_COHERENCY_SHAREABLE_CACHE)
+			val |= GPU_COHERENCY_SHAREABLE_CACHE;
+	}
+
+	gpu_write(ptdev, GPU_COHERENCY_PROTOCOL, val);
 }
 
 static void panthor_gpu_l2_config_set(struct panthor_device *ptdev)
diff --git a/drivers/gpu/drm/panthor/panthor_mmu.c b/drivers/gpu/drm/panthor/panthor_mmu.c
index 7761c45bc75e5..791965a720bd1 100644
--- a/drivers/gpu/drm/panthor/panthor_mmu.c
+++ b/drivers/gpu/drm/panthor/panthor_mmu.c
@@ -773,7 +773,7 @@ int panthor_vm_active(struct panthor_vm *vm)
 		   AS_TRANSCFG_PTW_RA |
 		   AS_TRANSCFG_ADRMODE_AARCH64_4K |
 		   AS_TRANSCFG_INA_BITS(55 - va_bits);
-	if (ptdev->coherent)
+	if (ptdev->coherency_mode == PANTHOR_COHERENCY_ACE)
 		transcfg |= AS_TRANSCFG_PTW_SH_OS;
 
 	/* If the VM is re-activated, we clear the fault. */
@@ -1943,7 +1943,8 @@ void panthor_vm_heaps_sizes(struct panthor_file *pfile, struct drm_memory_stats
 	xa_unlock(&pfile->vms->xa);
 }
 
-static u64 mair_to_memattr(u64 mair, bool coherent)
+static u64 mair_to_memattr(u64 mair, enum panthor_coherency_mode mode,
+			   bool has_iommu)
 {
 	u64 memattr = 0;
 	u32 i;
@@ -1961,19 +1962,27 @@ static u64 mair_to_memattr(u64 mair, bool coherent)
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
 				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
 				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(false, false);
+		} else if (mode != PANTHOR_COHERENCY_ACE && !has_iommu) {
+			/* GPU not fully coherent and no IOMMU to override
+			 * memory attributes at the bus level. Even with
+			 * ACE-Lite, GPU L2 may not evict to SLC in time
+			 * for non-snooping masters like the DPU.
+			 * Force NC to guarantee DRAM visibility.
+			 */
+			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_NC |
+				   AS_MEMATTR_AARCH64_SH_MIDGARD_INNER |
+				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(false, false);
 		} else {
 			out_attr = AS_MEMATTR_AARCH64_INNER_OUTER_WB |
 				   AS_MEMATTR_AARCH64_INNER_ALLOC_EXPL(inner & 1, inner & 2);
-			/* Use SH_MIDGARD_INNER mode when device isn't coherent,
-			 * so SH_IS, which is used when IOMMU_CACHE is set, maps
-			 * to Mali's internal-shareable mode. As per the Mali
-			 * Spec, inner and outer-shareable modes aren't allowed
-			 * for WB memory when coherency is disabled.
+			/* Use SH_MIDGARD_INNER mode when device isn't fully
+			 * coherent, so SH_IS, which is used when IOMMU_CACHE
+			 * is set, maps to Mali's internal-shareable mode.
 			 * Use SH_CPU_INNER mode when coherency is enabled, so
-			 * that SH_IS actually maps to the standard definition of
-			 * inner-shareable.
+			 * that SH_IS actually maps to the standard definition
+			 * of inner-shareable.
 			 */
-			if (!coherent)
+			if (mode != PANTHOR_COHERENCY_ACE)
 				out_attr |= AS_MEMATTR_AARCH64_SH_MIDGARD_INNER;
 			else
 				out_attr |= AS_MEMATTR_AARCH64_SH_CPU_INNER;
@@ -2326,7 +2335,7 @@ panthor_vm_create(struct panthor_device *ptdev, bool for_mcu,
 		.pgsize_bitmap	= SZ_4K | SZ_2M,
 		.ias		= va_bits,
 		.oas		= pa_bits,
-		.coherent_walk	= ptdev->coherent,
+		.coherent_walk	= ptdev->coherency_mode == PANTHOR_COHERENCY_ACE,
 		.tlb		= &mmu_tlb_ops,
 		.iommu_dev	= ptdev->base.dev,
 		.alloc		= alloc_pt,
@@ -2349,7 +2358,8 @@ panthor_vm_create(struct panthor_device *ptdev, bool for_mcu,
 		goto err_sched_fini;
 
 	mair = io_pgtable_ops_to_pgtable(vm->pgtbl_ops)->cfg.arm_lpae_s1_cfg.mair;
-	vm->memattr = mair_to_memattr(mair, ptdev->coherent);
+	vm->memattr = mair_to_memattr(mair, ptdev->coherency_mode,
+				      device_iommu_mapped(ptdev->base.dev));
 
 	mutex_lock(&ptdev->mmu->vm.lock);
 	list_add_tail(&vm->node, &ptdev->mmu->vm.list);
diff --git a/drivers/gpu/drm/panthor/panthor_regs.h b/drivers/gpu/drm/panthor/panthor_regs.h
index 14296e2f94a98..77add31facd68 100644
--- a/drivers/gpu/drm/panthor/panthor_regs.h
+++ b/drivers/gpu/drm/panthor/panthor_regs.h
@@ -122,6 +122,7 @@
 #define   GPU_COHERENCY_ACE_LITE			0
 #define   GPU_COHERENCY_ACE				1
 #define   GPU_COHERENCY_NONE				31
+#define   GPU_COHERENCY_SHAREABLE_CACHE			BIT(5)
 
 #define MCU_CONTROL					0x700
 #define MCU_CONTROL_ENABLE				1
