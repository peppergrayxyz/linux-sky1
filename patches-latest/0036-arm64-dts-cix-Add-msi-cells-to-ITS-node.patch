From 5c0c68afb88a499b48fd5121d2b3b8b34e8d721f Mon Sep 17 00:00:00 2001
From: Entrpi <entrpi@proton.me>
Date: Thu, 5 Feb 2026 09:28:05 +1100
Subject: [PATCH 036/118] arm64: dts: cix: Add #msi-cells to ITS node

Add the required #msi-cells = <1> property to the GICv3 ITS node as
specified by the arm,gic-v3-its binding. This is needed for platform
MSI consumers that reference the ITS via msi-parent with a device ID
cell.

The SMMU nodes do not get msi-parent: the vendor ACPI IORT table
confirms all three SMMU instances (pciehub, mmhub, syshub) have
DeviceID Valid = 0 and use wired GSIVs exclusively for their own
interrupt delivery.

diff --git a/arch/arm64/boot/dts/cix/sky1.dtsi b/arch/arm64/boot/dts/cix/sky1.dtsi
index bcffb970f492a..3eaca2bee81e6 100644
--- a/arch/arm64/boot/dts/cix/sky1.dtsi
+++ b/arch/arm64/boot/dts/cix/sky1.dtsi
@@ -2577,6 +2577,7 @@ gic: interrupt-controller@0e001000 {
 			its_pcie: its@e050000 {
 				compatible = "arm,gic-v3-its";
 				msi-controller;
+				#msi-cells = <1>;
 				reg = <0x0 0x0e050000 0x0 0x30000>;
 			};
 		};
